---
import MainLayout from "../layouts/MainLayout.astro";
import NavigationAPU from "../components/NavigationAPU.astro";
import Footer from "../components/Footer.astro";
import WireframePageHeroAPU from "../sections/WireframePageHeroAPU.astro";
import WireframePageSectionAPU from "../sections/WireframePageSectionAPU.astro";
---

<MainLayout title="Tentang APU" description="Profil, nilai, dan arah pengembangan Agung Putra University.">
  <NavigationAPU />
  <main>
    <WireframePageHeroAPU kicker="Tentang Kampus" title="Agung Putra University" description="Kampus modern yang menyiapkan lulusan berkarakter, adaptif, dan siap berkontribusi." primaryHref="#profil" primaryLabel="Lihat Profil" secondaryHref="/apu/leadership" secondaryLabel="Kenali Pimpinan" />
    <WireframePageSectionAPU id="profil" kicker="Profil" title="Identitas Institusi" description="APU bertumbuh dengan komitmen mutu, inovasi, dan pelayanan mahasiswa." bullets={["Lingkungan belajar futuristik dengan nuansa hijau yang nyaman.","Pendekatan pembelajaran kolaboratif lintas bidang.","Fokus pada kompetensi nyata untuk masa depan karier."]} />
    <WireframePageSectionAPU id="nilai" kicker="Nilai" title="Nilai Inti Kampus" description="Nilai inti menjadi fondasi budaya belajar dan pelayanan akademik." bullets={["Integritas dalam proses akademik dan administratif.","Kepedulian sosial untuk dampak yang berkelanjutan.","Profesionalisme dalam setiap layanan mahasiswa."]} />
    <WireframePageSectionAPU id="sejarah" kicker="Sejarah" title="Jejak Perkembangan Kampus" description="Linimasa sejarah institusi sedang disiapkan dalam format visual interaktif." />
  </main>
  <Footer />
</MainLayout>
