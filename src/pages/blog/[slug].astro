---
import Layout from '../../layouts/Layout.astro';
import { client, readItems } from '../../lib/directus';

const slug = Astro.params.slug;

let post: any | null = null;
try {
  const posts = await client.request(
    readItems('posts', {
      filter: {
        _and: [
          { status: { _eq: 'published' } },
          { slug: { _eq: slug } },
        ],
      },
      limit: 1,
    })
  );
  post = posts[0] ?? null;
} catch (error) {
  console.error('Failed to load Directus post:', error);
}
---

<Layout title={post ? `${post.title} | Kimi Claw` : 'Post Not Found | Kimi Claw'}>
  {post ? (
    <article class="prose max-w-none">
      <h1 class="text-3xl font-bold mb-2">{post.title}</h1>
      <time class="text-slate-500 block mb-6">{post.published_date}</time>
      <div class="mt-6" set:html={post.content} />
    </article>
  ) : (
    <article class="prose max-w-none">
      <h1 class="text-3xl font-bold mb-2">Post not found</h1>
      <p class="text-slate-600">This post does not exist or is not published.</p>
    </article>
  )}
</Layout>
