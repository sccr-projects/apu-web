---
import MainLayout from "../layouts/MainLayout.astro";
import NavigationAPU from "../components/NavigationAPU.astro";
import Footer from "../components/Footer.astro";
import AkademikHero from "../sections/AkademikHero.astro";
import WireframePageSectionAPU from "../sections/WireframePageSectionAPU.astro";
import AkademikProgramSection from "../sections/AkademikProgramSection.astro";
import AkademikCalendarSection from "../sections/AkademikCalendarSection.astro";
---

<MainLayout title="Akademik APU" description="Program studi, kurikulum, dan dukungan belajar di APU.">
  <NavigationAPU />
  <main>
    <AkademikHero
      kicker="Akademik"
      title="Pembelajaran yang Relevan untuk Dunia Kerja"
      description="Program akademik APU dirancang adaptif, terukur, dan dekat dengan kebutuhan industri."
      primaryHref="#program"
      primaryLabel="Jelajahi Program"
      secondaryHref="/pendaftaran"
      secondaryLabel="Mulai Pendaftaran"
    />
    <AkademikProgramSection />
    <AkademikCalendarSection />
    <!-- <WireframePageSectionAPU id="dukungan" kicker="Dukungan" title="Layanan Akademik Mahasiswa" description="Tim akademik membantu mahasiswa menjaga progres studi dari awal sampai lulus." bullets={["Bimbingan dosen wali untuk perencanaan mata kuliah.","Klinik belajar untuk pendalaman materi inti.","Monitoring capaian semester dan rencana perbaikan terarah."]} ctaHref="/apu/student-life-services" ctaLabel="Lihat Layanan Mahasiswa" />
    <WireframePageSectionAPU id="katalog" kicker="Katalog" title="Katalog Mata Kuliah Digital" description="Katalog interaktif per semester sedang disiapkan agar calon mahasiswa bisa eksplor lebih detail." /> -->
  </main>
  <Footer />
</MainLayout>
