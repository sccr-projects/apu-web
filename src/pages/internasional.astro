---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import Footer from "@components/Footer.astro";
import WireframePageHeroAPU from "@sections/WireframePageHeroAPU.astro";
import WireframePageSectionAPU from "@sections/WireframePageSectionAPU.astro";
---

<MainLayout title="International Programs | APU" description="Global partnerships, mobility, and international opportunities for APU students.">
  <NavigationAPU />
  <main>
    <WireframePageHeroAPU kicker="Internasional" title="Perluas Wawasan ke Jejaring Global" description="APU membuka peluang kolaborasi lintas negara untuk memperkaya pengalaman akademik mahasiswa." primaryHref="#kemitraan" primaryLabel="Lihat Kemitraan" secondaryHref="/apu/research" secondaryLabel="Kolaborasi Riset" />
    <WireframePageSectionAPU id="kemitraan" kicker="Kemitraan" title="Jejaring Mitra Internasional" description="Kemitraan strategis mendukung pertukaran pengalaman belajar dan riset bersama." bullets={["Program kolaborasi akademik dengan institusi luar negeri.","Sesi kuliah tamu dari praktisi dan akademisi internasional.","Akses proyek lintas budaya untuk mahasiswa terpilih."]} />
    <WireframePageSectionAPU id="mobilitas" kicker="Mobilitas" title="Peluang Mahasiswa" description="Peluang mobilitas dibuka bertahap sesuai kesiapan akademik dan bahasa mahasiswa." bullets={["Program pertukaran mahasiswa jangka pendek.","Kelas kolaboratif virtual lintas kampus.","Pendampingan persiapan dokumen dan wawancara."]} ctaHref="/apu/contact" ctaLabel="Konsultasi Program" />
    <WireframePageSectionAPU id="beasiswa-global" kicker="Beasiswa" title="Skema Dukungan Internasional" description="Informasi dukungan pendanaan internasional sedang dikembangkan bersama mitra terkait." />
  </main>
  <Footer />
</MainLayout>
