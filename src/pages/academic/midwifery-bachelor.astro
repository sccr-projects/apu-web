---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import MidwiferyBachelorProgramHeroSection from "@sections/academic/program/MidwiferyBachelorProgramHeroSection.astro";
import ProgramStrengthsSection from "@sections/academic/program/ProgramStrengthsSection.astro";
import ProgramValuesSection from "@sections/academic/program/ProgramValuesSection.astro";
// import MidwiferyBachelorProgramCareersSection from "@sections/academic/program/MidwiferyBachelorProgramCareersSection.astro";
import MidwiferyBachelorProgramFacultySection from "@sections/academic/program/MidwiferyBachelorProgramFacultySection.astro";
import ContactSection from "@sections/ContactSection.astro";
import Footer from "@components/Footer.astro";
import ProgramMsgFromHead from "@sections/academic/program/ProgramMsgFromHead.astro";
import ProgramStrengthsBentoSection from "@sections/academic/program/ProgramStrengthsBentoSection.astro";
import ProgramVisionMissionSection from "@sections/academic/program/ProgramVisionMissionSection.astro";
import { midwiferyBachelorStrengthsBento } from "@data/program-strengths-bento";
import { midwiferyBachelorProgram } from "@data/program-details";
import { midwiferyBachelorLeadershipMessage as leadershipMessage } from "@data/academic-programs";
import BiomedicalGamePreviewSection from "@sections/academic/program/BiomedicalGamePreviewSection.astro";

---

<MainLayout
  title="Program Studi Keperawatan | Agung Putra University"
  description="Program Studi Keperawatan S1 APU — membekali mahasiswa dengan kompetensi kebidanan, kesehatan ibu dan anak, persalinan, perawatan bayi baru lahir, praktik klinis, dan pelayanan kesehatan masyarakat."
>
  <NavigationAPU />

  <MidwiferyBachelorProgramHeroSection />
  <ProgramMsgFromHead variant="light" data={leadershipMessage} />
  <!-- <BiomedicalGamePreviewSection /> -->
  <!-- <ProgramStrengthsSection /> -->
  <ProgramStrengthsBentoSection data={midwiferyBachelorStrengthsBento} />
  <ProgramVisionMissionSection data={midwiferyBachelorProgram} />
  <!-- <ProgramValuesSection /> -->
  <!-- <MidwiferyBachelorProgramCareersSection /> -->
  <MidwiferyBachelorProgramFacultySection />
  <ContactSection />
  <Footer />
</MainLayout>
