---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import LawProgramHeroSection from "@sections/academic/program/LawProgramHeroSection.astro";
import ProgramStrengthsSection from "@sections/academic/program/ProgramStrengthsSection.astro";
import ProgramValuesSection from "@sections/academic/program/ProgramValuesSection.astro";
import LawProgramCareersSection from "@sections/academic/program/LawProgramCareersSection.astro";
import LawProgramFacultySection from "@sections/academic/program/LawProgramFacultySection.astro";
import ContactSection from "@sections/ContactSection.astro";
import Footer from "@components/Footer.astro";
import ProgramMsgFromHead from "@sections/academic/program/ProgramMsgFromHead.astro";
import ProgramStrengthsBentoSection from "@sections/academic/program/ProgramStrengthsBentoSection.astro";
import ProgramVisionMissionSection from "@sections/academic/program/ProgramVisionMissionSection.astro";
import { lawStrengthsBento } from "@data/program-strengths-bento";
import { lawProgram } from "@data/program-details";
import { lawLeadershipMessage as leadershipMessage } from "@data/academic-programs";
import BiomedicalGamePreviewSection from "@sections/academic/program/BiomedicalGamePreviewSection.astro";

---

<MainLayout
  title="Program Studi Hukum | Agung Putra University"
  description="Program Studi Hukum S1 APU — jelajahi dunia mikroskopis biomedical science dengan fasilitas laboratorium modern dan dosen berkualifikasi internasional."
>
  <NavigationAPU />

  <LawProgramHeroSection />
  <ProgramMsgFromHead variant="light" data={leadershipMessage} />
  <!-- <BiomedicalGamePreviewSection /> -->
  <!-- <ProgramStrengthsSection /> -->
  <ProgramStrengthsBentoSection data={lawStrengthsBento} />
  <ProgramVisionMissionSection data={lawProgram} />
  <!-- <ProgramValuesSection /> -->
  <!-- <LawProgramCareersSection /> -->
  <LawProgramFacultySection />
  <ContactSection />
  <Footer />
</MainLayout>
