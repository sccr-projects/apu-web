---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import Footer from "@components/Footer.astro";
import AcademicHero from "@sections/academic/AcademicHero.astro";
import WireframePageSectionAPU from "@sections/WireframePageSectionAPU.astro";
import AcademicProgramSection from "@sections/academic/AcademicProgramSection.astro";
import AcademicCalendarSection from "@sections/academic/AcademicCalendarSection.astro";
import ProgramsSectionAPU from "@sections/ProgramsSectionAPU.astro";
import AboutVisionMission from "@/sections/about/AboutVisionMission.astro";
import LecturersSection from "@/sections/LecturersSection.astro";
---

<MainLayout title="APU Academics" description="Study programs, curriculum, and learning support at APU.">
  <NavigationAPU />
  <main>
    <AcademicHero
      kicker="Academics"
      title="Relevant Learning for the Workforce"
      description="APU's academic programs are designed to be adaptive, measurable, and aligned with industry needs."
      primaryHref="#program"
      primaryLabel="Explore Programs"
      secondaryHref="/pendaftaran"
      secondaryLabel="Start Registration"
    />
    <AboutVisionMission />
    <AcademicProgramSection />
    <ProgramsSectionAPU />
    <LecturersSection />
    <AcademicCalendarSection />
    <!-- <WireframePageSectionAPU id="dukungan" kicker="Support" title="Student Academic Services" description="The academic team helps students maintain their study progress from start to finish." bullets={["Academic advisor guidance for course planning.","Learning clinics for deepening core material.","Semester achievement monitoring and targeted improvement plans."]} ctaHref="/apu/student-life-services" ctaLabel="See Student Services" />
    <WireframePageSectionAPU id="katalog" kicker="Catalog" title="Digital Course Catalog" description="An interactive semester catalog is being prepared so prospective students can explore in more detail." /> -->
  </main>
  <Footer />
</MainLayout>
