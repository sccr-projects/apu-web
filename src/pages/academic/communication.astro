---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import ProgramHeroSection from "@sections/academic/program/ProgramHeroSection.astro";
import ProgramValuesSection from "@sections/academic/program/ProgramValuesSection.astro";
import ProgramCareersSection from "@sections/academic/program/ProgramCareersSection.astro";
import ProgramFacultySpotlightSection from "@sections/academic/program/ProgramFacultySpotlightSection.astro";
import ContactSection from "@sections/ContactSection.astro";
import Footer from "@components/Footer.astro";
import ProgramMsgFromHead from "@sections/academic/program/ProgramMsgFromHead.astro";
import ProgramStrengthsBentoSection from "@sections/academic/program/ProgramStrengthsBentoSection.astro";
import ProgramVisionMissionSection from "@sections/academic/program/ProgramVisionMissionSection.astro";
import { communicationStrengthsBento } from "@data/program-strengths-bento";
import { communicationProgram } from "@data/program-details";
import { communicationLeadershipMessage as leadershipMessage } from "@data/academic-programs";
import { communicationHero } from "@data/program-heroes";
import { communicationCareers } from "@data/program-careers";
import { getLecturersByProgram } from "@data/lecturers";
import { programFacultyDescriptions } from "@data/academic-programs";
import { communicationValues } from "@data/program-values";
import BiomedicalGamePreviewSection from "@sections/academic/program/BiomedicalGamePreviewSection.astro";

const lecturers = getLecturersByProgram("communication");
const description = programFacultyDescriptions.communication;

---

<MainLayout
  title="Program Studi Communication Science | Agung Putra University"
  description="Program Studi Communication Science S1 APU — membekali mahasiswa dengan keahlian komunikasi strategis, media digital, public relations, jurnalistik, branding, dan industri kreatif."
>
  <NavigationAPU />

  <ProgramHeroSection data={communicationHero} />
  <ProgramMsgFromHead variant="light" data={leadershipMessage} />
  <!-- <BiomedicalGamePreviewSection /> -->
  <ProgramStrengthsBentoSection data={communicationStrengthsBento} />
  <ProgramVisionMissionSection data={communicationProgram} variant="communication" />
  <!-- <ProgramValuesSection data={communicationValues} /> -->
  <ProgramCareersSection data={communicationCareers} />
  <ProgramFacultySpotlightSection lecturers={lecturers} description={description} />
  <ContactSection />
  <Footer />
</MainLayout>
