---
import MainLayout from "@layouts/MainLayout.astro";
import NavigationAPU from "@components/NavigationAPU.astro";
import Footer from "@components/Footer.astro";
import ScrollReveal from "@components/ScrollReveal.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CtaButton from "@components/CtaButton.astro";
import heroImage from "@/assets/images/international-hero.jpg";
import { contact } from "@data/contact";
import { internship, exchange, research } from "@data/international-content";

const programs = [
  {
    icon: "globe",
    title: "Internship",
    subtitle: "Agung Putra University",
    desc: "The SCCR Internship Program offers students and young professionals the opportunity to gain hands-on experience in an advanced laboratory. Participants develop professional skills, expand their global perspective, and actively contribute to meaningful projects.",
    dataProgram: "internship",
  },
  {
    icon: "eye",
    title: "Student Exchange",
    subtitle: "Agung Putra University",
    desc: "The Student Exchange Program provides students with the chance to experience international learning and cultural immersion. Through academic activities and cross-cultural engagement, participants broaden their perspectives while building global connections.",
    dataProgram: "exchange",
  },
  {
    icon: "building",
    title: "Research & Collaboration",
    subtitle: "Agung Putra University",
    desc: "SCCR Research Collaboration connects researchers, academics, and institutions to work together on impactful research initiatives especially in the field of Stem Cells. This program fosters innovation across borders.",
    dataProgram: "research",
  },
];

const mapSrc = "https://maps.google.com/maps?q=-7.071300,110.362306&z=15&output=embed";

const pdfSrc = "/pdfs/brochure.pdf";
---
---

<MainLayout title="International Office | APU" description="International programs, partnerships, and global opportunities at Agung Putra University.">
  <NavigationAPU />
  <main>
    <section class="inter-hero">
      <div class="inter-hero-bg" style={`background-image: url(${heroImage.src})`}></div>
      <div class="inter-hero-overlay"></div>
      <div class="inter-hero-content">
        <span class="inter-hero-kicker">International Office</span>
        <h1 class="inter-hero-title">Join Agung Putra University,<br>a Futuristic Green Campus</h1>
        <p class="inter-hero-desc">Built for curious minds, bold collaborators, and the next generation of changemakers.</p>
        <div class="inter-hero-actions">
          <a href="/admission" class="apu-btn apu-btn--primary">Explore Admission</a>
          <a href="#programs" class="apu-btn apu-btn--secondary">Our Programs</a>
        </div>
      </div>
    </section>

    <section id="programs" class="apu-section-shell py-24 md:py-32">
      <div class="content-max">
        <ScrollReveal>
          <SectionHeader kicker="Programs" title="Let's Get Started" description="Choose the study abroad experience you're looking for." class="text-center mb-16" />
        </ScrollReveal>

        <div class="grid md:grid-cols-3 gap-6">
          {programs.map((p, i) => (
            <ScrollReveal delay={i * 120}>
              <button type="button" class="group block w-full text-left h-full apu-glass-card apu-interactive-card p-8 rounded-2xl border border-[rgb(var(--color-apu-navy)_/_0.08)] cursor-pointer" data-program={p.dataProgram}>
                <div class="apu-icon-chip flex h-14 w-14 rounded-xl mb-5">
                  {p.icon === "globe" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.5 2.6 4 5.6 4 9s-1.5 6.4-4 9c-2.5-2.6-4-5.6-4-9s1.5-6.4 4-9z"/></svg>
                  )}
                  {p.icon === "eye" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="2.5"/></svg>
                  )}
                  {p.icon === "building" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M4 10h16"/><path d="M6 10V7.5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2V10"/><path d="M6 10v9"/><path d="M10 10v9"/><path d="M14 10v9"/><path d="M18 10v9"/><path d="M4 19h16"/></svg>
                  )}
                </div>
                <h3 class="text-h3 text-[rgb(var(--color-apu-navy))] mb-1">{p.title}</h3>
                <p class="text-caption text-brand-text-muted font-medium mb-3">{p.subtitle}</p>
                <p class="text-body-s text-brand-text-muted leading-relaxed">{p.desc}</p>
              </button>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <section id="info" class="apu-section-shell py-24 md:py-32 bg-white">
      <div class="content-max">
        <ScrollReveal>
          <SectionHeader kicker="Information" title="Brochure & Location" description="Browse our program brochure and find us on the map." class="text-center mb-14" />
        </ScrollReveal>

        <div class="grid md:grid-cols-2 gap-8 mb-20">
          <ScrollReveal delay={0}>
            <div class="flex flex-col">
              <div class="rounded-2xl overflow-hidden shadow-[0_18px_50px_rgb(var(--color-brand-primary-deeper)/0.12)] flex-1 bg-brand-surface-alt">
                <iframe src={pdfSrc} class="w-full h-full border-0 min-h-[400px] md:min-h-[800px]" loading="lazy" title="Brochure PDF"></iframe>
              </div>
              <div class="flex justify-center mt-4">
                <CtaButton href={pdfSrc} variant="secondary" withArrow target="_blank">Download PDF</CtaButton>
              </div>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={100}>
            <div class="flex flex-col">
              <div class="rounded-2xl overflow-hidden shadow-[0_18px_50px_rgb(var(--color-brand-primary-deeper)/0.12)] flex-1">
                <iframe src={mapSrc} class="w-full h-full border-0 min-h-[400px] md:min-h-[800px]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="APU Campus Location"></iframe>
              </div>
              <div class="flex justify-center mt-4">
                <a href="https://maps.google.com/maps?q=-7.071300,110.362306" target="_blank" rel="noopener noreferrer" class="apu-btn apu-btn--secondary">Open in Google Maps</a>
              </div>
            </div>
          </ScrollReveal>
        </div>

        <ScrollReveal>
          <div class="border-t border-[rgb(var(--color-apu-navy)_/_0.08)] pt-14">
            <h3 class="text-h3 text-center text-[rgb(var(--color-apu-navy))] mb-10">Get in Touch</h3>
            <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
              <div class="text-center">
                <div class="apu-icon-chip flex h-14 w-14 rounded-2xl mx-auto mb-4">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <p class="text-caption text-brand-text-muted font-medium mb-1">Address</p>
                <p class="text-body-s text-brand-text-muted leading-relaxed">Nongkosawit Raya Street, Nongkosawit, Gn. Pati,<br>Semarang, Central Java, 50224</p>
              </div>
              <div class="text-center">
                <div class="apu-icon-chip flex h-14 w-14 rounded-2xl mx-auto mb-4">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <p class="text-caption text-brand-text-muted font-medium mb-1">Phone</p>
                <a href="tel:+628113755552" class="text-body-s text-brand-text-muted hover:text-[rgb(var(--color-apu-accent))] transition-colors no-underline">+62 8113755552</a>
              </div>
              <div class="text-center">
                <div class="apu-icon-chip flex h-14 w-14 rounded-2xl mx-auto mb-4">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <p class="text-caption text-brand-text-muted font-medium mb-1">E-mail</p>
                <a href="mailto:info@apu.ac.id" class="text-body-s text-brand-text-muted hover:text-[rgb(var(--color-apu-accent))] transition-colors no-underline">info@apu.ac.id</a>
              </div>
            </div>
            <div class="flex justify-center mt-10">
              <a href={contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="apu-btn apu-btn--primary">Contact via WhatsApp</a>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </section>


  </main>

  <div id="progModal" class="pm-overlay" hidden>
    <div class="pm-backdrop"></div>
    <div class="pm-panel">
      <button class="pm-close" id="pmClose" type="button" aria-label="Close modal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
      {[internship, exchange, research].map((prog, idx) => (
        <div class="pm-content" data-program={["internship", "exchange", "research"][idx]} hidden>
          <div class="pm-grid">
            <aside class="pm-side">
              <nav class="pm-nav">
                {prog.nav.map((item) =>
                  item.type === "parent" ? (
                    <>
                      <button class="progpage-item" type="button" data-has-children="1" data-expanded={item.expanded ? "1" : "0"} data-target={`#${item.paneId}`}>
                        {item.label}
                        <span class="progpage-caret" aria-hidden="true">
                          <svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"></path></svg>
                        </span>
                      </button>
                      <div class="progpage-children" data-open={item.expanded ? "1" : "0"}>
                        {item.children.map((c) => (
                          <button class="progpage-child" type="button" data-target={`#${c.paneId}`}>{c.label}</button>
                        ))}
                      </div>
                    </>
                  ) : (
                    <button class="progpage-item" type="button" data-target={`#${item.paneId}`}>
                      {item.label}
                      <span class="progpage-caret" aria-hidden="true">
                        <svg viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"></path></svg>
                      </span>
                    </button>
                  )
                )}
              </nav>
            </aside>
            <section class="pm-main">
              <div class="pm-topbar">{prog.name}</div>
              <div class="pm-body">
                {prog.panes.map((pane) => (
                  <section class="progpage-pane" id={pane.id} data-title={pane.title} hidden><Fragment set:html={pane.html} /></section>
                ))}
              </div>
            </section>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Footer />
</MainLayout>

<style>
  .inter-hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 3.5rem;
    display: flex;
    align-items: center;
    min-height: 70vh;
  }
  .inter-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.35);
    z-index: 0;
  }
  .inter-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(19,40,66,.7) 0%, rgba(19,40,66,.4) 50%, rgba(19,40,66,.85) 100%);
    z-index: 1;
  }
  .inter-hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .inter-hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.12);
    backdrop-filter: blur(8px);
    padding: 0.45rem 0.9rem;
    font-family: "Space Mono", monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-apu-accent));
    margin-bottom: 1rem;
  }
  .inter-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -.02em;
    color: #fff;
    margin: 0 0 1rem;
  }
  .inter-hero-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255,255,255,.75);
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .inter-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    justify-content: center;
  }
</style>

<style is:global>
  .pm-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .pm-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(var(--color-apu-navy) / .65);
    backdrop-filter: blur(6px);
  }
  .pm-panel {
    position: relative;
    width: min(100%, 1100px);
    max-height: min(85vh, 800px);
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 30px 80px rgb(var(--color-apu-navy) / .25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: pm-in .25s ease-out;
  }
  @keyframes pm-in {
    from { opacity: 0; transform: scale(.96) translateY(12px); }
  }
  .pm-close {
    position: absolute;
    top: .75rem;
    right: .75rem;
    z-index: 10;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-apu-navy) / .1);
    background: #fff;
    cursor: pointer;
    color: rgb(var(--color-apu-navy));
    transition: background .15s;
  }
  .pm-close:hover { background: rgb(var(--color-apu-navy) / .06); }
  .pm-close svg { width: 18px; height: 18px; }
  .pm-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    flex: 1;
    min-height: 0;
  }
  .pm-side {
    background: #fafbfc;
    border-right: 1px solid rgb(var(--color-apu-navy) / .08);
    overflow-y: auto;
    padding: 1rem .75rem;
  }
  .pm-nav { display: flex; flex-direction: column; gap: 2px; }

  .pm-nav .progpage-item, .pm-nav .progpage-child {
    width: 100%; display: flex; align-items: center; gap: 8px;
    padding: .55rem .75rem; border-radius: 10px;
    border: 1px solid transparent; background: transparent;
    cursor: pointer; text-align: left; font-size: .82rem;
    font-weight: 600; color: rgb(var(--color-apu-navy));
    transition: background .12s;
  }
  .pm-nav .progpage-item { justify-content: space-between; }
  .pm-nav .progpage-item:hover, .pm-nav .progpage-child:hover { background: rgb(var(--color-apu-navy) / .05); }
  .pm-nav .progpage-item[aria-current="page"], .pm-nav .progpage-child[aria-current="page"] {
    background: rgb(var(--color-apu-accent) / .12);
    border-color: rgb(var(--color-apu-accent) / .25);
  }
  .pm-nav .progpage-child { font-weight: 500; color: rgb(var(--color-apu-navy) / .8); justify-content: flex-start; }
  .pm-nav .progpage-child[aria-current="page"] { font-weight: 600; color: rgb(var(--color-apu-navy)); }
  .pm-nav .progpage-caret { flex: 0 0 auto; opacity: .6; transition: transform .15s; }
  .pm-nav .progpage-caret svg { display: block; width: 16px; height: 16px; }
  .pm-nav .progpage-item[data-expanded="1"] .progpage-caret { transform: rotate(90deg); }
  .pm-nav .progpage-children { margin: 4px 0 6px 12px; padding-left: 12px; border-left: 1px solid rgb(var(--color-apu-navy) / .1); display: none; }
  .pm-nav .progpage-children[data-open="1"] { display: flex; flex-direction: column; gap: 2px; }

  .pm-main {
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }
  .pm-topbar {
    padding: 1rem 1.25rem;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    background: rgb(var(--color-apu-navy));
    flex: 0 0 auto;
  }
  .pm-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
  }
  .pm-body h2 { margin: 0 0 .5rem; font-size: 1.1rem; }
  .pm-body h3 { margin: 0 0 .4rem; font-size: 1rem; color: rgb(var(--color-apu-navy)); }
  .pm-body p { margin: 0 0 .6rem; font-size: .88rem; line-height: 1.6; color: rgb(var(--color-apu-navy) / .85); }
  .pm-body p a { color: rgb(var(--color-apu-accent)); font-weight: 600; text-decoration: none; }
  .pm-body ol, .pm-body ul { margin: .4rem 0 .8rem; padding-left: 1.2rem; }
  .pm-body li { font-size: .88rem; line-height: 1.55; color: rgb(var(--color-apu-navy) / .85); margin-bottom: .3rem; }
  .pm-body strong { color: rgb(var(--color-apu-navy)); }
  .pm-body .progpage-pane[hidden] { display: none !important; }

  .pm-body .progpage-acc { margin-top: .5rem; border: 1px solid rgb(var(--color-apu-navy) / .1); border-radius: 12px; overflow: hidden; }
  .pm-body .progpage-acc-item { border-top: 1px solid rgb(var(--color-apu-navy) / .08); }
  .pm-body .progpage-acc-item:first-child { border-top: 0; }
  .pm-body .progpage-acc-btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 8px;
    padding: .7rem .9rem; background: #f8f9fa; cursor: pointer; user-select: none; border: none;
    font-weight: 600; font-size: .82rem; color: rgb(var(--color-apu-navy)); text-align: left;
  }
  .pm-body .progpage-acc-btn svg { display: block; width: 14px; height: 14px; }
  .pm-body .progpage-acc-panel { padding: .6rem .9rem .8rem; font-size: .85rem; color: rgb(var(--color-apu-navy) / .85); }
  .pm-body .progpage-acc-panel ul { margin: .3rem 0; }
  .pm-body .progpage-media { margin: .6rem 0; border-radius: 10px; overflow: hidden; border: 1px solid rgb(var(--color-apu-navy) / .08); }
  .pm-body .progpage-media img { width: 100%; height: auto; display: block; }

  @media (max-width: 767px) {
    .pm-panel { max-height: 92vh; border-radius: 16px; }
    .pm-grid { grid-template-columns: 1fr; }
    .pm-side { display: none; }
  }
</style>

<script>
  const modal = document.getElementById("progModal");
  const backdrop = modal?.querySelector(".pm-backdrop");
  const closeBtn = document.getElementById("pmClose");

  document.querySelectorAll(".apu-glass-card[data-program]").forEach((btn) => {
    btn.addEventListener("click", () => openModal(btn.dataset.program));
  });

  function openModal(program) {
    if (!modal) return;
    modal.hidden = false;
    document.body.style.overflow = "hidden";

    document.querySelectorAll(".pm-content").forEach((el) => (el.hidden = true));
    const content = document.querySelector(`.pm-content[data-program="${program}"]`);
    if (!content) return;
    content.hidden = false;

    initSidebar(content);
  }

  function closeModal() {
    if (!modal) return;
    modal.hidden = true;
    document.body.style.overflow = "";
  }

  if (backdrop) backdrop.addEventListener("click", closeModal);
  if (closeBtn) closeBtn.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hidden) closeModal();
  });

  function initSidebar(container) {
    const navWrap = container.querySelector(".pm-nav");
    const titleEl = container.querySelector(".pm-topbar");
    const bodyEl = container.querySelector(".pm-body");
    if (!navWrap || !titleEl || !bodyEl) return;

    const navButtons = navWrap.querySelectorAll("button");

    function showPane(sel) {
      const pane = bodyEl.querySelector(sel);
      if (!pane) return;
      bodyEl.querySelectorAll(".progpage-pane").forEach((p) => { p.hidden = p !== pane; });
      const t = pane.getAttribute("data-title") || "";
      if (t) titleEl.textContent = t;
    }

    navButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.target;
        if (target) showPane(target);

        if (btn.dataset.hasChildren !== undefined) {
          const expanded = btn.dataset.expanded === "1";
          btn.dataset.expanded = expanded ? "0" : "1";
          const children = btn.nextElementSibling;
          if (children && children.classList.contains("progpage-children")) {
            children.dataset.open = expanded ? "0" : "1";
          }
        }

        navButtons.forEach((b) => b.removeAttribute("aria-current"));
        btn.setAttribute("aria-current", "page");
      });
    });

    const firstTarget = navWrap.querySelector("[data-target]");
    if (firstTarget && firstTarget.dataset.target) {
      firstTarget.setAttribute("aria-current", "page");
      showPane(firstTarget.dataset.target);
    }

    bodyEl.addEventListener("toggle", (e) => {
      const details = e.target;
      if (!(details instanceof HTMLDetailsElement)) return;
      const group = details.closest("[data-acc-group]");
      if (!group) return;
      if (!details.open) return;
      group.querySelectorAll("details.progpage-acc-item[open]").forEach((d) => {
        if (d !== details) d.open = false;
      });
    }, true);
  }
</script>
