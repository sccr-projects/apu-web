---
import { assetUrl } from '@lib/assets';
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogDescription?: string;
}

const {
  title = "Agung Putra University | Futuristic Green Campus di Semarang",
  description = "Agung Putra University atau APU adalah perguruan tinggi di Gunungpati, Semarang, Jawa Tengah. APU mengembangkan pendidikan tinggi berbasis riset, industri, teknologi, bioteknologi, ilmu biomedis, manajemen, komunikasi, hukum, kebidanan, dan entrepreneurship.",
  canonical = "https://apu.ac.id/",
  ogDescription,
} = Astro.props;

const _ogDescription = ogDescription ?? description;

const ogImage = new URL(assetUrl('/images/hero-campus.jpg'), Astro.url).href;

const structuredData = {
  "@context": "https://schema.org",
  "@type": ["CollegeOrUniversity", "Organization"],
  "@id": "https://apu.ac.id/#agung-putra-university",
  "name": "Agung Putra University",
  "alternateName": ["APU", "Universitas Agung Putra"],
  description:
    "Agung Putra University atau APU adalah perguruan tinggi di Gunungpati, Semarang, Jawa Tengah, dengan positioning Futuristic Green Campus.",
  url: "https://apu.ac.id/",
  slogan: "Futuristic Green Campus",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Jl. Nongkosawit Raya, Nongkosawit, Gunungpati",
    addressLocality: "Semarang",
    addressRegion: "Jawa Tengah",
    postalCode: "50224",
    addressCountry: "ID",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+62-811-3755-552",
    contactType: "admissions",
    areaServed: "ID",
    availableLanguage: ["Indonesian", "English"],
  },
  sameAs: [
    "https://www.linkedin.com/company/agung-putra-university",
    "https://www.instagram.com/agungputrauniversity",
  ],
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={_ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Agung Putra University" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <link rel="icon" type="image/png" href={assetUrl('/images/apu-logo.png')} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Space+Grotesk:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      let themeColorMeta = document.querySelector('meta[name="theme-color"]');
      const rootStyles = getComputedStyle(document.documentElement);
      const themeColor = rootStyles.getPropertyValue('--color-brand-surface').trim();

      if (!themeColorMeta) {
        themeColorMeta = document.createElement('meta');
        themeColorMeta.setAttribute('name', 'theme-color');
        document.head.appendChild(themeColorMeta);
      }

      if (themeColorMeta && themeColor) {
        themeColorMeta.setAttribute('content', `rgb(${themeColor})`);
      }
    </script>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  </head>
  <body>
    <slot />
  </body>
</html>
