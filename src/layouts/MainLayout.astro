---
import { assetUrl } from '@lib/assets';
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pendaftaran Mahasiswa Baru 2026/2027 | Agung Putra University",
  description = "Pendaftaran mahasiswa baru Agung Putra University Tahun Ajaran 2026/2027. 7 program studi unggulan, beasiswa prestasi, dan kampus futuristik hijau di Semarang.",
} = Astro.props;

const ogImage = new URL(assetUrl('/images/hero-campus.jpg'), Astro.url).href;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <link rel="icon" type="image/png" href={assetUrl('/images/apu-logo.png')} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Space+Grotesk:wght@300;400;500&family=Space+Mono&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      let themeColorMeta = document.querySelector('meta[name="theme-color"]');
      const rootStyles = getComputedStyle(document.documentElement);
      const themeColor = rootStyles.getPropertyValue('--color-brand-surface').trim();

      if (!themeColorMeta) {
        themeColorMeta = document.createElement('meta');
        themeColorMeta.setAttribute('name', 'theme-color');
        document.head.appendChild(themeColorMeta);
      }

      if (themeColorMeta && themeColor) {
        themeColorMeta.setAttribute('content', `rgb(${themeColor})`);
      }
    </script>

  </head>
  <body>
    <slot />
  </body>
</html>
