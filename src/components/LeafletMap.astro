---
interface MarkerData {
  lat: number;
  lng: number;
  label?: string;
  icon?: string;
}

interface Props {
  center?: [number, number];
  zoomStart?: number;
  zoomEnd?: number;
  zoomDuration?: number;
  markers?: MarkerData[];
  route?: [number, number][];
  animated?: boolean;
  class?: string;
}

const {
  center = [-7.071300, 110.362306],
  zoomStart = 10,
  zoomEnd = 16,
  zoomDuration = 4000,
  markers,
  route,
  animated = true,
  class: className = "",
} = Astro.props;
---

<div
  class={`apu-leaflet-map ${className}`}
  data-map-instance
  data-center={JSON.stringify(center)}
  data-zoom-start={zoomStart}
  data-zoom-end={zoomEnd}
  data-zoom-duration={zoomDuration}
  data-markers={markers ? JSON.stringify(markers) : undefined}
  data-route={route ? JSON.stringify(route) : undefined}
  data-animated={String(animated)}
>
</div>

<script>
  import L from "leaflet";

  interface MarkerData {
    lat: number;
    lng: number;
    label?: string;
    icon?: string;
  }

  interface MapData {
    center: [number, number];
    zoomStart: number;
    zoomEnd: number;
    zoomDuration: number;
    markers?: MarkerData[];
    route?: [number, number][];
    animated: boolean;
    markerIcon?: string;
  }

  function parseData(container: HTMLElement): MapData {
    return {
      center: JSON.parse(container.dataset.center || "[-7.071300, 110.362306]"),
      zoomStart: parseInt(container.dataset.zoomStart || "10"),
      zoomEnd: parseInt(container.dataset.zoomEnd || "16"),
      zoomDuration: parseInt(container.dataset.zoomDuration || "4000"),
      markers: container.dataset.markers ? JSON.parse(container.dataset.markers) : undefined,
      route: container.dataset.route ? JSON.parse(container.dataset.route) : undefined,
      animated: container.dataset.animated !== "false",
      markerIcon: container.dataset.markerIcon || undefined,
    };
  }

  function createPulseIcon(): L.DivIcon {
    return L.divIcon({
      className: "apu-map-pin",
      html: `
        <div class="apu-map-pin__container">
          <div class="apu-map-pin__pulse"></div>
          <div class="apu-map-pin__dot"></div>
        </div>
      `,
      iconSize: [24, 24],
      iconAnchor: [12, 12],
    });
  }

  function createStaticIcon(): L.DivIcon {
    return L.divIcon({
      className: "apu-map-pin",
      html: `<div class="apu-map-pin__container"><div class="apu-map-pin__dot"></div></div>`,
      iconSize: [24, 24],
      iconAnchor: [12, 12],
    });
  }

  function createCustomIcon(iconHtml: string): L.DivIcon {
    return L.divIcon({
      className: "apu-map-pin",
      html: `<div class="apu-map-pin__container apu-map-pin__container--custom">${iconHtml}</div>`,
      iconSize: [32, 32],
      iconAnchor: [16, 32],
    });
  }

  function createImageIcon(iconUrl: string): L.Icon {
    return L.icon({
      iconUrl: iconUrl,
      iconSize: [136, 180],
      iconAnchor: [65, 180],
      popupAnchor: [0, -120],
      className: "apu-map-pin-image",
    });
  }

  function invalidateMapSize(map: L.Map) {
    requestAnimationFrame(() => map.invalidateSize());
    setTimeout(() => map.invalidateSize(), 0);
    setTimeout(() => map.invalidateSize(), 300);
  }

  function initSingleMarkerMap(container: HTMLElement, data: MapData) {
    const map = L.map(container, {
      center: data.center,
      zoom: data.zoomStart,
      zoomControl: false,
      attributionControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      touchZoom: false,
      boxZoom: false,
      keyboard: false,
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
    }).addTo(map);

    const icon = data.animated ? createPulseIcon() : createStaticIcon();
    L.marker(data.center, { icon }).addTo(map);

    invalidateMapSize(map);

    if (data.animated) {
      setTimeout(() => {
        map.flyTo(data.center, data.zoomEnd, {
          duration: data.zoomDuration / 1000,
          easeLinearity: 0.25,
        });
        map.once("moveend zoomend", () => {
          invalidateMapSize(map);
        });
      }, 800);
    }

    return map;
  }

  function initMultiMarkerMap(container: HTMLElement, data: MapData) {
    if (!data.markers || data.markers.length === 0) return;

    const map = L.map(container, {
      zoomControl: false,
      attributionControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      touchZoom: false,
      boxZoom: false,
      keyboard: false,
      zoomSnap: 0.1,
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
    }).addTo(map);

    const bounds = L.latLngBounds(data.markers.map((m) => [m.lat, m.lng]));

    if (data.route && data.route.length > 1) {
      const routeLatLngs = data.route.map(([lat, lng]) => [lat, lng]);

      // Glow layer — wide, intense, pulsing
      L.polyline(routeLatLngs, {
        color: "#2B7A4A",
        weight: 20,
        opacity: 0.35,
        lineCap: "round",
        lineJoin: "round",
        className: "apu-route-glow",
      }).addTo(map);

      // Secondary glow — strong spread
      L.polyline(routeLatLngs, {
        color: "#43A047",
        weight: 10,
        opacity: 0.6,
        lineCap: "round",
        lineJoin: "round",
        className: "apu-route-glow-soft",
      }).addTo(map);

      // Main animated line — marching dash
      L.polyline(routeLatLngs, {
        color: "#2B7A4A",
        weight: 4,
        opacity: 1.0,
        dashArray: "12, 8",
        lineCap: "round",
        lineJoin: "round",
        className: "apu-route-pulse",
      }).addTo(map);

      // Bright core
      L.polyline(routeLatLngs, {
        color: "#81C784",
        weight: 2,
        opacity: 1.0,
        lineCap: "round",
        lineJoin: "round",
        className: "apu-route-core",
      }).addTo(map);
    }

    data.markers.forEach((marker) => {
      const markerIcon = marker.icon
        ? createImageIcon(marker.icon)
        : data.markerIcon
          ? createCustomIcon(data.markerIcon)
          : createStaticIcon();
      const m = L.marker([marker.lat, marker.lng], { icon: markerIcon }).addTo(map);
      if (marker.label) {
        m.bindPopup(marker.label, {
          closeButton: false,
          className: "apu-map-popup",
        });
        m.on("click", () => {
          console.log("[LeafletMap] Marker clicked:", marker.label);
          container.dispatchEvent(
            new CustomEvent("markerclick", {
              detail: { label: marker.label },
              bubbles: true,
            })
          );
        });
      }
    });

    const containerWidth = container.clientWidth;
    const containerHeight = container.clientHeight;
    const paddingX = Math.min(600, Math.max(40, Math.round(containerWidth * 0.35)));
    const paddingY = Math.min(160, Math.max(40, Math.round(containerHeight * 0.2)));
    map.fitBounds(bounds, { paddingTopLeft: [paddingX, paddingY], paddingBottomRight: [paddingX, paddingY] });
    map.setZoom(Math.min(map.getZoom(), 17.8));

    invalidateMapSize(map);
    map.once("moveend", () => invalidateMapSize(map));

    return map;
  }

  function initMap(container: HTMLElement) {
    try {
      const data = parseData(container);

      let map: L.Map | undefined;
      if (data.markers && data.markers.length > 0) {
        map = initMultiMarkerMap(container, data);
      } else {
        map = initSingleMarkerMap(container, data);
      }

      if (map) {
        let resizeTimer: number;
        const handleResize = () => {
          clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(() => {
            invalidateMapSize(map);
          }, 150);
        };
        window.addEventListener("resize", handleResize);

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                invalidateMapSize(map);
              }
            });
          },
          { threshold: 0.1 }
        );
        observer.observe(container);

        document.addEventListener("astro:before-swap", () => {
          window.removeEventListener("resize", handleResize);
          observer.disconnect();
          map?.remove();
        });
      }
    } catch (err) {
      console.error("LeafletMap init failed:", err);
    }
  }

  function initAllMaps() {
    const containers = document.querySelectorAll<HTMLElement>("[data-map-instance]");
    containers.forEach((container) => {
      if (!container.dataset.mapInitialized) {
        container.dataset.mapInitialized = "true";
        initMap(container);
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllMaps);
  } else {
    initAllMaps();
  }
</script>

<style>
  .apu-leaflet-map {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .apu-leaflet-map :global(.leaflet-container) {
    background: transparent;
  }

  .apu-leaflet-map :global(.leaflet-tile-pane) {
    filter: saturate(1.05) contrast(1.02);
  }

  /* Custom APU Pin Styles */
  .apu-map-pin {
    background: transparent;
    border: none;
  }

  .apu-map-pin__container {
    position: relative;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .apu-map-pin__container--custom {
    width: 32px;
    height: 32px;
  }

  .apu-map-pin__container--custom svg {
    width: 100%;
    height: 100%;
    color: rgb(var(--color-apu-accent));
    filter: drop-shadow(0 2px 4px rgb(var(--color-apu-navy) / 0.3));
  }

  .apu-map-pin-image {
    filter: drop-shadow(0 2px 6px rgb(var(--color-apu-navy) / 0.35));
    transition: transform 0.2s ease;
  }

  .apu-map-pin-image:hover {
    transform: scale(1.15) translateY(-4px);
  }

  .apu-map-pin__dot {
    width: 12px;
    height: 12px;
    background: rgb(var(--color-apu-accent));
    border: 2px solid rgb(var(--color-apu-navy));
    border-radius: 50%;
    position: relative;
    z-index: 2;
    box-shadow: 0 0 0 4px rgb(var(--color-apu-accent) / 0.3);
  }

  .apu-map-pin__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgb(var(--color-apu-accent) / 0.4);
    animation: apu-map-pulse 2s ease-out infinite;
    z-index: 1;
  }

  @keyframes apu-map-pulse {
    0% {
      transform: scale(0.5);
      opacity: 0.8;
    }
    100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .apu-map-pin__pulse {
      animation: none;
    }
  }

  /* Route Glow & Pulse Effects */
  .apu-leaflet-map :global(.apu-route-glow) {
    filter: drop-shadow(0 0 20px #2B7A4A) drop-shadow(0 0 40px #43A047) drop-shadow(0 0 80px #66BB6A);
    animation: apu-route-glow-pulse 2s ease-in-out infinite;
  }

  .apu-leaflet-map :global(.apu-route-glow-soft) {
    filter: drop-shadow(0 0 15px #43A047) drop-shadow(0 0 30px #66BB6A);
  }

  .apu-leaflet-map :global(.apu-route-pulse) {
    animation: apu-route-dash 1s linear infinite;
    filter: drop-shadow(0 0 10px #66BB6A) drop-shadow(0 0 20px #81C784);
  }

  .apu-leaflet-map :global(.apu-route-core) {
    filter: drop-shadow(0 0 8px #81C784) drop-shadow(0 0 16px #A5D6A7);
  }

  @keyframes apu-route-glow-pulse {
    0%, 100% {
      opacity: 0.3;
      filter: drop-shadow(0 0 20px #2B7A4A) drop-shadow(0 0 40px #43A047) drop-shadow(0 0 60px #66BB6A);
    }
    50% {
      opacity: 0.9;
      filter: drop-shadow(0 0 40px #2B7A4A) drop-shadow(0 0 80px #43A047) drop-shadow(0 0 120px #66BB6A) drop-shadow(0 0 160px #81C784);
    }
  }

  @keyframes apu-route-dash {
    0% {
      stroke-dashoffset: 20;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

</style>
