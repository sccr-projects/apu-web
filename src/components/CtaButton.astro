---
type Variant = "primary" | "secondary" | "requirements" | "tertiary";

type Props = {
  href: string;
  target?: string;
  rel?: string;
  class?: string;
  variant?: Variant;
  withArrow?: boolean;
  arrowSize?: number;
  ariaLabel?: string;
};

const {
  href,
  target,
  rel,
  class: className = "",
  variant = "primary",
  withArrow = false,
  arrowSize = 18,
  ariaLabel,
} = Astro.props as Props;

const variantClasses: Record<Variant, string> = {
  primary: "apu-btn apu-btn--primary",
  secondary: "apu-btn apu-btn--secondary",
  tertiary: "apu-btn apu-btn--tertiary",
  requirements: "apu-btn apu-btn--secondary",
};

const mergedClass = `${variantClasses[variant]} ${className}`.trim();
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  class={mergedClass}
>
  <slot />
  {
    withArrow && (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width={arrowSize}
        height={arrowSize}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    )
  }
</a>
