---
type Variant = "primary" | "secondary" | "requirements";

type Props = {
  href: string;
  target?: string;
  rel?: string;
  class?: string;
  variant?: Variant;
  withArrow?: boolean;
  arrowSize?: number;
  ariaLabel?: string;
};

const {
  href,
  target,
  rel,
  class: className = "",
  variant = "primary",
  withArrow = false,
  arrowSize = 18,
  ariaLabel,
} = Astro.props as Props;

const variantClasses: Record<Variant, string> = {
  primary: "apu-btn apu-btn--primary",
  secondary: "apu-btn apu-btn--secondary",
  requirements:
    "inline-flex text-white items-center justify-center gap-3 rounded-2xl border border-[rgb(var(--color-apu-navy))] bg-gradient-to-r from-[rgb(var(--color-apu-navy))] to-[rgb(var(--color-apu-navy)_/_0.8)] px-10 py-4 text-body font-medium shadow-[0_16px_30px_rgb(var(--color-apu-navy)_/_0.22)] transition-all duration-300 hover:-translate-y-0.5 hover:gap-4 hover:border-[rgb(var(--color-apu-accent))] hover:from-[rgb(var(--color-apu-accent))] hover:to-[rgb(var(--color-apu-accent)_/_0.92)] hover:text-[rgb(var(--color-apu-navy))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-white",
};

const mergedClass = `${variantClasses[variant]} ${className}`.trim();
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  class={mergedClass}
>
  <slot />
  {
    withArrow && (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width={arrowSize}
        height={arrowSize}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    )
  }
</a>
