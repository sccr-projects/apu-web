---
import { Image } from "astro:assets";

export interface Props {
    seed?: string;
    blobCount?: number;
    blur?: number;
    opacity?: number;
    theme?: "light" | "dark" | "auto";
    class?: string;
}

const { class: className = "" } = Astro.props;

import bgImage from "@/assets/images/bg-apu-main.webp";
---

<div class:list={["apu-bg-image", className]} aria-hidden="true">
    <Image
        src={bgImage}
        alt=""
        loading="lazy"
        decoding="async"
    />
</div>

<script is:inline data-astro-rerun>
    (function () {
        function pick(arr) {
            return arr[Math.floor(Math.random() * arr.length)];
        }

        document
            .querySelectorAll(".apu-bg-image:not([data-apu-bg-randomized])")
            .forEach(function (el) {
                const img = el.querySelector("img");
                if (!img) return;

                img.style.setProperty(
                    "--apu-bg-rotate",
                    pick(["0deg", "180deg"]),
                );
                img.style.setProperty(
                    "--apu-bg-scale-x",
                    pick(["1", "-1"]),
                );
                img.style.setProperty(
                    "--apu-bg-scale-y",
                    pick(["1", "-1"]),
                );
                el.setAttribute("data-apu-bg-randomized", "");
            });
    })();
</script>

<style>
    .apu-bg-image {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .apu-bg-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: rotate(var(--apu-bg-rotate, 0deg))
            scaleX(var(--apu-bg-scale-x, 1)) scaleY(var(--apu-bg-scale-y, 1));
    }
</style>
