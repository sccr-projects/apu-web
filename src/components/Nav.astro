---
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Posts' },
  { href: '/form', label: 'Submit' },
];
const current = Astro.url.pathname;
---

<nav class="bg-slate-900 text-white px-6 py-4">
  <div class="max-w-4xl mx-auto flex gap-6">
    <a href="/" class="font-bold text-lg">Kimi Claw</a>
    <div class="flex gap-4 ml-auto">
      {links.map(l => (
        <a href={l.href} class={current === l.href ? 'underline' : 'hover:text-slate-300'}>
          {l.label}
        </a>
      ))}
    </div>
  </div>
</nav>
