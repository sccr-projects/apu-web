  //   label: "About APU",
  //   href: `#`,
  //   kind: "anchor",
  //   placeholder: true,
  //   badge: "Coming Soon",
  // },
];

const utilityActions: NavItem[] = [
  {
    label: "Apply Now",
    href: `http://49.50.9.214:8060/index.php/pendaftaran_pmb`,
    description: "Direct admissions consultation with the admissions team.",
    kind: "external",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    label: "Downloads",
    href: `${HOME_PATH}/downloads`,
    description: "Guides, forms, and APU reference files.",
    kind: "route",
    placeholder: true,
    // badge: "Coming Soon",
  },
  {
    label: "System Login",
    href: `${HOME_PATH}/systems`,
    description: "Student portal, LMS, and campus system access.",
    kind: "route",
    placeholder: true,
    // badge: "Coming Soon",
