---
const HOME_PATH = "/apu";

const normalizePath = (path: string) => {
  const cleaned = path.replace(/\/+$/, "");
  return cleaned || "/";
};

const routePathFromHref = (href: string) => {
  try {
    return normalizePath(new URL(href, "https://apu.local").pathname);
  } catch {
    return HOME_PATH;
  }
};

const toDomId = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

const currentPath = normalizePath(Astro.url.pathname);
const admissionsWhatsApp =
  "https://wa.me/628113755552?text=Halo, saya ingin menanyakan informasi pendaftaran mahasiswa baru APU 2026/2027.";

type NavItem = {
  label: string;
  href: string;
  description: string;
  kind: "route" | "anchor" | "external";
  section?: string;
  placeholder?: boolean;
  badge?: string;
  target?: string;
  rel?: string;
};

const groupedNav: Array<{
  title: string;
  description: string;
  items: NavItem[];
}> = [
  {
    title: "Plan & Apply",
    description: "Masuk APU dengan alur yang jelas, bantuan cepat, dan titik kontak resmi.",
    items: [
      {
        label: "Admissions",
        href: `${HOME_PATH}#jalur-masuk`,
        description: "Jalur pendaftaran, intake, dan langkah awal menuju kampus.",
        kind: "anchor",
        section: "jalur-masuk",
        badge: "Live on home",
      },
      {
        label: "Scholarships",
        href: `${HOME_PATH}/scholarships`,
        description: "Katalog beasiswa, benefit, timeline, dan bantuan pembiayaan.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
      {
        label: "Contact",
        href: `${HOME_PATH}#kontak`,
        description: "WhatsApp, alamat kampus, dan kanal bantuan resmi APU.",
        kind: "anchor",
        section: "kontak",
        badge: "Live on home",
      },
    ],
  },
  {
    title: "Discover APU",
    description: "Jelajahi akademik, riset, kehidupan mahasiswa, dan jejaring global APU.",
    items: [
      {
        label: "Academics",
        href: `${HOME_PATH}#program`,
        description: "Program studi, diferensiasi pembelajaran, dan arah karier lulusan.",
        kind: "anchor",
        section: "program",
        badge: "Live on home",
      },
      {
        label: "Research",
        href: `${HOME_PATH}/research`,
        description: "Pusat riset, publikasi, ekosistem laboratorium, dan kolaborasi.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
      {
        label: "Student Life & Services",
        href: `${HOME_PATH}/student-life-services`,
        description: "SIAKAD, LMS, wellbeing, tutorial, dan dukungan operasional mahasiswa.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
      {
        label: "International",
        href: `${HOME_PATH}/international`,
        description: "Kemitraan global, mobility, dan layanan untuk mahasiswa internasional.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
    ],
  },
  {
    title: "Institution & Stories",
    description: "Bangun kepercayaan melalui profil institusi, kepemimpinan, dan cerita kampus.",
    items: [
      {
        label: "News & Stories",
        href: `${HOME_PATH}/news-stories`,
        description: "Berita institusi, cerita mahasiswa, event, dan sorotan kampus.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
      {
        label: "About",
        href: `${HOME_PATH}/about`,
        description: "Profil APU, sejarah transisi, visi, misi, dan identitas universitas.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
      {
        label: "Leadership",
        href: `${HOME_PATH}/leadership`,
        description: "Pesan pimpinan, struktur pengelolaan, dan arah strategis kampus.",
        kind: "route",
        placeholder: true,
        badge: "Segera Hadir",
      },
    ],
  },
];

const utilityActions: NavItem[] = [
  {
    label: "Apply Now",
    href: admissionsWhatsApp,
    description: "Konsultasi pendaftaran langsung dengan tim admissions.",
    kind: "external",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    label: "WhatsApp Admissions",
    href: admissionsWhatsApp,
    description: "Tanya cepat soal intake, biaya, atau proses daftar.",
    kind: "external",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    label: "Downloads",
    href: `${HOME_PATH}/downloads`,
    description: "Panduan, formulir, dan file referensi APU.",
    kind: "route",
    placeholder: true,
    badge: "Segera Hadir",
  },
  {
    label: "Systems Login",
    href: `${HOME_PATH}/systems`,
    description: "Portal mahasiswa, LMS, dan akses sistem kampus.",
    kind: "route",
    placeholder: true,
    badge: "Segera Hadir",
  },
];

const homeAnchors: NavItem[] = [
  {
    label: "Beranda",
    href: `${HOME_PATH}#beranda-orange-navy`,
    description: "Hero dan positioning utama APU.",
    kind: "anchor",
    section: "beranda-orange-navy",
  },
  {
    label: "Program",
    href: `${HOME_PATH}#program`,
    description: "Snapshot seluruh program studi.",
    kind: "anchor",
    section: "program",
  },
  {
    label: "Jalur Masuk",
    href: `${HOME_PATH}#jalur-masuk`,
    description: "Admissions snapshot di homepage.",
    kind: "anchor",
    section: "jalur-masuk",
  },
  {
    label: "Persyaratan",
    href: `${HOME_PATH}#persyaratan`,
    description: "Dokumen dan syarat pendaftaran.",
    kind: "anchor",
    section: "persyaratan",
  },
  {
    label: "Kontak",
    href: `${HOME_PATH}#kontak`,
    description: "Alamat, WhatsApp, dan info kunjungan.",
    kind: "anchor",
    section: "kontak",
  },
];

const visibleUtilities = utilityActions.filter((item) => !item.placeholder).slice(0, 2);
---

<nav
  id="apu-nav"
  data-home-path={HOME_PATH}
  data-open="false"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50"
  aria-label="Navigasi utama APU"
>
  <div class="nav-topline"></div>

  <div class="content-max">
    <div class="nav-shell">
      <a href={HOME_PATH} class="nav-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-brand-surface))]">
        <img
          src="/images/apu.webp"
          alt="Agung Putra University"
          class="h-14 w-auto shrink-0"
          loading="eager"
        />

        <span class="nav-brand-copy hidden sm:flex">
          <span class="nav-brand-title">Agung Putra University</span>
          <span class="nav-brand-meta">Future-ready university · Semarang</span>
        </span>
      </a>

      <div class="nav-actions">
        {
          visibleUtilities.map((item, index) => (
            <a
              href={item.href}
              target={item.target}
              rel={item.rel}
              class:list={[
                "nav-utility-chip hidden min-[560px]:inline-flex",
                index === 0 ? "nav-utility-chip--secondary" : "nav-utility-chip--primary",
                index > 0 && "hidden md:inline-flex",
              ]}
            >
              {item.label}
            </a>
          ))
        }

        <button
          id="apu-menu-toggle"
          type="button"
          class="menu-toggle"
          aria-controls="apu-menu-overlay"
          aria-expanded="false"
          aria-haspopup="dialog"
          aria-label="Buka menu utama APU"
        >
          <span class="menu-toggle-label">Menu</span>
          <span class="menu-toggle-icon" aria-hidden="true">
            <span class="menu-line"></span>
            <span class="menu-line"></span>
            <span class="menu-line"></span>
          </span>
        </button>
      </div>
    </div>
  </div>

  <div id="apu-menu-overlay" class="nav-overlay" hidden aria-hidden="true">
    <div
      id="apu-menu-panel"
      class="nav-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="apu-menu-title"
      tabindex="-1"
    >
      <div class="nav-panel-head">
        <div class="nav-panel-copy">
          <span class="apu-section-kicker">APU Directory</span>
          <h2 id="apu-menu-title" class="text-h3 nav-panel-title">
            Institutional navigation, disederhanakan.
          </h2>
          <p class="text-body-s nav-panel-description">
            Struktur menu ini mengikuti arsitektur kampus utama: kategori institusi,
            tindakan cepat, dan akses ke ringkasan homepage yang sudah aktif.
          </p>
        </div>

        <button
          id="apu-menu-close"
          type="button"
          class="nav-close"
          data-menu-close
          aria-label="Tutup menu utama APU"
        >
          <span aria-hidden="true">×</span>
          <span>Tutup</span>
        </button>
      </div>

      <div class="nav-panel-grid">
        <div class="nav-panel-main">
          {
            groupedNav.map((group) => (
              <section class="nav-group" aria-labelledby={`nav-group-${toDomId(group.title)}`}>
                <div class="nav-group-head">
                  <h3 id={`nav-group-${toDomId(group.title)}`} class="nav-group-title">
                    {group.title}
                  </h3>
                  <p class="text-caption nav-group-description">{group.description}</p>
                </div>

                <ul class="nav-card-grid" role="list">
                  {
                    group.items.map((item) => {
                      const routePath = item.kind === "route" ? routePathFromHref(item.href) : undefined;
                      const isCurrentRoute =
                        item.kind === "route" && !item.placeholder && routePath === currentPath;

                      return (
                        <li>
                          {
                            item.placeholder ? (
                              <button
                                type="button"
                                class="nav-card nav-card--placeholder"
                                data-placeholder-item
                                data-placeholder-label={item.label}
                                data-placeholder-path={routePath}
                                aria-describedby="apu-placeholder-guidance"
                              >
                                <span class="nav-card-topline">
                                  <span class="nav-card-label">{item.label}</span>
                                  {item.badge && <span class="nav-card-badge">{item.badge}</span>}
                                </span>
                                <span class="nav-card-description">{item.description}</span>
                                <span class="nav-card-meta">Rute disiapkan untuk fase berikutnya</span>
                              </button>
                            ) : (
                              <a
                                href={item.href}
                                target={item.target}
                                rel={item.rel}
                                class:list={["nav-card", isCurrentRoute && "is-current-route"]}
                                data-menu-link
                                data-nav-kind={item.kind}
                                data-section={item.section}
                                data-route-path={routePath}
                                aria-current={isCurrentRoute ? "page" : undefined}
                              >
                                <span class="nav-card-topline">
                                  <span class="nav-card-label">{item.label}</span>
                                  {item.badge && <span class="nav-card-badge nav-card-badge--live">{item.badge}</span>}
                                </span>
                                <span class="nav-card-description">{item.description}</span>
                                <span class="nav-card-meta">Open section / route</span>
                              </a>
                            )
                          }
                        </li>
                      );
                    })
                  }
                </ul>
              </section>
            ))
          }
        </div>

        <aside class="nav-panel-side">
          <section class="nav-side-block" aria-labelledby="nav-utility-title">
            <div class="nav-side-head">
              <h3 id="nav-utility-title" class="nav-side-title">Utility Actions</h3>
              <p class="text-caption nav-side-description">
                Akses cepat untuk kebutuhan utama calon mahasiswa.
              </p>
            </div>

            <div class="nav-utility-list">
              {
                utilityActions.map((item, index) => {
                  const routePath = item.kind === "route" ? routePathFromHref(item.href) : undefined;

                  return item.placeholder ? (
                    <button
                      type="button"
                      class="nav-utility-row nav-utility-row--placeholder"
                      data-placeholder-item
                      data-placeholder-label={item.label}
                      data-placeholder-path={routePath}
                      aria-describedby="apu-placeholder-guidance"
                    >
                      <span class="nav-utility-row-copy">
                        <span class="nav-utility-row-label">{item.label}</span>
                        <span class="nav-utility-row-description">{item.description}</span>
                      </span>
                      <span class="nav-card-badge">{item.badge}</span>
                    </button>
                  ) : (
                    <a
                      href={item.href}
                      target={item.target}
                      rel={item.rel}
                      class:list={[
                        "nav-utility-row",
                        index === 0 && "nav-utility-row--accent",
                      ]}
                      data-menu-link
                    >
                      <span class="nav-utility-row-copy">
                        <span class="nav-utility-row-label">{item.label}</span>
                        <span class="nav-utility-row-description">{item.description}</span>
                      </span>
                      <span class="nav-utility-arrow" aria-hidden="true">↗</span>
                    </a>
                  );
                })
              }
            </div>
          </section>

          <section class="nav-side-block" aria-labelledby="nav-home-anchor-title">
            <div class="nav-side-head">
              <h3 id="nav-home-anchor-title" class="nav-side-title">On This Homepage</h3>
              <p class="text-caption nav-side-description">
                Tetap sediakan akses ke section penting selama rollout halaman penuh.
              </p>
            </div>

            <ul class="nav-anchor-list" role="list">
              {
                homeAnchors.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="nav-anchor-link"
                      data-menu-link
                      data-nav-kind="anchor"
                      data-section={item.section}
                    >
                      <span>{item.label}</span>
                      <span aria-hidden="true">↘</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>

          <section class="nav-side-block nav-side-block--contact" aria-labelledby="nav-contact-title">
            <div class="nav-side-head">
              <h3 id="nav-contact-title" class="nav-side-title">Need a fast answer?</h3>
              <p class="text-caption nav-side-description">
                Jalur tercepat saat ini tetap melalui admissions dan kontak kampus resmi.
              </p>
            </div>

            <div class="nav-contact-card">
              <p class="nav-contact-label">Admissions WhatsApp</p>
              <a
                href={admissionsWhatsApp}
                target="_blank"
                rel="noopener noreferrer"
                class="nav-contact-link"
                data-menu-link
              >
                +62 811 3755 552
              </a>

              <p class="nav-contact-label">Campus Address</p>
              <p class="nav-contact-copy">
                Jl. Nongkosawit Raya, Gn. Pati, Kota Semarang, Jawa Tengah 50224
              </p>
            </div>

            <p id="apu-placeholder-guidance" class="nav-placeholder-guidance">
              Item dengan badge <strong>Segera Hadir</strong> aman dipilih, tetapi rutenya
              belum dipublikasikan pada fase ini.
            </p>
            <p
              id="apu-placeholder-status"
              class="nav-placeholder-status"
              aria-live="polite"
              hidden
            ></p>
          </section>
        </aside>
      </div>
    </div>
  </div>
</nav>

<script>
  // @ts-nocheck
  (function () {
    const nav = document.getElementById("apu-nav");
    const menuToggle = document.getElementById("apu-menu-toggle");
    const menuOverlay = document.getElementById("apu-menu-overlay");
    const menuPanel = document.getElementById("apu-menu-panel");
    const menuClose = document.getElementById("apu-menu-close");
    const placeholderStatus = document.getElementById("apu-placeholder-status");

    if (
      !(nav instanceof HTMLElement) ||
      !(menuToggle instanceof HTMLButtonElement) ||
      !(menuOverlay instanceof HTMLDivElement) ||
      !(menuPanel instanceof HTMLDivElement) ||
      !(menuClose instanceof HTMLButtonElement)
    ) {
      return;
    }

    const navEl = /** @type {HTMLElement} */ (nav);
    const menuToggleEl = /** @type {HTMLButtonElement} */ (menuToggle);
    const menuOverlayEl = /** @type {HTMLDivElement} */ (menuOverlay);
    const menuPanelEl = /** @type {HTMLDivElement} */ (menuPanel);
    const menuCloseEl = /** @type {HTMLButtonElement} */ (menuClose);

    const homePath = normalizePath(navEl.getAttribute("data-home-path") || "/apu");
    const menuLinks = menuOverlayEl.querySelectorAll("a[data-menu-link]");
    const placeholderItems = menuOverlayEl.querySelectorAll("[data-placeholder-item]");
    const routeLinks = navEl.querySelectorAll('[data-nav-kind="route"]');
    const anchorLinks = navEl.querySelectorAll('[data-nav-kind="anchor"]');

    let isOpen = false;
    let bodyOverflow = "";
    let bodyPaddingRight = "";
    let closeTimer = 0;
    /** @type {IntersectionObserver | null} */
    let sectionObserver = null;

    /**
     * @param {string} path
     */
    function normalizePath(path) {
      const cleaned = (path || "").replace(/\/+$/, "");
      return cleaned || "/";
    }

    function setScrolledState() {
      navEl.setAttribute("data-scrolled", String(window.scrollY > 18));
    }

    function lockBodyScroll() {
      bodyOverflow = document.body.style.overflow;
      bodyPaddingRight = document.body.style.paddingRight;

      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
      document.body.style.overflow = "hidden";

      if (scrollbarWidth > 0) {
        document.body.style.paddingRight = `${scrollbarWidth}px`;
      }
    }

    function unlockBodyScroll() {
      document.body.style.overflow = bodyOverflow;
      document.body.style.paddingRight = bodyPaddingRight;
    }

    /**
     * @param {HTMLElement} link
     * @param {boolean} isActive
     */
    function setTrackedActiveState(link, isActive) {
      if (isActive) {
        link.setAttribute("data-active", "true");
        link.setAttribute(
          "aria-current",
          link.getAttribute("data-nav-kind") === "route" ? "page" : "location",
        );
      } else {
        link.removeAttribute("data-active");
        link.removeAttribute("aria-current");
      }
    }

    function updateRouteActiveState() {
      const pathname = normalizePath(window.location.pathname);

      routeLinks.forEach((link) => {
        const routePath = normalizePath(link.getAttribute("data-route-path") || "");
        setTrackedActiveState(link, routePath === pathname);
      });
    }

    function clearAnchorActiveState() {
      anchorLinks.forEach((link) => setTrackedActiveState(link, false));
    }

    /**
     * @param {string} sectionId
     */
    function syncAnchorActiveState(sectionId) {
      anchorLinks.forEach((link) => {
        setTrackedActiveState(link, link.getAttribute("data-section") === sectionId);
      });
    }

    function setupSectionObserver() {
      if (sectionObserver) {
        sectionObserver.disconnect();
        sectionObserver = null;
      }

      if (normalizePath(window.location.pathname) !== homePath) {
        clearAnchorActiveState();
        return;
      }

      /** @type {string[]} */
      const ids = (Array.from(anchorLinks)
        .map((link) => link.getAttribute("data-section"))
        .filter((id) => typeof id === "string"));

      /** @type {HTMLElement[]} */
      const sections = ([...new Set(ids)]
        .map((id) => document.getElementById(id))
        .filter((section) => section instanceof HTMLElement));

      if (!sections.length) {
        clearAnchorActiveState();
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const activeEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((entryA, entryB) => {
              if (entryB.intersectionRatio !== entryA.intersectionRatio) {
                return entryB.intersectionRatio - entryA.intersectionRatio;
              }

              return Math.abs(entryA.boundingClientRect.top) - Math.abs(entryB.boundingClientRect.top);
            })[0];

          if (activeEntry) {
            syncAnchorActiveState(activeEntry.target.id);
          }
        },
        {
          rootMargin: "-22% 0px -58% 0px",
          threshold: [0.15, 0.35, 0.55],
        },
      );

      sectionObserver = observer;

      sections.forEach((section) => observer.observe(section));

      const currentHash = window.location.hash.replace(/^#/, "");
      if (currentHash) {
        syncAnchorActiveState(currentHash);
      }
    }

    /**
     * @param {boolean} nextState
     * @param {{ returnFocus?: boolean }=} options
     */
    function setMenuOpen(
      nextState,
      options,
    ) {
      const settings = {
        returnFocus: true,
        ...options,
      };

      if (nextState === isOpen) {
        return;
      }

      window.clearTimeout(closeTimer);
      isOpen = nextState;

      navEl.setAttribute("data-open", String(nextState));
      menuToggleEl.setAttribute("aria-expanded", String(nextState));
      menuToggleEl.setAttribute(
        "aria-label",
        nextState ? "Tutup menu utama APU" : "Buka menu utama APU",
      );

      if (nextState) {
        menuOverlayEl.hidden = false;
        menuOverlayEl.setAttribute("aria-hidden", "false");
        lockBodyScroll();
        menuPanelEl.scrollTop = 0;

        if (placeholderStatus instanceof HTMLElement) {
          placeholderStatus.hidden = true;
          placeholderStatus.textContent = "";
        }

        requestAnimationFrame(() => {
          menuOverlayEl.setAttribute("data-state", "open");
        });

        menuCloseEl.focus();
        return;
      }

      menuOverlayEl.setAttribute("data-state", "closed");
      menuOverlayEl.setAttribute("aria-hidden", "true");
      unlockBodyScroll();

      closeTimer = window.setTimeout(() => {
        if (!isOpen) {
          menuOverlayEl.hidden = true;
        }
      }, 280);

      if (settings.returnFocus) {
        menuToggleEl.focus();
      }
    }

    menuToggleEl.addEventListener("click", () => {
      setMenuOpen(!isOpen, { returnFocus: false });
    });

    menuCloseEl.addEventListener("click", () => {
      setMenuOpen(false, { returnFocus: true });
    });

    menuOverlayEl.addEventListener("click", (event) => {
      if (event.target === menuOverlayEl) {
        setMenuOpen(false, { returnFocus: true });
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isOpen) {
        event.preventDefault();
        setMenuOpen(false, { returnFocus: true });
      }
    });

    menuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        setMenuOpen(false, { returnFocus: false });
      });
    });

    placeholderItems.forEach((item) => {
      item.addEventListener("click", () => {
        if (!(placeholderStatus instanceof HTMLElement)) {
          return;
        }

        const label = item.getAttribute("data-placeholder-label") || "Halaman ini";
        const path = item.getAttribute("data-placeholder-path");

        placeholderStatus.hidden = false;
        placeholderStatus.textContent = path
          ? `${label} sedang dipersiapkan. Rute ${path} belum dipublikasikan pada fase ini.`
          : `${label} sedang dipersiapkan dan akan hadir pada fase berikutnya.`;
      });
    });

    window.addEventListener("scroll", setScrolledState, { passive: true });
    window.addEventListener("hashchange", setupSectionObserver);

    setScrolledState();
    updateRouteActiveState();
    setupSectionObserver();
  })();
</script>

<style>
  #apu-nav {
    color: rgb(var(--color-apu-navy));
  }

  #apu-nav .nav-topline {
    height: 2px;
    width: 100%;
    background: linear-gradient(
      90deg,
      rgb(var(--color-apu-accent) / 0.95),
      rgb(var(--color-apu-accent) / 0.24),
      transparent 78%
    );
  }

  #apu-nav .nav-shell {
    display: flex;
    position: relative;
    z-index: 2;
    min-height: 78px;
    align-items: center;
