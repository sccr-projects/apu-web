---
import { assetUrl } from '@lib/assets';
const HOME_PATH = "/";

const normalizePath = (path: string) => {
  const cleaned = path.replace(/\/+$/, "");
  return cleaned || "/";
};

const routePathFromHref = (href: string) => {
  try {
    return normalizePath(new URL(href, "https://apu.local").pathname);
  } catch {
    return HOME_PATH;
  }
};

const currentPath = normalizePath(Astro.url.pathname);
const admissionsWhatsApp =
  "https://wa.me/628113755552?text=Halo, saya ingin menanyakan informasi pendaftaran mahasiswa baru APU 2026/2027.";

type NavItem = {
  label: string;
  href: string;
  description: string;
  kind: "route" | "anchor" | "external";
  section?: string;
  placeholder?: boolean;
  badge?: string;
  target?: string;
  rel?: string;
  children?: NavItem[];  // NEW: nested children
};

type NavSection = {
  label: string;
  href?: string;
  items?: NavItem[];
  kind?: "route" | "anchor" | "external";
  section?: string;
  placeholder?: boolean;
  badge?: string;
  target?: string;
  rel?: string;
};

const navSections: NavSection[] = [
  {
    label: "Home",
    href: HOME_PATH,
    kind: "route",
  },
  {
    label: "Admission",
    href: `${HOME_PATH}admission`,
    kind: "route",
    items: [
      {
        label: "Scholarship",
        href: `${HOME_PATH}admission`,
        description: "Beasiswa APU — jalur beasiswa akademik dan non-akademik.",
        kind: "route",
        children: [
          {
            label: "Academic",
            href: `${HOME_PATH}admission/academic-scholarship`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "route",
          },
          {
            label: "Non-Academic",
            href: `https://scholarship.apu.ac.id/non-academic-achievement-scholarship/`,
            description: "Beasiswa berbasis prestasi non-akademik.",
            kind: "anchor",
          },
          {
            label: "Partnership",
            href: `https://scholarship.apu.ac.id/partnership-scholarship/`,
            description: "Beasiswa berbasis prestasi non-akademik.",
            kind: "anchor",
          },
          {
            label: "Content Creator",
            href: `https://scholarship.apu.ac.id/content-creator-scholarship/`,
            description: "Beasiswa berbasis prestasi non-akademik.",
            kind: "anchor",
          },
        ],
      },
    ],
  },
  {
    label: "Academic",
    href: `${HOME_PATH}academic`,
    kind: "anchor",
    section: "program",
    items: [
      {
        label: "Study Programs",
        href: `${HOME_PATH}academic`,
        description: "Study programs, curriculum, and learning support at APU.",
        kind: "route",
        children: [
          {
            label: "Biomedical Science",
            href: `${HOME_PATH}academic/biomedical`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "route",
          },
          {
            label: "Biotechnology",
            href: `https://biotechnology.apu.ac.id/`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
          {
            label: "Law",
            href: `${HOME_PATH}academic/law`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
          {
            label: "Management",
            href: `https://management.apu.ac.id/`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
          {
            label: "Communication Science",
            href: `${HOME_PATH}academic/communication`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
          {
            label: "Midwifery Bachelors",
            href: `${HOME_PATH}academic/midwifery-bachelor`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
          {
            label: "Midwifery Associate",
            href: `${HOME_PATH}academic/midwifery-associate`,
            description: "Beasiswa berbasis prestasi akademik.",
            kind: "anchor",
          },
        ],
      },
    ],
  },
  // {
  //   label: "Research",
  //   href: `#`,
  //   kind: "anchor",
  //   placeholder: true,
  //   badge: "Coming Soon",
  // },
  // {
  //   label: "News",
  //   href: `#`,
