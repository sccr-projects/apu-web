const visibleUtilities = utilityActions.filter((item) => !item.placeholder).slice(0, 1);
---

<nav
  id="apu-nav"
  data-home-path={HOME_PATH}
  data-open="false"
  data-scrolled="false"
  class="fixed inset-x-0 top-0 z-50"
  aria-label="Main APU navigation"
>

  <div class="nav-bar">
    <div class="nav-bar-inner md:px-20">
      <a href={HOME_PATH} class="nav-brand">
        <img
          src={assetUrl('/images/apu.webp')}
          alt="Agung Putra University"
          class="h-18 w-auto shrink-0"
          loading="eager"
        />
        <span class="nav-brand-copy hidden sm:flex">
          <span class="font-semibold text-xl">Agung Putra University</span>
        </span>
      </a>

      <ul class="nav-desktop" role="menubar">
        {
          navSections.map((section) => (
            <li
              class="nav-item "
              role="none"
              data-has-dropdown={section.items ? "true" : "false"}
            >
              {section.items ? (
                <>
                  {section.href ? (
                    <a
                      href={section.href}
                      class="nav-trigger"
                      role="menuitem"
                      aria-expanded="false"
                      aria-haspopup="true"
                      data-nav-kind={section.kind}
                      data-section={section.section}
                      data-route-path={section.kind === "route" && section.href ? routePathFromHref(section.href) : undefined}
                    >
                      <span>{section.label}</span>
                      <svg
                        class="nav-chevron"
                        width="12"
                        height="12"
                        viewBox="0 0 12 12"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M2.5 4.5L6 8L9.5 4.5"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  ) : (
                    <button
                      type="button"
                      class="nav-trigger"
                      aria-expanded="false"
                      aria-haspopup="true"
                      data-nav-kind={section.kind}
                      data-section={section.section}
                      data-route-path={section.kind === "route" && section.href ? routePathFromHref(section.href) : undefined}
                    >
                      <span>{section.label}</span>
                      <svg
                        class="nav-chevron"
                        width="12"
                        height="12"
                        viewBox="0 0 12 12"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M2.5 4.5L6 8L9.5 4.5"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </button>
                  )}
                  <div class="nav-dropdown" role="menu">
                    <ul class="nav-dropdown-list">
                      {section.items.map((item) => {
                        const routePath = item.kind === "route" ? routePathFromHref(item.href) : undefined;
                        const isCurrentRoute =
                          item.kind === "route" && !item.placeholder && routePath === currentPath;
                        const hasChildren = Array.isArray(item.children) && item.children.length > 0;

                        return item.placeholder ? (
                          <li role="none">
                            <button
                              type="button"
                              class="nav-dropdown-item nav-dropdown-item--placeholder"
                              data-placeholder-item
                              data-placeholder-label={item.label}
                              data-placeholder-path={routePath}
                              role="menuitem"
                            >
                              <span class="nav-dropdown-label">{item.label}</span>
                              {item.badge && <span class="nav-dropdown-badge">{item.badge}</span>}
                            </button>
                          </li>
                        ) : hasChildren ? (
                          <li role="none">
                            <div class="nav-dropdown-cascade">
                              <a
                                href={item.href}
                                target={item.target}
                                rel={item.rel}
                                class:list={["nav-dropdown-item", isCurrentRoute && "is-current-route"]}
                                data-menu-link
                                data-nav-kind={item.kind}
                                data-section={item.section}
                                data-route-path={routePath}
                                aria-current={isCurrentRoute ? "page" : undefined}
                                role="menuitem"
                              >
                                <span class="nav-dropdown-label">{item.label}</span>
                                {item.badge && <span class="nav-dropdown-badge nav-dropdown-badge--live">{item.badge}</span>}
                              </a>
                              <ul class="nav-dropdown-children" role="menu">
                                {item.children!.map((child) => {
                                  const childRoutePath = child.kind === "route" ? routePathFromHref(child.href) : undefined;
                                  const isChildCurrent =
                                    child.kind === "route" && !child.placeholder && childRoutePath === currentPath;

                                  return (
                                    <li role="none">
                                      <a
                                        href={child.href}
                                        target={child.target}
                                        rel={child.rel}
                                        class:list={["nav-dropdown-item nav-dropdown-item--child", isChildCurrent && "is-current-route"]}
                                        data-menu-link
                                        data-nav-kind={child.kind}
                                        data-section={child.section}
                                        data-route-path={childRoutePath}
                                        aria-current={isChildCurrent ? "page" : undefined}
                                        role="menuitem"
                                      >
                                        <span class="nav-dropdown-label">{child.label}</span>
                                        {child.badge && <span class="nav-dropdown-badge nav-dropdown-badge--live">{child.badge}</span>}
                                      </a>
                                    </li>
                                  );
                                })}
                              </ul>
                            </div>
                          </li>
                        ) : (
                          <li role="none">
                            <a
                              href={item.href}
                              target={item.target}
                              rel={item.rel}
                              class:list={["nav-dropdown-item", isCurrentRoute && "is-current-route"]}
                              data-menu-link
                              data-nav-kind={item.kind}
                              data-section={item.section}
                              data-route-path={routePath}
                              aria-current={isCurrentRoute ? "page" : undefined}
                              role="menuitem"
                            >
                              <span class="nav-dropdown-label">{item.label}</span>
                              {item.badge && <span class="nav-dropdown-badge nav-dropdown-badge--live">{item.badge}</span>}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </>
              ) : (
                <a
                  href={section.href}
                  class="nav-link"
                  data-nav-kind={section.kind}
                  data-section={section.section}
                  data-route-path={section.kind === "route" ? routePathFromHref(section.href || "") : undefined}
                  role="menuitem"
                >
                  <span>{section.label}</span>
                  {section.badge && <span class="nav-link-badge">{section.badge}</span>}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <div class="nav-actions">
        {
          visibleUtilities.map((item) => (
            <a
              href={item.href}
              target={item.target}
              rel={item.rel}
              class="nav-cta"
            >
              {item.label}
            </a>
          ))
        }

        <button
          id="apu-menu-toggle"
          type="button"
          class="menu-toggle"
          aria-controls="apu-mobile-menu"
          aria-expanded="false"
          aria-label="Open main APU menu"
        >
          <span class="menu-toggle-label">Menu</span>
          <span class="menu-toggle-icon" aria-hidden="true">
            <span class="menu-line"></span>
            <span class="menu-line"></span>
            <span class="menu-line"></span>
          </span>
        </button>
      </div>
    </div>
  </div>

    <div id="apu-mobile-menu" class="mobile-menu" hidden aria-hidden="true">
    <div class="mobile-menu-backdrop"></div>
    <div class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="APU navigation menu">
      <div class="mobile-menu-header">
        <span class="apu-section-kicker">Navigation Menu</span>
        <button
          id="apu-menu-close"
          type="button"
          class="mobile-menu-close"
          aria-label="Close menu"
        >
          <span aria-hidden="true">×</span>
        </button>
      </div>

      <ul class="mobile-nav-list" role="menu">
        {
          navSections.map((section) => (
            <li class="mobile-nav-item" role="none">
              {section.items ? (
                <div class="mobile-nav-group">
                  <button
                    type="button"
                    class="mobile-nav-trigger"
                    aria-expanded="false"
                    aria-haspopup="true"
                  >
                    <span>{section.label}</span>
                    <svg
                      class="mobile-nav-chevron"
                      width="14"
                      height="14"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.5 4.5L6 8L9.5 4.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </button>
                  <ul class="mobile-nav-submenu" role="menu">
                    {section.items.map((item) => {
                      const routePath = item.kind === "route" ? routePathFromHref(item.href) : undefined;
                      const hasChildren = Array.isArray(item.children) && item.children.length > 0;

                      return item.placeholder ? (
                        <li role="none">
                          <button
                            type="button"
                            class="mobile-nav-submenu-item mobile-nav-submenu-item--placeholder"
                            data-placeholder-item
                            data-placeholder-label={item.label}
                            data-placeholder-path={routePath}
                            role="menuitem"
                          >
                            <span>{item.label}</span>
                            {item.badge && <span class="mobile-nav-badge">{item.badge}</span>}
                          </button>
                        </li>
                      ) : (
                        <li role="none">
                          {hasChildren ? (
                            <div class="mobile-nav-cascade">
                              <a
                                href={item.href}
                                target={item.target}
                                rel={item.rel}
                                class="mobile-nav-submenu-item mobile-nav-submenu-item--parent"
                                data-menu-link
                                data-nav-kind={item.kind}
                                data-section={item.section}
                                data-route-path={routePath}
                                role="menuitem"
                              >
                                <span>{item.label}</span>
                                {item.badge && <span class="mobile-nav-badge mobile-nav-badge--live">{item.badge}</span>}
                              </a>
                              <ul class="mobile-nav-children" role="menu">
                                {item.children!.map((child) => {
                                  const childRoutePath = child.kind === "route" ? routePathFromHref(child.href) : undefined;

                                  return (
                                    <li role="none">
                                      <a
                                        href={child.href}
                                        target={child.target}
                                        rel={child.rel}
                                        class="mobile-nav-submenu-item mobile-nav-submenu-item--child"
                                        data-menu-link
                                        data-nav-kind={child.kind}
                                        data-section={child.section}
                                        data-route-path={childRoutePath}
                                        role="menuitem"
                                      >
                                        <span>{child.label}</span>
                                        {child.badge && <span class="mobile-nav-badge mobile-nav-badge--live">{child.badge}</span>}
                                      </a>
                                    </li>
                                  );
                                })}
                              </ul>
                            </div>
                          ) : (
                            <a
                              href={item.href}
                              target={item.target}
                              rel={item.rel}
                              class="mobile-nav-submenu-item"
                              data-menu-link
                              data-nav-kind={item.kind}
                              data-section={item.section}
                              data-route-path={routePath}
                              role="menuitem"
                            >
                              <span>{item.label}</span>
                              {item.badge && <span class="mobile-nav-badge mobile-nav-badge--live">{item.badge}</span>}
                            </a>
                           )}
                         </li>
                       );
                     })}
                   </ul>
                 </div>
               ) : (
                <a
                  href={section.href}
                  class="mobile-nav-link"
                  data-nav-kind={section.kind}
                  data-section={section.section}
                  data-route-path={section.kind === "route" ? routePathFromHref(section.href || "") : undefined}
                  role="menuitem"
                >
                  <span>{section.label}</span>
                  {section.badge && <span class="mobile-nav-badge">{section.badge}</span>}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <div class="mobile-menu-footer">
        <div class="mobile-menu-contact">
          <p class="mobile-menu-contact-label">Admissions WhatsApp</p>
          <a
            href={admissionsWhatsApp}
            target="_blank"
            rel="noopener noreferrer"
            class="mobile-menu-contact-link"
          >
            +62 811 3755 552
          </a>
        </div>
        <p id="apu-placeholder-status" class="mobile-placeholder-status" aria-live="polite" hidden></p>
      </div>
    </div>
  </div>
</nav>

<script>
  // @ts-nocheck
  (function () {
    const nav = document.getElementById("apu-nav");
    const menuToggle = document.getElementById("apu-menu-toggle");
    const mobileMenu = document.getElementById("apu-mobile-menu");
    const menuClose = document.getElementById("apu-menu-close");
    const placeholderStatus = document.getElementById("apu-placeholder-status");

    if (
      !(nav instanceof HTMLElement) ||
      !(menuToggle instanceof HTMLButtonElement) ||
      !(mobileMenu instanceof HTMLDivElement) ||
      !(menuClose instanceof HTMLButtonElement)
    ) {
      return;
    }

    const navEl = /** @type {HTMLElement} */ (nav);
    const menuToggleEl = /** @type {HTMLButtonElement} */ (menuToggle);
    const mobileMenuEl = /** @type {HTMLDivElement} */ (mobileMenu);
    const menuCloseEl = /** @type {HTMLButtonElement} */ (menuClose);

    const homePath = normalizePath(navEl.getAttribute("data-home-path") || HOME_PATH);
    const menuLinks = mobileMenuEl.querySelectorAll("a[data-menu-link]");
    const placeholderItems = mobileMenuEl.querySelectorAll("[data-placeholder-item]");
    const routeLinks = navEl.querySelectorAll('[data-nav-kind="route"]');
    const anchorLinks = navEl.querySelectorAll('[data-nav-kind="anchor"]');
    const desktopTriggers = navEl.querySelectorAll('.nav-trigger');
    const mobileTriggers = navEl.querySelectorAll('.mobile-nav-trigger');

    let isOpen = false;
    let bodyOverflow = "";
    let bodyPaddingRight = "";
    let bodyPosition = "";
    let bodyWidth = "";
    let bodyTop = "";
    let closeTimer = 0;
    let hoverTimer = 0;
    /** @type {IntersectionObserver | null} */
    let sectionObserver = null;

    function normalizePath(path) {
      const cleaned = (path || "").replace(/\/+$/, "");
      return cleaned || "/";
    }

    function setScrolledState() {
      navEl.setAttribute("data-scrolled", String(window.scrollY > 18));
    }

    function lockBodyScroll() {
      bodyOverflow = document.body.style.overflow;
      bodyPaddingRight = document.body.style.paddingRight;
      bodyPosition = document.body.style.position;
      bodyWidth = document.body.style.width;
      bodyTop = document.body.style.top;
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
      document.body.style.overflow = "hidden";
      document.body.style.position = "fixed";
      document.body.style.width = "100%";
      document.body.style.top = `-${window.scrollY}px`;
      if (scrollbarWidth > 0) {
        document.body.style.paddingRight = `${scrollbarWidth}px`;
      }
    }

    function unlockBodyScroll() {
      const scrollY = Math.abs(parseInt(document.body.style.top || "0", 10));
      document.body.style.overflow = bodyOverflow;
      document.body.style.paddingRight = bodyPaddingRight;
      document.body.style.position = bodyPosition;
      document.body.style.width = bodyWidth;
      document.body.style.top = bodyTop;
      if (scrollY) {
        window.scrollTo(0, scrollY);
      }
    }

    function setTrackedActiveState(link, isActive) {
      if (isActive) {
        link.setAttribute("data-active", "true");
        link.setAttribute(
          "aria-current",
          link.getAttribute("data-nav-kind") === "route" ? "page" : "location",
        );
      } else {
        link.removeAttribute("data-active");
        link.removeAttribute("aria-current");
      }
    }

    function updateRouteActiveState() {
      const pathname = normalizePath(window.location.pathname);
      routeLinks.forEach((link) => {
        const rawPath = link.getAttribute("data-route-path");
        if (rawPath == null) return;
        const routePath = normalizePath(rawPath);
        setTrackedActiveState(link, routePath === pathname);
      });
    }

    function clearAnchorActiveState() {
      anchorLinks.forEach((link) => setTrackedActiveState(link, false));
    }

    function syncAnchorActiveState(sectionId) {
      anchorLinks.forEach((link) => {
        setTrackedActiveState(link, link.getAttribute("data-section") === sectionId);
      });
    }

    function setupSectionObserver() {
      if (sectionObserver) {
        sectionObserver.disconnect();
        sectionObserver = null;
      }

      if (normalizePath(window.location.pathname) !== homePath) {
        clearAnchorActiveState();
        return;
      }

      const ids = Array.from(anchorLinks)
        .map((link) => link.getAttribute("data-section"))
        .filter((id) => typeof id === "string");

      const sections = [...new Set(ids)]
        .map((id) => document.getElementById(id))
        .filter((section) => section instanceof HTMLElement);

      if (!sections.length) {
        clearAnchorActiveState();
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const activeEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((entryA, entryB) => {
              if (entryB.intersectionRatio !== entryA.intersectionRatio) {
                return entryB.intersectionRatio - entryA.intersectionRatio;
              }
              return Math.abs(entryA.boundingClientRect.top) - Math.abs(entryB.boundingClientRect.top);
            })[0];

          if (activeEntry) {
            syncAnchorActiveState(activeEntry.target.id);
          }
        },
        {
          rootMargin: "-22% 0px -58% 0px",
          threshold: [0.15, 0.35, 0.55],
        },
      );

      sectionObserver = observer;
      sections.forEach((section) => observer.observe(section));

      const currentHash = window.location.hash.replace(/^#/, "");
      if (currentHash) {
        syncAnchorActiveState(currentHash);
      }
    }

    function setMenuOpen(nextState, options = {}) {
      const settings = { returnFocus: true, ...options };

      if (nextState === isOpen) return;

      window.clearTimeout(closeTimer);
      isOpen = nextState;

      navEl.setAttribute("data-open", String(nextState));
      menuToggleEl.setAttribute("aria-expanded", String(nextState));
      menuToggleEl.setAttribute(
        "aria-label",
        nextState ? "Close main APU menu" : "Open main APU menu",
      );

      if (nextState) {
        mobileMenuEl.hidden = false;
        mobileMenuEl.setAttribute("aria-hidden", "false");
        lockBodyScroll();
        document.addEventListener("keydown", handleMobileKeydown);

        if (placeholderStatus instanceof HTMLElement) {
          placeholderStatus.hidden = true;
          placeholderStatus.textContent = "";
        }

        requestAnimationFrame(() => {
          mobileMenuEl.setAttribute("data-state", "open");
        });

        menuCloseEl.focus();
        return;
      }

      mobileMenuEl.setAttribute("data-state", "closed");
      mobileMenuEl.setAttribute("aria-hidden", "true");
      unlockBodyScroll();
      document.removeEventListener("keydown", handleMobileKeydown);

      closeTimer = window.setTimeout(() => {
        if (!isOpen) {
          mobileMenuEl.hidden = true;
        }
      }, 280);

      if (settings.returnFocus) {
        menuToggleEl.focus();
      }
    }

    // Desktop hover dropdowns
    desktopTriggers.forEach((trigger) => {
      const parent = trigger.closest('.nav-item');
      const dropdown = parent?.querySelector('.nav-dropdown');
      if (!dropdown) return;

      /** @type {number | null} */
      let enterTimer = null;
      /** @type {number | null} */
      let leaveTimer = null;

      function openDropdown() {
        window.clearTimeout(leaveTimer);
        leaveTimer = null;
        window.clearTimeout(enterTimer);
        enterTimer = window.setTimeout(() => {
          trigger.setAttribute('aria-expanded', 'true');
          dropdown.setAttribute('data-open', 'true');
        }, 150);
      }

      function closeDropdown() {
        window.clearTimeout(enterTimer);
        enterTimer = null;
        window.clearTimeout(leaveTimer);
        leaveTimer = window.setTimeout(() => {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.setAttribute('data-open', 'false');
        }, 400);
      }

      trigger.addEventListener('mouseenter', openDropdown);
      dropdown.addEventListener('mouseenter', openDropdown);
      trigger.addEventListener('mouseleave', closeDropdown);
      dropdown.addEventListener('mouseleave', closeDropdown);

      trigger.addEventListener('click', (e) => {
        if (trigger instanceof HTMLAnchorElement) return;
        e.preventDefault();
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!isExpanded));
        dropdown.setAttribute('data-open', String(!isExpanded));
      });

      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          if (trigger instanceof HTMLAnchorElement) return;
          e.preventDefault();
          const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
          trigger.setAttribute('aria-expanded', String(!isExpanded));
          dropdown.setAttribute('data-open', String(!isExpanded));
        }
        if (e.key === 'Escape') {
          trigger.setAttribute('aria-expanded', 'false');
          dropdown.setAttribute('data-open', 'false');
          trigger.focus();
        }
      });

      const navItem = trigger.closest('.nav-item');
      if (navItem) {
        navItem.addEventListener('focusin', openDropdown);
        navItem.addEventListener('focusout', (e) => {
          if (!navItem.contains(e.relatedTarget)) {
            closeDropdown();
          }
        });
      }
    });

    // Mobile accordion
    mobileTriggers.forEach((trigger) => {
      const parent = trigger.closest('.mobile-nav-group');
      const submenu = parent?.querySelector('.mobile-nav-submenu');
      if (!submenu) return;

      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!isExpanded));
        submenu.setAttribute('data-open', String(!isExpanded));
        submenu.style.maxHeight = isExpanded ? '0px' : `${submenu.scrollHeight}px`;
      });
    });

    menuToggleEl.addEventListener("click", () => {
      setMenuOpen(!isOpen);
    });

    menuCloseEl.addEventListener("click", () => {
      setMenuOpen(false, { returnFocus: true });
    });

    mobileMenuEl.addEventListener("click", (event) => {
      if (event.target === mobileMenuEl.querySelector('.mobile-menu-backdrop')) {
        setMenuOpen(false, { returnFocus: true });
      }
    });

    function handleMobileKeydown(event) {
      if (event.key === "Escape" && isOpen) {
        event.preventDefault();
        setMenuOpen(false, { returnFocus: true });
        return;
      }

      if (event.key !== "Tab" || !isOpen) return;

      const panel = mobileMenuEl.querySelector('.mobile-menu-panel');
      if (!panel) return;

      const focusable = Array.from(
        panel.querySelectorAll('a[href], button, input, textarea, select, [tabindex]:not([tabindex="-1"])')
      ).filter((el) => {
        if (el.hasAttribute('disabled')) return false;
        if (el.offsetParent === null) return false;
        const closedSubmenu = el.closest('.mobile-nav-submenu[data-open="false"]');
        if (closedSubmenu) return false;
        return true;
      });

      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const active = document.activeElement;

      if (event.shiftKey) {
        if (active === first) {
          event.preventDefault();
          last.focus();
        }
      } else {
        if (active === last) {
          event.preventDefault();
          first.focus();
        }
      }
    }

    menuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        setMenuOpen(false, { returnFocus: false });
      });
    });

    placeholderItems.forEach((item) => {
      item.addEventListener("click", () => {
        if (!(placeholderStatus instanceof HTMLElement)) return;

        const label = item.getAttribute("data-placeholder-label") || "Halaman ini";
        const path = item.getAttribute("data-placeholder-path");

        placeholderStatus.hidden = false;
        placeholderStatus.textContent = path
          ? `${label} is being prepared. The ${path} route has not been published in this phase.`
          : `${label} is being prepared and will be available in the next phase.`;
      });
    });

    window.addEventListener("scroll", setScrolledState, { passive: true });
    window.addEventListener("hashchange", setupSectionObserver);

    setScrolledState();
    updateRouteActiveState();
    setupSectionObserver();
  })();
</script>

