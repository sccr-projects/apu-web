---
import { Image } from "astro:assets";
import type { Lecturer } from "@data/lecturers";
import canada from "@/assets/images/academic/canada-bg.jpg";
import googleScholar from "@/assets/images/academic/google_scholar.webp";
import scopus from "@/assets/images/academic/scopus.webp";

interface Props {
  person: Lecturer;
  class?: string;
}

const { person, class: className = "" } = Astro.props;
const bgImage = person.backgroundImage ?? canada;
const portrait = (person.diasporaImage ?? person.image)!;
const scopusHref = person.scopusId
  ? `https://www.scopus.com/authid/detail.uri?authorId=${person.scopusId}`
  : "#";
---

<div
  class:list={["relative flex justify-center w-full py-8", className]}
  data-diaspora-featured-card
>
  <Image
    src={bgImage}
    alt=""
    class="pointer-events-none absolute top-0 left-0 h-full w-full object-cover opacity-10"
    aria-hidden="true"
    loading="eager"
    data-featured-background
  />
  <img
    src={person.flag}
    alt={`Flag of ${person.country}`}
    class="absolute top-4 right-4 h-20 w-auto rounded-sm opacity-75 shadow-lg"
    loading="eager"
    data-featured-flag
  />

  <div class="relative z-10 flex w-full flex-col justify-center md:flex-row">
    <div
      class="order-2 flex w-full flex-col justify-center px-4 md:order-1 md:w-1/2 md:px-0 md:pl-10"
    >
      <h2 class="text-h2 mb-3 text-white" data-featured-name>
        {person.name}
      </h2>
      <p class="text-body mb-3 text-apu-accent" data-featured-role>
        {person.role}
      </p>

      <div class="mb-6">
        <p class="text-body mb-6 text-apu-accent" data-featured-univ>
          {person.university}
        </p>
        <h3
          class="text-caption mb-3 uppercase tracking-widest text-white/70"
        >
          Past Experience
        </h3>
        <ul class="space-y-2" data-featured-past-experience>
          {
            (person.pastExperience ?? []).map((item) => (
              <li class="text-body-s flex items-start gap-3 text-white/90">
                <span
                  class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-apu-accent"
                  aria-hidden="true"
                />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mb-2">
        <h3
          class="text-caption mb-3 uppercase tracking-widest text-white/70"
        >
          Notable Research
        </h3>
        <p
          class="text-body-s leading-relaxed text-white/90"
          data-featured-notable-research
        >
          {person.notableResearch}
        </p>
      </div>

      <p class="mb-4 text-caption text-white/60 ">NIDN {person.nidn}</p>

      <div class="flex flex-row gap-3">
          <div>
              <a
                data-featured-google-link
                href={person.googleScholar || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "flex flex-row w-full mb-6 text-white",
                  { hidden: !person.googleScholar },
                ]}
              >
                <Image
                  src={googleScholar}
                  alt={`Google Scholar profile of ${person.name}`}
                  class="w-6 object-contain border-0 mr-1"
                  loading="lazy"
                />
                <span class="text-white" data-featured-google-index>{person.googleIndex ?? ""}</span>
              </a>
          </div>

          <div>
              <a
                data-featured-scopus-link
                href={scopusHref}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "flex flex-row w-full mb-6 text-white",
                  { hidden: !person.scopusId },
                ]}
              >
                <Image
                  src={scopus}
                  alt={`Scopus profile of ${person.name}`}
                  class="w-6 object-contain border-0 mr-1"
                  loading="lazy"
                />
                <span class="text-white" data-featured-scopus-index>{person.scopusIndex ?? ""}</span>
              </a>
          </div>

      </div>





      <div class="flex flex-wrap items-center gap-4">
        <a
          href={person.googleScholar}
          target="_blank"
          rel="noopener noreferrer"
          class="apu-btn apu-btn--primary inline-flex items-center gap-2"
          data-featured-profile
        >
          View Researcher Profile
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="relative order-1 mb-4 w-full md:order-2 md:mb-0 md:w-96">
      <div class="relative aspect-[4/5] overflow-hidden rounded-2xl md:aspect-auto md:h-full">
        <Image
          src={portrait}
          alt={`Portrait of ${person.name}`}
          class="h-full w-full border-0 object-cover"
          style={`object-position: ${person.position ?? 50}% center;`}
          loading="eager"
          data-featured-image
        />
      </div>
    </div>
  </div>
</div>
