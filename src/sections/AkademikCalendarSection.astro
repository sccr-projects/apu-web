---
import ScrollReveal from '../components/ScrollReveal.astro';
import SectionHeader from '../components/SectionHeader.astro';

interface CalendarEvent {
  dateRange: string;
  title: string;
  description: string;
  type: 'akademik' | 'pendaftaran' | 'libur' | 'ujian';
  highlight?: boolean;
}

interface SemesterData {
  id: string;
  label: string;
  period: string;
  months: {
    month: string;
    year: string;
    events: CalendarEvent[];
  }[];
}

const semesters: SemesterData[] = [
  {
    id: 'ganjil',
    label: 'Semester Ganjil',
    period: 'Agustus 2025 – Januari 2026',
    months: [
      {
        month: 'Agustus',
        year: '2025',
        events: [
          { dateRange: '1 – 15 Agt', title: 'Pendaftaran Ulang Mahasiswa Baru', description: 'Registrasi dan verifikasi data untuk mahasiswa yang diterima pada periode penerimaan sebelumnya.', type: 'pendaftaran' },
          { dateRange: '18 – 22 Agt', title: 'Pengenalan Kehidupan Kampus', description: 'Orientasi mahasiswa baru mengenai fasilitas, aturan akademik, dan organisasi kemahasiswaan.', type: 'akademik', highlight: true },
          { dateRange: '25 Agt', title: 'Awal Perkuliahan Semester Ganjil', description: 'Pertemuan pertama perkuliahan untuk seluruh program studi.', type: 'akademik', highlight: true },
        ]
      },
      {
        month: 'September',
        year: '2025',
        events: [
          { dateRange: '1 – 5 Sep', title: 'Periode Penambahan & Penggantian MK', description: 'Jadwal untuk mengubah mata kuliah yang telah dipilih sebelumnya.', type: 'akademik' },
          { dateRange: '15 – 19 Sep', title: 'Pendaftaran Beasiswa Semester Ganjil', description: 'Pengajuan berkas beasiswa berprestasi dan bantuan biaya pendidikan.', type: 'pendaftaran' },
        ]
      },
      {
        month: 'Oktober',
        year: '2025',
        events: [
          { dateRange: '6 – 10 Okt', title: 'Ujian Tengah Semester (UTS)', description: 'Evaluasi pembelajaran pertengahan semester untuk seluruh mata kuliah.', type: 'ujian', highlight: true },
          { dateRange: '20 Okt – 24 Okt', title: 'Pekan Kampus', description: 'Serangkaian acara kemahasiswaan, seminar, dan kompetisi antar-fakultas.', type: 'akademik' },
        ]
      },
      {
        month: 'November',
        year: '2025',
        events: [
          { dateRange: '10 – 14 Nov', title: 'Pengisian KRS Semester Genap', description: 'Perencanaan studi dan pemilihan mata kuliah untuk semester berikutnya.', type: 'akademik' },
        ]
      },
      {
        month: 'Desember',
        year: '2025',
        events: [
          { dateRange: '1 – 5 Des', title: 'Batas Pembayaran UKT Semester Genap', description: 'Tenggat waktu pembayaran uang kuliah tunggal untuk semester berikutnya.', type: 'pendaftaran', highlight: true },
          { dateRange: '15 – 19 Des', title: 'Ujian Akhir Semester (UAS)', description: 'Evaluasi akhir semester untuk mengukur capaian pembelajaran mahasiswa.', type: 'ujian', highlight: true },
        ]
      },
      {
        month: 'Januari',
        year: '2026',
        events: [
          { dateRange: '5 – 9 Jan', title: 'Pengumuman Hasil UAS', description: 'Penilaian akhir dan pengumuman indeks prestasi semester ganjil.', type: 'akademik' },
          { dateRange: '12 Jan', title: 'Akhir Perkuliahan Semester Ganjil', description: 'Penutupan aktivitas akademik semester ganjil.', type: 'akademik' },
        ]
      },
    ]
  },
  {
    id: 'genap',
    label: 'Semester Genap',
    period: 'Februari 2026 – Juli 2026',
    months: [
      {
        month: 'Februari',
        year: '2026',
        events: [
          { dateRange: '2 Feb', title: 'Awal Perkuliahan Semester Genap', description: 'Pertemuan pertama perkuliahan semester genap untuk seluruh program studi.', type: 'akademik', highlight: true },
          { dateRange: '9 – 13 Feb', title: 'Periode Penambahan & Penggantian MK', description: 'Jadwal untuk menyesuaikan pilihan mata kuliah semester genap.', type: 'akademik' },
        ]
      },
      {
        month: 'Maret',
        year: '2026',
        events: [
          { dateRange: '16 – 20 Mar', title: 'Pendaftaran Beasiswa Semester Genap', description: 'Pengajuan ulang berkas beasiswa untuk periode semester genap.', type: 'pendaftaran' },
          { dateRange: '23 – 27 Mar', title: 'Seminar Karier & Industri', description: 'Paparan peluang karier dan kolaborasi dengan mitra industri.', type: 'akademik' },
        ]
      },
      {
        month: 'April',
        year: '2026',
        events: [
          { dateRange: '6 – 10 Apr', title: 'Ujian Tengah Semester (UTS)', description: 'Evaluasi tengah semester genap untuk mengukur progress belajar.', type: 'ujian', highlight: true },
          { dateRange: '13 – 17 Apr', title: 'Libur Paskah', description: 'Cuti akademik dalam rangka perayaan Paskah.', type: 'libur' },
        ]
      },
      {
        month: 'Mei',
        year: '2026',
        events: [
          { dateRange: '1 Mei', title: 'Hari Buruh Internasional', description: 'Libur nasional, tidak ada aktivitas perkuliahan.', type: 'libur' },
          { dateRange: '11 – 15 Mei', title: 'Pengisian KRS Semester Ganjil 2026/2027', description: 'Perencanaan studi untuk semester ganjil tahun ajaran berikutnya.', type: 'akademik' },
        ]
      },
      {
        month: 'Juni',
        year: '2026',
        events: [
          { dateRange: '1 – 5 Jun', title: 'Batas Pembayaran UKT Semester Ganjil', description: 'Tenggat pembayaran UKT untuk semester ganjil tahun ajaran baru.', type: 'pendaftaran', highlight: true },
          { dateRange: '8 – 12 Jun', title: 'Ujian Akhir Semester (UAS)', description: 'Evaluasi akhir semester genap.', type: 'ujian', highlight: true },
        ]
      },
      {
        month: 'Juli',
        year: '2026',
        events: [
          { dateRange: '6 – 10 Jul', title: 'Pengumuman Hasil UAS', description: 'Penilaian akhir semester genap dan pengumuman IP.', type: 'akademik' },
          { dateRange: '13 Jul', title: 'Akhir Perkuliahan Semester Genap', description: 'Penutupan aktivitas akademik semester genap.', type: 'akademik' },
          { dateRange: '20 Jul – 14 Agt', title: 'Libur Antara Semester', description: 'Periode istirahat akademik sebelum semester ganjil dimulai.', type: 'libur' },
        ]
      },
    ]
  }
];

const typeConfig = {
  akademik: { label: 'Akademik', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>', color: '#14B8A6' },
  pendaftaran: { label: 'Pendaftaran', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>', color: '#F59E0B' },
  libur: { label: 'Libur', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>', color: '#F43F5E' },
  ujian: { label: 'Ujian', icon: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>', color: '#3B82F6' },
};
---

<section id="kalender-akademik" class="apu-section-shell motion-aurora-shell motion-aurora-shell--ecosystem relative isolate overflow-hidden bg-gradient-to-b from-brand-surface via-brand-surface-alt to-brand-surface py-24 md:py-32">
  <style>
    .calendar-tabs {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 3rem;
    }

    .calendar-tab {
      position: relative;
      padding: 0.75rem 1.75rem;
      border-radius: var(--apu-radius-pill);
      border: 1px solid rgb(var(--color-apu-navy) / 0.12);
      background: rgb(255 255 255 / 0.6);
      color: rgb(var(--color-brand-text-muted));
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 500;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 260ms ease;
      backdrop-filter: blur(8px);
    }

    .calendar-tab:hover {
      background: rgb(255 255 255 / 0.9);
      border-color: rgb(var(--color-apu-navy) / 0.25);
      color: rgb(var(--color-brand-text));
    }

    .calendar-tab[aria-selected="true"] {
      background: rgb(var(--color-apu-navy));
      color: rgb(var(--color-apu-accent));
      border-color: rgb(var(--color-apu-navy));
      box-shadow: 0 10px 28px rgb(var(--color-apu-navy) / 0.22);
    }

    .calendar-tab:focus-visible {
      outline: none;
      box-shadow: 0 0 0 2px rgb(var(--color-brand-surface)), 0 0 0 4px rgb(var(--color-apu-accent) / 0.82);
    }

    .semester-panel {
      display: none;
    }

    .semester-panel[data-active="true"] {
      display: block;
      animation: panelFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes panelFadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .month-block {
      position: relative;
      margin-bottom: 2.5rem;
    }

    .month-block:last-child {
      margin-bottom: 0;
    }

    .month-label {
      font-family: "Instrument Serif", Georgia, serif;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 500;
      color: rgb(var(--color-apu-navy));
      line-height: 1.1;
      margin-bottom: 0.25rem;
      letter-spacing: -0.02em;
    }

    .year-label {
      font-family: "Space Mono", monospace;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgb(var(--color-brand-text-muted));
      margin-bottom: 1rem;
    }

    .event-card {
      padding: 1.25rem;
      border-radius: var(--apu-radius-card);
      border: 1px solid rgb(var(--color-brand-border) / 0.2);
      background: rgb(255 255 255 / 0.78);
      backdrop-filter: blur(10px);
      transition: all 260ms ease;
      position: relative;
      overflow: hidden;
    }

    .event-card::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: var(--event-accent, rgb(var(--color-brand-primary)));
      border-radius: 3px 0 0 3px;
    }

    .event-card:hover {
      transform: translateX(4px);
      box-shadow: var(--apu-shadow-card-hover);
      border-color: rgb(var(--color-brand-border) / 0.4);
    }

    .event-card.highlight {
      background: rgb(255 255 255 / 0.92);
      border-color: rgb(var(--color-apu-accent) / 0.35);
      box-shadow: 0 8px 24px rgb(var(--color-apu-navy) / 0.08);
    }

    .event-card.highlight::before {
      width: 4px;
      background: linear-gradient(to bottom, rgb(var(--color-apu-accent)), rgb(var(--color-apu-navy)));
    }

    .event-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .event-date {
      font-family: "Space Mono", monospace;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: rgb(var(--color-apu-navy));
      white-space: nowrap;
      padding: 0.25rem 0.6rem;
      background: rgb(var(--color-apu-accent) / 0.12);
      border-radius: 6px;
    }

    .event-type-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-family: "Space Mono", monospace;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      border: 2px solid var(--badge-color);
      color: var(--badge-color);
      background: var(--badge-bg);
    }

    .event-title {
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 600;
      font-size: 1.05rem;
      line-height: 1.3;
      color: rgb(var(--color-brand-text));
      margin-bottom: 0.375rem;
    }

    .event-desc {
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 400;
      font-size: 0.85rem;
      line-height: 1.5;
      color: rgb(var(--color-brand-text-muted));
    }

    .event-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
  </style>

  <div class="content-max relative z-10">
    <ScrollReveal>
      <SectionHeader
        kicker="KALENDER AKADEMIK"
        title="Jadwal Kegiatan Kampus"
        description="Rencanakan semester-mu dengan memahami jadwal akademik, ujian, dan kegiatan kampus sepanjang tahun ajaran."
        class="text-center mb-12"
        titleClass="text-h2 text-[rgb(var(--color-apu-navy))] mb-4"
        descriptionClass="text-body-s text-brand-text-muted max-w-2xl mx-auto leading-relaxed"
      />
    </ScrollReveal>

    <!-- Semester Tabs -->
    <ScrollReveal delay={150}>
      <div class="calendar-tabs" role="tablist" aria-label="Pilih Semester">
        {semesters.map((sem, idx) => (
          <button
            class="calendar-tab"
            role="tab"
            aria-selected={idx === 0 ? 'true' : 'false'}
            aria-controls={`panel-${sem.id}`}
            id={`tab-${sem.id}`}
            tabindex={idx === 0 ? 0 : -1}
            data-tab={sem.id}
          >
            {sem.label}
            <span class="hidden sm:inline text-body-s opacity-60 ml-1">· {sem.period}</span>
          </button>
        ))}
      </div>
    </ScrollReveal>

    <!-- Semester Panels -->
    {semesters.map((sem, semIdx) => (
      <div
        id={`panel-${sem.id}`}
        role="tabpanel"
        aria-labelledby={`tab-${sem.id}`}
        class="semester-panel"
        data-active={semIdx === 0 ? 'true' : 'false'}
        data-panel={sem.id}
      >
        <div class="relative">
          <!-- Central Line -->
          <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-[rgb(var(--color-apu-navy))] via-[rgb(var(--color-apu-accent))] to-[rgb(var(--color-apu-navy))] md:-translate-x-px"></div>

          <div class="space-y-12">
            {sem.months.map((monthData, monthIdx) => {
              const isLeft = monthIdx % 2 === 0;
              return (
                <ScrollReveal delay={monthIdx * 100}>
                  <div class={`month-block relative flex items-start gap-8 ${isLeft ? 'md:flex-row text-right' : 'md:flex-row-reverse'}`}>
                    <!-- Content -->
                    <div class={`flex-1 ml-16 md:ml-0 ${isLeft ? 'md:pr-16' : 'md:pl-16 '}`}>
                      <div class="month-label">{monthData.month}</div>
                      <div class="year-label">{monthData.year}</div>
                      <div class="event-list">
                        {monthData.events.map((event) => (
                          <div
                            class={`event-card ${event.highlight ? 'highlight' : ''}`}
                            style={`--event-accent: ${typeConfig[event.type].color}; --badge-color: ${typeConfig[event.type].color}; --badge-bg: color-mix(in srgb, ${typeConfig[event.type].color} 8%, transparent)`}
                          >
                            <div class={`event-header ${isLeft ? 'flex-row' : 'flex-row-reverse'}`}>
                              <span class="event-date">{event.dateRange}</span>
                              <span class="event-type-badge">
                                <Fragment set:html={typeConfig[event.type].icon} />
                                {typeConfig[event.type].label}
                              </span>
                            </div>
                            <h4 class="event-title">{event.title}</h4>
                            <p class="event-desc">{event.description}</p>
                          </div>
                        ))}
                      </div>
                    </div>

                    <!-- Timeline Node -->
                    <div class="absolute left-8 md:left-1/2 -translate-x-1/2 flex items-center justify-center">
                      <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-[rgb(var(--color-apu-navy))] border-[3px] border-[rgb(var(--color-brand-surface))] shadow-[0_0_0_2px_rgb(var(--color-apu-accent)_/_0.5),0_4px_12px_rgb(var(--color-apu-navy)_/_0.2)] z-10 flex items-center justify-center">
                        <div class="w-2 h-2 rounded-full bg-[rgb(var(--color-apu-accent))]"></div>
                      </div>
                    </div>

                    <!-- Spacer for opposite side -->
                    <div class="hidden md:block flex-1"></div>
                  </div>
                </ScrollReveal>
              );
            })}
          </div>
        </div>
      </div>
    ))}

    <!-- Legend -->
    <ScrollReveal delay={300}>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        {Object.values(typeConfig).map((config) => (
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full" style={`background: ${config.color}; box-shadow: 0 0 0 2px ${config.color.replace(')', ' / 0.2)')}`}></div>
            <span class="text-caption text-brand-text-muted">{config.label}</span>
          </div>
        ))}
      </div>
    </ScrollReveal>
  </div>

  <script is:inline>
    (function() {
      var tabs = document.querySelectorAll('[data-tab]');
      var panels = document.querySelectorAll('[data-panel]');

      function switchTab(targetId) {
        tabs.forEach(function(tab) {
          var isTarget = tab.getAttribute('data-tab') === targetId;
          tab.setAttribute('aria-selected', isTarget ? 'true' : 'false');
          tab.setAttribute('tabindex', isTarget ? '0' : '-1');
        });

        panels.forEach(function(panel) {
          var isTarget = panel.getAttribute('data-panel') === targetId;
          panel.setAttribute('data-active', isTarget ? 'true' : 'false');
        });
      }

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var targetId = tab.getAttribute('data-tab');
          if (targetId) switchTab(targetId);
        });

        tab.addEventListener('keydown', function(e) {
          var currentIndex = Array.from(tabs).indexOf(tab);
          var nextIndex = currentIndex;

          if (e.key === 'ArrowRight') {
            nextIndex = (currentIndex + 1) % tabs.length;
          } else if (e.key === 'ArrowLeft') {
            nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
          } else {
            return;
          }

          e.preventDefault();
          var nextTab = tabs[nextIndex];
          if (nextTab && nextTab.focus) nextTab.focus();
          var targetId = nextTab.getAttribute('data-tab');
          if (targetId) switchTab(targetId);
        });
      });
    })();
  </script>
</section>
