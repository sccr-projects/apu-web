---
import { Image } from "astro:assets";
import ScrollReveal from "@components/ScrollReveal.astro";
import CtaButton from "@components/CtaButton.astro";
import LeafletMap from "@components/LeafletMap.astro";
import BackgroundBlobs from "@components/BackgroundBlobs.astro";
import apuPin from "@/assets/mapsection/apu-pin.webp";

const admissionsWhatsApp =
  "https://wa.me/628113755552?text=Hello, I would like to ask about new student admission information for APU 2026/2027.";

const APU_CENTER: [number, number] = [-7.071300, 110.362306];
---

<section
  id="ekosistem"
  class="apu-anchor-campus apu-section-shell relative isolate overflow-hidden bg-white"
  aria-label="Agung Putra University campus ecosystem"
>
  <BackgroundBlobs seed="AnchorCampusSectionAPU" />
  <div class="w-full relative z-[1]">
    <ScrollReveal>
      <div class="apu-anchor-campus__frame relative isolate w-full overflow-hidden bg-white shadow-[0_30px_72px_rgb(var(--color-brand-primary-deeper)/0.16)] lg:aspect-video">
        <section class="apu-anchor-campus__map-zone relative h-[260px] overflow-hidden sm:h-full lg:absolute lg:inset-0" aria-label="APU campus visual map">
          <div class="apu-anchor-campus__map-stage absolute left-1/2 top-1/2 aspect-square w-[150%] translate-x-[-61%] translate-y-[-46%] lg:w-[150%]">
            <LeafletMap
              center={APU_CENTER}
              zoomStart={11}
              zoomEnd={17}
              zoomDuration={20000}
              class="apu-anchor-campus__map-plate"
            />
          </div>

          <div class="apu-anchor-campus__map-vignette pointer-events-none absolute inset-0 z-[2]"></div>

          <div
            class="apu-anchor-campus__pin-wrap absolute left-1/2 top-1/2 z-[4] grid aspect-square w-28 -translate-x-1/2 -translate-y-1/2 place-items-center sm:w-36 md:w-44 lg:left-[33.4%] lg:top-[50%] lg:w-80 lg:-translate-x-1/2 lg:-translate-y-1/2"
            aria-label="APU campus location pin"
          >
            <Image
              src={apuPin}
              alt="APU campus location pin"
              class="apu-anchor-campus__pin-image relative z-[3] h-[92%] w-[92%] object-contain opacity-100 translate-y-[-12%]"
              loading="lazy"
              decoding="async"
            />
            <p class="text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl absolute left-1/2 top-[calc(80%+14px)] m-0 -translate-x-1/2 whitespace-nowrap rounded-full border border-apu-navy/24 bg-brand-surface/86 px-3 py-1.5 font-semibold text-apu-navy backdrop-blur-sm">
                APU Campus
            </p>
          </div>
        </section>

        <section class="apu-anchor-campus__text-zone relative z-[5] grid content-end gap-4 bg-brand-surface px-[clamp(1.4rem,4vw,3rem)] py-[clamp(1.4rem,4vw,2.4rem)] lg:absolute lg:inset-y-0 lg:left-auto lg:right-0 lg:w-[min(42%,620px)] lg:content-center lg:bg-gradient-to-l lg:from-brand-surface/94 lg:via-brand-surface/76 lg:to-transparent lg:px-[clamp(2rem,4.2vw,4rem)]">
          <span class="apu-section-kicker mb-1 w-fit">Ecosystem</span>
          <h2 class="text-h2 m-0 max-w-[18ch] text-apu-navy">
            Agung Putra University is the center of the SCCR ecosystem
          </h2>
          <p class="text-body m-0 max-w-[35ch] text-brand-text-muted">
              From Semarang, Agung Putra University connects with academic, industry, and community partners. <br>Its center remains one; a campus that prepares your future with a clear direction.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <CtaButton href={admissionsWhatsApp} target="_blank" rel="noopener noreferrer" withArrow>
              Apply Now
            </CtaButton>
            <CtaButton href="#jalur-masuk" variant="tertiary" class="ecosystem-trigger">
                View SCCR Ecosystem
            </CtaButton>
          </div>
        </section>
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  @keyframes apu-anchor-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes apu-anchor-pulse {
    0% {
      transform: scale(0.34);
      opacity: 0.9;
    }
    80% {
      opacity: 0.08;
    }
    100% {
      transform: scale(1.45);
      opacity: 0;
    }
  }

  @keyframes apu-pin-pop {
    0%,
    100% {
      transform: scale(0.95);
      filter: brightness(0.9) drop-shadow(0 0 0 rgb(255 86 86 / 0.12));
    }
    50% {
      transform: scale(1.05);
      filter: brightness(1.22) drop-shadow(0 0 18px rgb(255 86 86 / 0.42));
    }
  }

  @keyframes apu-red-wave {
    0% {
      transform: scale(0.46);
      opacity: 0.3;
    }
    75% {
      opacity: 0.08;
    }
    100% {
      transform: scale(1.55);
      opacity: 0;
    }
  }

  .apu-anchor-campus {
    --anchor-pin-x: 50%;
    --anchor-pin-y: 50%;
  }

  .apu-anchor-campus__frame {
    --apu-shell-glow-opacity: 0.92;
  }

  .apu-anchor-campus__map-stage {
    transform-origin: var(--anchor-pin-x) var(--anchor-pin-y);
    animation: apu-anchor-spin 160s linear infinite;
    will-change: transform;
  }

  .apu-anchor-campus__map-plate {
    pointer-events: none;
    transform: scale(1.06);
    filter: saturate(1.05) contrast(1.02);
  }

  .apu-anchor-campus__map-vignette {
    background:
      linear-gradient(
        90deg,
        rgb(var(--color-brand-surface) / 0.08) 0 46%,
        rgb(var(--color-brand-surface) / 0.62) 72%,
        rgb(var(--color-brand-surface) / 0.94) 100%
      ),
      radial-gradient(
        circle at 18% 22%,
        rgb(var(--color-apu-accent) / 0.22),
        transparent 38%
      );
  }

  .apu-anchor-campus__pin-image {
    animation: apu-pin-pop 2.6s ease-in-out infinite;
    transform-origin: 50% 80%;
    will-change: transform, filter;
  }

  .apu-anchor-campus__wave {
    pointer-events: none;
    position: absolute;
    inset: 18%;
    border-radius: 999px;
    border: 2px solid rgb(255 92 92 / 0.42);
    box-shadow: 0 0 20px rgb(255 92 92 / 0.2);
    animation: apu-red-wave 3.6s ease-out infinite;
  }

  .apu-anchor-campus__wave--2 {
    animation-delay: 1.4s;
  }

  @media (max-width: 1023px) {
    .apu-anchor-campus__map-zone {
      height: 320px;
    }
    .apu-anchor-campus__map-vignette {
      background:
        linear-gradient(
          180deg,
          rgb(var(--color-brand-surface) / 0.02) 0 55%,
          rgb(var(--color-brand-surface) / 0.45) 85%,
          rgb(var(--color-brand-surface) / 0.92) 100%
        ),
        radial-gradient(
          circle at 50% 30%,
          rgb(var(--color-apu-accent) / 0.18),
          transparent 45%
        );
    }
    .apu-anchor-campus__map-stage {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 150%;
      height: 150%;
      transform: translate(-50%, -50%) !important;
      translate: none !important;
      animation: none;
      aspect-ratio: auto;
    }
    .apu-anchor-campus__map-plate {
      transform: scale(1.02);
    }
    .apu-anchor-campus__text-zone .text-h2 {
      font-size: clamp(1.35rem, 5vw, 1.75rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .apu-anchor-campus__pin-image,
    .apu-anchor-campus__wave,
    .apu-anchor-campus__pulse,
    .apu-anchor-campus__pulse::before,
    .apu-anchor-campus__pulse::after {
      animation: none !important;
    }
  }
</style>
