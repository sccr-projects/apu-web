---
import { Image } from "astro:assets";
import ScrollReveal from "@components/ScrollReveal.astro";
import SectionHeader from "@components/SectionHeader.astro";
import LeafletMap from "@components/LeafletMap.astro";
import { campusLocations } from "@data/locations";
import apuPin from "@/assets/mapsection/apu-pin2.webp";
import sccrPin from "@/assets/mapsection/sccr-pin.webp";
import kareninaPin from "@/assets/mapsection/karenina-pin.webp";
import dermaninaPin from "@/assets/mapsection/dermanina-pin.webp";
import farmPin from "@/assets/mapsection/farm-pin.webp";
import restoPin from "@/assets/mapsection/resto-pin.webp";

import apuImg from "@/assets/mapsection/images/apu-background.webp";
import sccrImg from "@/assets/mapsection/images/sccr.jpg";
import kareninaImg from "@/assets/mapsection/images/karenina.jpg";
import dermaninaImg from "@/assets/mapsection/images/dermanina.jpeg";
import farmImg from "@/assets/mapsection/images/farm.jpg";
import restoImg from "@/assets/mapsection/images/resto.jpg";
import BackgroundBlobs from "@components/BackgroundBlobs.astro";

const pinMap: Record<string, string> = {
  "APU Main Campus": apuPin.src,
  "SCCR": sccrPin.src,
  "Karenina Resort": kareninaPin.src,
  "Dermanina": dermaninaPin.src,
  "Agung Farm": farmPin.src,
  "Sains De Resto": restoPin.src,
};

const imageMap: Record<string, { url: string; name: string }> = {
  "APU Main Campus": { url: apuImg.src, name: "APU Main Campus" },
  "SCCR": { url: sccrImg.src, name: "SCCR" },
  "Karenina Resort": { url: kareninaImg.src, name: "Karenina Resort" },
  "Dermanina": { url: dermaninaImg.src, name: "Dermanina" },
  "Agung Farm": { url: farmImg.src, name: "Agung Farm" },
  "Sains De Resto": { url: restoImg.src, name: "Sains De Resto" },
};

const mapMarkers = campusLocations.map((loc) => ({
  lat: loc.lat,
  lng: loc.lng,
  label: loc.name,
  icon: pinMap[loc.name],
}));

const routeCoordinates: [number, number][] = campusLocations.map((loc) => [
  loc.lat,
  loc.lng,
]);

const APU_CENTER: [number, number] = [-7.071300, 110.362306];
---

<section
  id="lokasi-kampus"
  class="apu-ecosystem-section apu-section-shell relative isolate overflow-hidden"
>
  <BackgroundBlobs seed="EcosystemSection" />

  <div class="relative z-[1] w-full">
    <ScrollReveal>
      <div class="apu-ecosystem-frame relative isolate w-full overflow-hidden bg-white shadow-[0_30px_72px_rgb(var(--color-brand-primary-deeper)/0.16)]">
        <!-- Map layer -->
        <div
          class="apu-ecosystem-map absolute inset-0 overflow-hidden"
          aria-label="Visual map of APU campus locations"
        >
          <LeafletMap
            center={APU_CENTER}
            markers={mapMarkers}
            route={routeCoordinates}
            animated={false}
            class="apu-ecosystem-leaflet absolute inset-0 h-full w-full lg:translate-x-40"
          />
        </div>

        <!-- Vignette overlay -->
        <div class="apu-ecosystem-vignette pointer-events-none absolute inset-0 z-[2]"></div>

        <!-- Content overlay panel -->
        <div class="apu-ecosystem-panel absolute bottom-0 z-[5] grid content-end gap-5 bg-gradient-to-t from-brand-surface/92 via-brand-surface/70 to-transparent px-[clamp(1.4rem,4vw,3rem)] py-[clamp(1.8rem,4vw,3.6rem)] lg:inset-y-0 lg:left-auto lg:w-[min(42%,620px)] lg:content-center lg:bg-gradient-to-l lg:from-brand-surface/94 lg:via-brand-surface/76 lg:to-transparent lg:px-[clamp(2rem,4.2vw,4rem)]">
          <div class="apu-ecosystem-copy">
            <SectionHeader
              kicker="CAMPUS LOCATIONS"
              title="SCCR Ecosystem"
              description="Agung Putra University is part of the SCCR ecosystem. The SCCR ecosystem consists of various business sectors that can collaborate and complement each other to advance civilization."
              class="text-left"
              titleClass="text-h2 text-[rgb(var(--color-apu-navy))] mb-4"
              descriptionClass="text-body-s text-brand-text-muted max-w-sm leading-relaxed"
              dividerClass="apu-gradient-line mt-4 w-48"
            />
          </div>

          <!-- Reactive location image -->
          <div class="ecosystem-image-wrapper relative isolate aspect-[16/10] w-full overflow-hidden rounded-[var(--apu-radius-card)] border border-[var(--apu-border)] bg-[var(--apu-surface-soft)]">
            <Image
              id="ecosystem-location-image"
              src={apuImg}
              alt="APU Main Campus — APU Ecosystem"
              class="absolute inset-0 h-full w-full object-cover transition-opacity duration-300 ease-in-out"
              loading="eager"
              decoding="async"
            />

            <span
              id="ecosystem-location-caption"
              class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-4 py-2 text-caption font-medium text-white"
            >
              APU Main Campus
            </span>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  .apu-ecosystem-frame {
    aspect-ratio: 16 / 9;
  }

  .apu-ecosystem-map {
    background: rgb(var(--color-brand-surface));
  }

  .apu-ecosystem-leaflet {
    width: 100%;
    height: 100%;
  }

  .apu-ecosystem-leaflet :global(.leaflet-container) {
    width: 100% !important;
    height: 100% !important;
  }

  .apu-ecosystem-vignette {
    background:
      linear-gradient(
        270deg,
        rgb(var(--color-brand-surface) / 0.08) 0 46%,
        rgb(var(--color-brand-surface) / 0.62) 72%,
        rgb(var(--color-brand-surface) / 0.94) 100%
      ),
      radial-gradient(
        circle at 18% 22%,
        rgb(var(--color-apu-accent) / 0.22),
        transparent 38%
      );
  }

  .apu-ecosystem-panel {
    left: 0;
    width: min(42%, 620px);
    padding-left: clamp(2rem, 4.2vw, 4rem);
  }

  .ecosystem-image-wrapper {
    box-shadow: 0 18px 44px rgb(var(--color-apu-navy) / 0.16);
  }

  @media (max-width: 1023px) {
    .apu-ecosystem-section {
      overflow: hidden;
    }

    .apu-ecosystem-frame {
      aspect-ratio: auto;
      min-height: 0;
      display: grid;
      grid-template-rows: auto auto;
      overflow: hidden;
      border-radius: 0;
      background: rgb(var(--color-brand-surface));
    }

    .apu-ecosystem-map {
      position: relative !important;
      inset: auto !important;
      height: clamp(420px, 78vh, 620px);
      min-height: 420px;
      overflow: hidden;
    }

    .apu-ecosystem-leaflet {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      transform: none !important;
      translate: none !important;
    }

    .apu-ecosystem-vignette {
      top: 0;
      bottom: auto;
      height: clamp(420px, 78vh, 620px);
      background:
        linear-gradient(
          180deg,
          rgb(var(--color-brand-surface) / 0.02) 0%,
          rgb(var(--color-brand-surface) / 0.08) 34%,
          rgb(var(--color-brand-surface) / 0.58) 82%,
          rgb(var(--color-brand-surface) / 0.96) 100%
        ),
        radial-gradient(
          circle at 50% 22%,
          rgb(var(--color-apu-accent) / 0.18),
          transparent 44%
        );
    }

    .apu-ecosystem-panel {
      position: relative !important;
      left: auto !important;
      right: auto !important;
      bottom: auto !important;
      width: 100% !important;
      z-index: 6;
      gap: 1rem;
      margin-top: -5.5rem;
      padding: 0 clamp(1rem, 5vw, 1.4rem) clamp(1.4rem, 5vw, 2rem);
      background: transparent !important;
    }

    .apu-ecosystem-copy {
      display: block;
      width: 100%;
      border: 1px solid rgb(var(--color-apu-navy) / 0.1);
      border-radius: 1.35rem;
      background: rgb(var(--color-brand-surface) / 0.9);
      padding: 1.1rem;
      box-shadow: 0 18px 42px rgb(var(--color-apu-navy) / 0.12);
      backdrop-filter: blur(14px);
    }

    .apu-ecosystem-copy :global(.apu-section-kicker) {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
    }

    .apu-ecosystem-copy :global(.text-h2) {
      font-size: clamp(1.75rem, 9vw, 2.45rem);
      line-height: 0.98;
      margin-bottom: 0.8rem;
    }

    .apu-ecosystem-copy :global(.text-body-s) {
      max-width: none;
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .apu-ecosystem-copy :global(.apu-gradient-line) {
      width: 7.5rem;
      margin-top: 0.9rem;
    }

    .ecosystem-image-wrapper {
      width: min(100%, 360px);
      aspect-ratio: 16 / 10;
      margin-inline: auto;
      border-radius: 1.15rem;
      box-shadow: 0 18px 42px rgb(var(--color-apu-navy) / 0.16);
    }

    #ecosystem-location-caption {
      padding: 0.7rem 0.9rem;
      font-size: 0.95rem;
      line-height: 1.15;
    }

    .apu-ecosystem-section :global(.leaflet-marker-icon) {
      --eco-pin-w: clamp(72px, 20vw, 108px);
      --eco-pin-h: clamp(92px, 26vw, 142px);

      width: var(--eco-pin-w) !important;
      height: var(--eco-pin-h) !important;
      object-fit: contain !important;

      margin-left: calc(var(--eco-pin-w) / -2) !important;
      margin-top: calc(var(--eco-pin-h) * -0.88) !important;
    }

    .apu-ecosystem-section :global(.leaflet-marker-shadow) {
      display: none !important;
    }

    .apu-ecosystem-section :global(.leaflet-control-container) {
      display: none !important;
    }

    .apu-ecosystem-section :global(.leaflet-pane),
    .apu-ecosystem-section :global(.leaflet-map-pane),
    .apu-ecosystem-section :global(.leaflet-tile-pane),
    .apu-ecosystem-section :global(.leaflet-overlay-pane),
    .apu-ecosystem-section :global(.leaflet-marker-pane) {
      max-width: 100vw;
    }
  }

  @media (max-width: 640px) {
    .apu-ecosystem-map {
      height: 560px;
      min-height: 560px;
    }

    .apu-ecosystem-vignette {
      height: 560px;
    }

    .apu-ecosystem-panel {
      margin-top: -7.2rem;
    }

    .apu-ecosystem-copy {
      padding: 1rem;
    }

    .apu-ecosystem-copy :global(.text-h2) {
      font-size: clamp(1.65rem, 10vw, 2.15rem);
    }

    .apu-ecosystem-copy :global(.text-body-s) {
      font-size: 0.9rem;
    }

    .ecosystem-image-wrapper {
      width: min(100%, 330px);
    }

    .apu-ecosystem-section :global(.leaflet-marker-icon) {
      --eco-pin-w: clamp(68px, 21vw, 92px);
      --eco-pin-h: clamp(88px, 28vw, 122px);

      width: var(--eco-pin-w) !important;
      height: var(--eco-pin-h) !important;
      margin-left: calc(var(--eco-pin-w) / -2) !important;
      margin-top: calc(var(--eco-pin-h) * -0.88) !important;
    }
  }

  @media (max-width: 420px) {
    .apu-ecosystem-map {
      height: 530px;
      min-height: 530px;
    }

    .apu-ecosystem-vignette {
      height: 530px;
    }

    .apu-ecosystem-panel {
      margin-top: -6.5rem;
      padding-inline: 1rem;
    }

    .ecosystem-image-wrapper {
      width: min(100%, 300px);
    }

    .apu-ecosystem-section :global(.leaflet-marker-icon) {
      --eco-pin-w: 72px;
      --eco-pin-h: 96px;

      width: var(--eco-pin-w) !important;
      height: var(--eco-pin-h) !important;
      margin-left: calc(var(--eco-pin-w) / -2) !important;
      margin-top: calc(var(--eco-pin-h) * -0.88) !important;
    }
  }

  @media (max-width: 360px) {
    .apu-ecosystem-map {
      height: 500px;
      min-height: 500px;
    }

    .apu-ecosystem-vignette {
      height: 500px;
    }

    .apu-ecosystem-panel {
      margin-top: -5.8rem;
    }

    .apu-ecosystem-section :global(.leaflet-marker-icon) {
      --eco-pin-w: 64px;
      --eco-pin-h: 86px;

      width: var(--eco-pin-w) !important;
      height: var(--eco-pin-h) !important;
      margin-left: calc(var(--eco-pin-w) / -2) !important;
      margin-top: calc(var(--eco-pin-h) * -0.88) !important;
    }
  }
</style>

<script define:vars={{ imageMap }}>
  (function () {
    var IMAGE_MAP = imageMap;
    var DEFAULT_KEY = "APU Main Campus";
    var TRANSITION_DURATION = 300;

    function refreshLeafletLayout() {
      setTimeout(function () {
        window.dispatchEvent(new Event("resize"));
      }, 120);

      setTimeout(function () {
        window.dispatchEvent(new Event("resize"));
      }, 420);
    }

    function initReactiveImage() {
      var mapContainer = document.querySelector("[data-map-instance]");
      var img = document.getElementById("ecosystem-location-image");
      var caption = document.getElementById("ecosystem-location-caption");

      if (!mapContainer || !img) {
        return;
      }

      function setImage(label) {
        var entry = IMAGE_MAP[label] || IMAGE_MAP[DEFAULT_KEY];
        if (!entry) return;

        img.style.opacity = "0";

        setTimeout(function () {
          img.src = entry.url;
          img.alt = entry.name + " — APU Ecosystem";

          if (caption) {
            caption.textContent = entry.name;
          }

          img.style.opacity = "1";
        }, TRANSITION_DURATION);
      }

      document.addEventListener("markerclick", function (event) {
        var label = event.detail && event.detail.label;
        if (!label) return;
        setImage(label);
      });

      setImage(DEFAULT_KEY);
      refreshLeafletLayout();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initReactiveImage);
    } else {
      initReactiveImage();
    }

    window.addEventListener("load", refreshLeafletLayout);
    window.addEventListener("orientationchange", refreshLeafletLayout);
  })();
</script>