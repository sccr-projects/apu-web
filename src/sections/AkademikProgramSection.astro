---
import ScrollReveal from '../components/ScrollReveal.astro';
import SectionHeader from '../components/SectionHeader.astro';

const pillars = [
  {
    icon: 'book-open',
    title: 'Kurikulum Berbasis Capaian',
    subtitle: 'Teori yang Terukur',
    description:
      'Setiap mata kuliah dirancang dengan capaian pembelajaran jelas yang selaras dengan kebutuhan industri. Mahasiswa tidak hanya memahami konsep, tetapi juga mampu mengaplikasikannya dalam konteks profesional.',
    points: [
      'Learning outcome terdefinisi per semester',
      'Alignment dengan standar kompetensi nasional',
      'Pathway sertifikasi profesional',
    ],
  },
  {
    icon: 'microscope',
    title: 'Praktikum Terstruktur',
    subtitle: 'Praktik dengan Pendampingan',
    description:
      'Sesi praktikum dilaksanakan secara terjadwal dengan rasio dosen pendamping yang optimal. Evaluasi berkala memastikan mahasiswa menguasai keterampilan teknis sebelum melangkah ke proyek mandiri.',
    points: [
      'Laboratorium dengan peralatan standar industri',
      'Dosen pendamping aktif selama sesi praktik',
      'Evaluasi formatif tiap pertemuan',
    ],
  },
  {
    icon: 'puzzle',
    title: 'Proyek Lintas Disiplin',
    subtitle: 'Kolaborasi & Problem Solving',
    description:
      'Mahasiswa dari berbagai program studi berkumpul dalam tim untuk menyelesaikan masalah nyata. Pengalaman ini melatih komunikasi antar-disiplin, manajemen proyek, dan pemikiran sistem.',
    points: [
      'Tim multidisiplin dari 2–3 program studi',
      'Case study dari mitra industri dan komunitas',
      'Portofolio proyek yang dapat ditampilkan',
    ],
  },
];

const iconSvgs: Record<string, string> = {
  'book-open': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  'microscope': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/></svg>',
  'puzzle': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 2H8.6c-.4 0-.8.2-1.1.5-.3.3-.5.7-.5 1.1v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8c.4 0 .8-.2 1.1-.5.3-.3.5-.7.5-1.1V6.5L15.5 2z"/><path d="M3 7.6v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8"/><path d="M15 2v5h5"/></svg>',
};
---

<section
  id="program"
  class="apu-section-shell motion-aurora-shell motion-aurora-shell--program relative isolate overflow-hidden py-24 md:py-32 bg-gradient-to-b from-brand-surface via-brand-surface-alt to-brand-surface-soft after:content-[''] after:pointer-events-none after:absolute after:inset-x-0 after:top-0 after:h-px after:bg-gradient-to-r after:from-transparent after:via-[rgb(var(--color-apu-accent)_/_0.65)] after:to-transparent"
>
  <!-- Ambient orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -left-20 top-20 h-80 w-80 rounded-full bg-[rgb(var(--color-apu-accent)_/_0.15)] blur-3xl"></div>
    <div class="absolute -right-16 bottom-16 h-96 w-96 rounded-full bg-[rgb(var(--color-apu-navy)_/_0.10)] blur-3xl"></div>
    <div class="absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[rgb(var(--color-brand-primary)_/_0.08)] blur-3xl"></div>
  </div>

  <div class=" relative z-10">
    <!-- Section Header -->
    <ScrollReveal>
      <SectionHeader
        kicker="Program"
        title="Fokus Pembelajaran"
        description="Setiap program menyeimbangkan teori, praktik, dan proyek nyata. Kurikulum dirancang adaptif agar lulusan siap menghadapi tantangan dunia kerja."
        class="text-center mb-16 md:mb-20"
        titleClass="text-h2 text-[rgb(var(--color-apu-navy))] mb-4"
      />
    </ScrollReveal>

    <!-- Three Pillars Grid -->
    <div class="flex flex-col md:flex-row gap-6 px-20">
      {pillars.map((pillar, index) => (
        <ScrollReveal delay={index * 150}>
          <div class="group relative h-full apu-glass-card apu-interactive-card p-8 hover:border-[rgb(var(--color-apu-accent)_/_0.65)] hover:shadow-[0_28px_70px_rgb(var(--color-apu-navy)_/_0.14)]">
            {/* Accent glow orb on hover */}
            <div class="pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full bg-[rgb(var(--color-apu-accent)_/_0.12)] blur-2xl transition-opacity duration-300 opacity-0 group-hover:opacity-100"></div>

            {/* Top accent line */}
            <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-[rgb(var(--color-apu-accent)_/_0.65)] to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 rounded-t-[var(--apu-radius-card)]"></div>

            {/* Icon + Title */}
            <div class="mb-6">
              <div class="apu-icon-chip flex h-16 w-16 rounded-2xl ring-4 ring-[rgb(var(--color-apu-accent)_/_0.08)] mb-5" set:html={iconSvgs[pillar.icon]} />
              <p class="text-caption text-brand-text-muted uppercase tracking-wider font-medium mb-2">{pillar.subtitle}</p>
              <h3 class="text-h3 text-[rgb(var(--color-apu-navy))] leading-tight">{pillar.title}</h3>
            </div>

            {/* Description */}
            <p class="text-body-s text-brand-text-muted mb-6 leading-relaxed">
              {pillar.description}
            </p>

            {/* Key Points */}
            <ul class="space-y-3" aria-label={`Poin utama ${pillar.title}`}>
              {pillar.points.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 h-2 w-2 rounded-full bg-[rgb(var(--color-apu-accent))] shadow-[0_0_0_4px_rgb(var(--color-apu-accent)_/_0.15)] flex-shrink-0"></span>
                  <span class="text-body-s text-brand-text leading-snug">{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </ScrollReveal>
      ))}
    </div>

    <!-- Bottom CTA -->
    <ScrollReveal delay={500} class="text-center mt-14 md:mt-18">
      <a
        href="/pendaftaran"
        class="apu-btn apu-btn--primary inline-flex items-center gap-3 px-8 py-4 text-body-s font-medium"
      >
        <span>Lihat Program Studi Lengkap</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-x-1"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
      <p class="text-caption text-brand-text-muted mt-4">
        Atau jelajahi katalog mata kuliah per semester di bawah.
      </p>
    </ScrollReveal>
  </div>
</section>
