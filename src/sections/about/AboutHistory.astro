---
import { Image } from "astro:assets";
import ScrollReveal from "@components/ScrollReveal.astro";

interface Milestone {
  step: string;
  label: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  bgGradient: string;
}

const milestones: Milestone[] = [
  {
    step: "01",
    label: "Birth of Vision",
    title: "Founding",
    description:
      "Agung Putra University was born from the aspiration to build beacons of the nation's next generation who are not only academically excellent, but also capable of answering future challenges",
    image: "https://picsum.photos/seed/apu-history-building/800/600",
    imageAlt: "APU History",
    bgGradient: "from-brand-primary-deeper/95 via-brand-primary-deep/85 to-brand-primary/75",
  },
  {
    step: "02",
    label: "Heritage & Innovation",
    title: "Heritage",
    description:
      "APU combines IKMB's strong heritage with a futuristic vision oriented toward innovation, character, and global competitiveness.",
    bgGradient: "from-brand-primary-deep/95 via-brand-primary/85 to-brand-border/75",
  },
  {
    step: "03",
    label: "Our Commitment",
    title: "Commitment",
    description:
      "Every step we take is grounded in a commitment to create an inclusive, adaptive learning ecosystem relevant to the development of science and industry needs.",
    bgGradient: "from-brand-primary/95 via-brand-border/85 to-brand-surface-soft/75",
  },
  {
    step: "04",
    label: "Future Vision",
    title: "Future",
    description:
      "Moving toward the future, APU continues to innovate to become an outstanding campus that produces young leaders of integrity and global competitiveness.",
    bgGradient: "from-brand-accent/95 via-brand-accent-soft/85 to-brand-surface-alt/75",
  },
];
---

<section
  id="latar-belakang"
  class="apu-section-shell relative overflow-hidden bg-brand-surface"
>
  <!-- Section Header -->
  <div class=" absolute top-0 inset-x-0 z-1 mt-10 ">
    <ScrollReveal>
      <header class="text-center">
        <span class="apu-section-kicker mb-5 inline-block">Our Journey</span>
        <h2 class="text-h2 text-white mb-4">Background</h2>
        <span class="apu-gradient-line mx-auto mt-4 w-48 block"></span>
      </header>
    </ScrollReveal>
  </div>

  <!-- Full-Screen Timeline Track -->
  <ScrollReveal delay={200}>
    <div class="relative">
      <div
        class="timeline-track flex overflow-x-auto snap-x snap-mandatory"
        id="history-timeline"
      >
        {milestones.map((milestone, index) => (
          <article
            class="timeline-card flex-shrink-0 w-screen snap-start"
            data-index={index}
          >
            <div class="relative overflow-hidden w-full h-[85vh] md:h-[80vh] flex flex-col">
              {/* Background Layer */}
              <div class="absolute inset-0 z-0">
                {milestone.image ? (
                  <>
                    <Image
                      src={milestone.image}
                      alt={milestone.imageAlt ?? milestone.title}
                      class="w-full h-full object-cover"
                      loading={index === 0 ? "eager" : "lazy"}
                      draggable="false"
                      width={800}
                      height={600}
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-black/30" />
                  </>
                ) : (
                  <div
                    class={`absolute inset-0 bg-gradient-to-br ${milestone.bgGradient}`}
                  />
                )}
                {/* Subtle ambient overlay */}
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent" />
              </div>

              {/* Content */}
              <div class="relative z-10 flex flex-col justify-end h-full p-8 md:p-16 lg:p-20 mx-auto w-full">
                {/* Step Badge */}
                <div class="mb-auto pt-8 md:pt-12">
                  <span
                    class={`inline-block text-mono absolute top-20 left-20 text-sm md:text-base px-4 py-2 rounded-full border ${
                      milestone.image
                        ? "bg-white/15 border-white/25 text-white"
                        : "bg-white/20 border-white/30 text-white"
                    }`}
                  >
                    {milestone.step} / 04
                  </span>
                </div>

                {/* Text Content */}
                <div class="mt-auto pb-8 md:pb-12">
                  <span
                    class={`text-caption md:text-body-s block mb-3 ${
                      milestone.image ? "text-white/70" : "text-white/80"
                    }`}
                  >
                    {milestone.label}
                  </span>
                  <h3
                    class={`text-h2 md:text-h1 mb-4 md:mb-6 ${
                      milestone.image ? "text-white" : "text-white"
                    }`}
                  >
                    {milestone.title}
                  </h3>
                  <p
                    class={`text-body-s md:text-body max-w-2xl leading-relaxed ${
                      milestone.image ? "text-white/90" : "text-white/90"
                    }`}
                  >
                    {milestone.description}
                  </p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Timeline Progress Indicator -->
      <div class="timeline-controls absolute bottom-6 md:bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-20">
        <div class="flex justify-center items-center gap-3">
          {milestones.map((_, index) => (
            <button
              class="timeline-dot w-3 h-3 rounded-full transition-all duration-300 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2"
              data-index={index}
              aria-label={`View milestone ${index + 1}`}
            />
          ))}
        </div>

        <!-- Swipe Hint -->
        <div class="flex items-center justify-center gap-2 text-caption text-white/60 animate-pulse">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
          <span class="hidden md:inline">Swipe or drag to continue</span>
          <span class="md:hidden">Swipe to continue</span>
        </div>
      </div>
    </div>
  </ScrollReveal>
</section>

<style>
  .timeline-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .timeline-track::-webkit-scrollbar {
    display: none;
  }

  /* Active dot styling */
  .timeline-dot {
    background-color: rgba(255, 255, 255, 0.35);
  }

  .timeline-dot.active {
    background-color: rgb(var(--color-brand-accent));
    transform: scale(1.4);
  }

  /* Focus visible for accessibility */
  .timeline-dot:focus-visible {
    outline: none;
  }

  /* Mouse drag cursor */
  .timeline-track {
    cursor: grab;
  }

  .timeline-track.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .timeline-track.is-dragging img {
    pointer-events: none;
  }
</style>

<script>
  (function () {
    let abortController: AbortController | null = null;
    let observer: IntersectionObserver | null = null;

    function cleanup() {
      if (observer) {
        observer.disconnect();
        observer = null;
      }
      if (abortController) {
        abortController.abort();
        abortController = null;
      }
    }

    function initTimeline() {
      cleanup();
      abortController = new AbortController();
      const signal = abortController.signal;

      const track = document.getElementById("history-timeline");
      const dots = document.querySelectorAll(".timeline-dot");
      const cards = document.querySelectorAll(".timeline-card");

      if (!track || cards.length === 0) return;

      if (dots[0]) dots[0].classList.add("active");

      observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt(
              (entry.target as HTMLElement).dataset.index || "0",
              10
            );

            dots.forEach((dot, i) => {
              if (i === index) {
                dot.classList.add("active");
              } else {
                dot.classList.remove("active");
              }
            });
          }
        });
      }, { root: track, threshold: 0.5 });

      cards.forEach((card) => observer?.observe(card));

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = parseInt(
            (dot as HTMLElement).dataset.index || "0",
            10
          );
          const targetCard = cards[index];
          if (targetCard) {
            targetCard.scrollIntoView({ behavior: "smooth", inline: "start" });
          }
        }, { signal });
      });

      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;

      track.addEventListener("mousedown", (e) => {
        isDown = true;
        track.classList.add("is-dragging");
        startX = e.pageX - track.offsetLeft;
        scrollLeft = track.scrollLeft;
      }, { signal });

      track.addEventListener("mouseleave", () => {
        isDown = false;
        track.classList.remove("is-dragging");
      }, { signal });

      track.addEventListener("mouseup", () => {
        isDown = false;
        track.classList.remove("is-dragging");
      }, { signal });

      track.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - track.offsetLeft;
        const walk = (x - startX) * 1.5;
        track.scrollLeft = scrollLeft - walk;
      }, { signal });
    }

    document.addEventListener('astro:page-load', initTimeline);
    document.addEventListener('astro:before-swap', cleanup);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimeline);
    } else {
      initTimeline();
    }
  })();
</script>
