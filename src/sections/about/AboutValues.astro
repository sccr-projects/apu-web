---
import ScrollReveal from "../../components/ScrollReveal.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<section
  id="nilai-institusi"
  class="apu-section-shell relative overflow-hidden bg-brand-surface-alt"
>
  <div class="content-max py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <SectionHeader
        kicker="NILAI INSTITUSI"
        title="Nilai-Nilai Kami"
        class="text-left mb-12 md:mb-16"
        titleClass="text-h2 text-brand-primary-deeper mb-4"
        dividerClass="apu-gradient-line mt-4 w-40"
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <ScrollReveal delay={100}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"
              ></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"
              ></path><path d="M4 22h16"></path><path
                d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
              ></path><path
                d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
              ></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            Excellence
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Kami mengejar keunggulan dalam setiap aspek akademik, penelitian, dan
            pelayanan, dengan standar yang terus ditingkatkan secara
            berkelanjutan.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22v-5"></path><path d="M9 8V2"
              ></path><path d="M15 8V2"></path><path
                d="M18 8v12a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V8"
              ></path><path d="M18 8H6a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4Z"
              ></path><path d="M9 17h6"></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            Innovation
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Inovasi menjadi DNA kami. Kami mendorong pemikiran kritis,
            kreativitas, dan penerapan teknologi untuk solusi masa depan.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
              ></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            Integrity
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Integritas adalah fondasi setiap keputusan dan tindakan. Kami
            menjunjung tinggi kejujuran, transparansi, dan akuntabilitas.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={400}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M23 21v-2a4 4 0 0 0-3-3.87"
              ></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            Collaboration
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Kolaborasi lintas disiplin dan institusi memperkuat dampak kami.
            Bersama, kami mencapai lebih banyak.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={500} class="md:col-span-2">
        <div
          class="apu-glass-card apu-interactive-card p-6 md:p-8 md:max-w-2xl md:mx-auto h-full text-center"
        >
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center mx-auto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"
              ></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            Human-Centered Impact
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Setiap upaya kami bermuara pada manusia. Kami menciptakan dampak
            positif yang nyata bagi kehidupan individu dan komunitas.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
