---
import ScrollReveal from "../../components/ScrollReveal.astro";
import SectionHeader from "../../components/SectionHeader.astro";
---

<section
  id="visi-misi"
  class="apu-section-shell relative overflow-hidden bg-brand-surface-alt"
>
  <div class="content-max py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <SectionHeader
        kicker="VISI & MISI"
        title="Visi dan Misi"
        class="text-left mb-12 md:mb-16"
        titleClass="text-h2 text-brand-primary-deeper mb-4"
        dividerClass="apu-gradient-line mt-4 w-40"
      />
    </ScrollReveal>

    <ScrollReveal class="mb-16 md:mb-20">
      <div class="max-w-4xl">
        <p class="text-mono text-brand-text-muted mb-4">VISI 2043</p>
        <blockquote
          class="text-h2 md:text-h1 text-brand-primary-deep font-normal leading-tight mb-4"
        >
          "Menjadi Institusi yang unggul, inovatif, berkarakter, berdaya saing di
          tingkat global di tahun 2043"
        </blockquote>
        <p class="text-body-s text-brand-text-muted italic">
          "To become an excellent, innovative, character-driven, and globally
          competitive institution by 2043"
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <ScrollReveal delay={100}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M22 10v6M2 10l10-5 10 5-10 5z"
              ></path><path d="M6 12v5c0 1.66 2.24 3 5 3s5-1.34 5-3v-5"
              ></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              1. Pendidikan Berkualitas
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Menyelenggarakan pendidikan tinggi yang berkualitas dan relevan
              dengan perkembangan zaman.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"
              ></path><path d="M12 8h.01"></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              2. Penelitian & Inovasi
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Mengembangkan penelitian dan inovasi untuk menjawab tantangan
              lokal dan global.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M23 21v-2a4 4 0 0 0-3-3.87"
              ></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              3. Pengabdian Masyarakat
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Melaksanakan pengabdian kepada masyarakat berbasis riset dan
              kearifan lokal.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={400}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              4. Kerja Sama Global
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Membangun kerja sama strategis dengan institusi dan industri di
              dalam maupun luar negeri.
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
