---
import { assetUrl } from '@lib/assets';
import ScrollReveal from "@components/ScrollReveal.astro";
import SectionHeader from "@components/SectionHeader.astro";
---

<section
  id="visi-misi"
  class="apu-section-shell relative overflow-hidden bg-brand-surface-alt"
>
  <div id="vm-logo-3d-wrapper" class="translate-scale-0.9 absolute inset-y-0 z-0 flex items-center justify-center pointer-events-none left-1/2 -translate-x-1/2 md:left-auto md:translate-x-0 md:right-5" style="perspective: 500px;">
    <div id="vm-logo-3d" class="pointer-events-none vm-logo-3d-inner w-[90vw] md:w-[50vw]">
      <img src={assetUrl('/images/apu-4k.webp')} alt="APU Logo" class="w-full h-full object-contain" loading="lazy" decoding="async" />
    </div>
  </div>

  <div class="max-w-5xl pl-4 md:pl-40 relative z-10 py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <SectionHeader
        kicker="VISION & MISSION"
        title="Vision and Mission"
        class="text-left mb-12 md:mb-16"
        titleClass="text-h2 text-brand-primary-deeper mb-4"
        dividerClass="apu-gradient-line mt-4 w-40"
      />
    </ScrollReveal>

    <ScrollReveal class="mb-8 md:mb-16">
      <div class="">
        <p class="text-mono text-brand-text-muted mb-4">VISION 2043</p>
        <blockquote
          class="text-h2 md:text-h1 text-brand-primary-deep font-normal leading-tight mb-4"
        >
          "To become an excellent, innovative, character-driven, and globally
          competitive institution by <span class="font-bold">2043</span>"
        </blockquote>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <ScrollReveal delay={100}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M22 10v6M2 10l10-5 10 5-10 5z"
              ></path><path d="M6 12v5c0 1.66 2.24 3 5 3s5-1.34 5-3v-5"
              ></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              1. Quality Education
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Delivering quality higher education relevant to the development
              of the times.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"
              ></path><path d="M12 8h.01"></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              2. Research & Innovation
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Developing research and innovation to answer local and global
              challenges.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M23 21v-2a4 4 0 0 0-3-3.87"
              ></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              3. Community Service
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Implementing community service based on research and local wisdom.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={400}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start">
          <div class="apu-icon-chip h-12 w-12 rounded-xl flex-shrink-0">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
          </div>
          <div>
            <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
              4. Global Cooperation
            </h3>
            <p class="text-body-s text-brand-text-muted leading-relaxed">
              Building strategic cooperation with institutions and industries
              domestically and abroad.
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>

  <style>
    .vm-logo-3d-inner {
      aspect-ratio: 1;
      transition: transform 0.1s ease-out;
      transform-style: preserve-3d;
      will-change: transform;
      cursor: pointer;
    }
    .vm-logo-3d-inner.is-flipped {
      transform: rotateY(180deg);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
  </style>

  <script is:inline>
    (function() {
      const section = document.getElementById('visi-misi');
      const logo = document.getElementById('vm-logo-3d');
      if (!section || !logo) return;

      const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

      let isVisible = false;
      let mouseX = 0, mouseY = 0;
      let currentRotateX = 0, currentRotateY = 0;
      let isFlipped = false;
      let lastFlipTime = 0;
      let rafId = null;

      // IntersectionObserver to gate rAF
      const observer = new IntersectionObserver(
        ([entry]) => {
          isVisible = entry.isIntersecting;
          if (isVisible && !rafId) animate();
        },
        { threshold: 0.1 }
      );
      observer.observe(section);

      // Mouse tracking (viewport-relative, skip on touch)
      function onMouseMove(e) {
        if (isTouchDevice) return;
        mouseX = (e.clientX / window.innerWidth - 0.5) * 30; // max +/-15deg
        mouseY = (e.clientY / window.innerHeight - 0.5) * -30; // invert Y for natural tilt
      }
      document.addEventListener('mousemove', onMouseMove);

      // rAF loop with lerp
      function animate() {
        if (isVisible && !isTouchDevice) {
          currentRotateX += (mouseY - currentRotateX) * 0.08;
          currentRotateY += (mouseX - currentRotateY) * 0.08;
          if (!isFlipped) {
            logo.style.transform = `rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;
          }
        }
        if (isVisible) {
          rafId = requestAnimationFrame(animate);
        } else {
          rafId = null;
        }
      }

      // Click flip with 5s debounce
      function onClick() {
        const now = Date.now();
        if (isFlipped || now - lastFlipTime < 5000) return;
        isFlipped = true;
        lastFlipTime = now;
        logo.style.transform = '';
        logo.classList.add('is-flipped');
      }
      logo.addEventListener('click', onClick);

      // Cleanup
      function cleanup() {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
        document.removeEventListener('mousemove', onMouseMove);
        logo.removeEventListener('click', onClick);
        observer.disconnect();
        window.removeEventListener('beforeunload', cleanup);
        section.removeEventListener('astro:unmount', cleanup);
      }
      window.addEventListener('beforeunload', cleanup);
      section.addEventListener('astro:unmount', cleanup);
    })();
  </script>
</section>
