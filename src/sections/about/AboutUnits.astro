---
import ScrollReveal from "../../components/ScrollReveal.astro";
---

<section
  id="unit-penunjang"
  class="apu-section-shell relative overflow-hidden bg-brand-surface"
>
  <div class="content-max py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <h2 class="text-h2 text-brand-primary-deeper mb-10 md:mb-12">
        Unit Penunjang
      </h2>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-6 md:mb-8">
      <ScrollReveal delay={100}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
              ></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
              ></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            LPPM
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Lembaga Penelitian dan Pengabdian kepada Masyarakat yang mengelola
            riset berkualitas serta program pengabdian berbasis kebutuhan
            komunitas.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
              ></path><polyline points="14 2 14 8 20 8"
              ></polyline><path d="M12 18v-6"></path><path
                d="m9 15 3 3 3-3"></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            LPMI
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Lembaga Penjaminan Mutu Internal yang memastikan standar pendidikan,
            penelitian, dan layanan terus meningkat secara sistematis.
          </p>
        </div>
      </ScrollReveal>
    </div>

    <div class="md:max-w-xl md:mx-auto">
      <ScrollReveal delay={300}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8 h-full text-center">
          <div
            class="apu-icon-chip h-12 w-12 rounded-xl mb-5 flex items-center justify-center mx-auto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><line x1="2" x2="22" y1="12" y2="12"
              ></line><path
                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
              ></path></svg
            >
          </div>
          <h3 class="text-h3 text-brand-primary-deep text-lg md:text-xl mb-2">
            International Office
          </h3>
          <p class="text-body-s text-brand-text-muted leading-relaxed">
            Mengelola kerja sama internasional, program pertukaran pelajar, dan
            jaringan global untuk memperluas wawasan civitas akademika.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
