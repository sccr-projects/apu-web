---
import ScrollReveal from "../../components/ScrollReveal.astro";
---

<section
  id="profil-institusi"
  class="apu-section-shell relative overflow-hidden bg-brand-surface-alt"
>
  <div class="content-max py-[var(--apu-section-spacing-y)]">
    <ScrollReveal>
      <h2 class="text-h2 text-brand-primary-deeper mb-10">Profil Institusi</h2>
    </ScrollReveal>

    <ScrollReveal delay={100}>
      <div class="apu-glass-card apu-interactive-card p-8 md:p-10 mb-8">
        <h3 class="text-h3 text-brand-primary-deep mb-3">
          Agung Putra University (APU)
        </h3>
        <p class="text-body-s text-brand-text-muted leading-relaxed">
          Dalam proses transisi dari Institut Karya Mulia Bangsa (IKMB) menuju
          cita-cita menjadi universitas yang unggul dan berdaya saing global.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <ScrollReveal delay={150}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8">
          <span class="text-mono text-brand-text-muted block mb-2"
            >DASAR HUKUM</span
          >
          <p class="text-body-s text-brand-text font-medium">
            SK Kemendikbudristek No. 813/E/O/2023
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8">
          <span class="text-mono text-brand-text-muted block mb-2">YAYASAN</span>
          <p class="text-body-s text-brand-text font-medium">
            Yayasan Karya Mulia Keluarga (est. 1990)
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={250}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8">
          <span class="text-mono text-brand-text-muted block mb-2">LOKASI</span>
          <p class="text-body-s text-brand-text font-medium">
            Jl. Nongkosawit Raya, Semarang
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="apu-glass-card apu-interactive-card p-6 md:p-8">
          <span class="text-mono text-brand-text-muted block mb-2">TRANSISI</span>
          <p class="text-body-s text-brand-text font-medium">
            Berganti nama dari IKMB menjadi APU
          </p>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
