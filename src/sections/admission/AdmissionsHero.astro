---
import { assetUrl } from '@lib/assets';
import CtaButton from "@components/CtaButton.astro";
import { contact } from "@data/contact";
---

<section
    id="beranda"
    class="admissions-hero relative min-h-[100dvh] flex items-end overflow-hidden"
>
    <!-- Background Image with Parallax -->
    <div
        id="admissions-hero-bg"
        class="absolute inset-0 z-[1] will-change-transform opacity-0 scale-[1.04]"
    >
        <img
            src={assetUrl('/images/loby1.webp')}
            alt="Futuristic Campus of Agung Putra University"
            class="w-full h-full object-cover"
            loading="eager"
            id="admissions-hero-bg-img"
        />
        <div class="absolute inset-0 admissions-hero-overlay-main"></div>
        <div class="absolute inset-0 admissions-hero-overlay-side"></div>
        <div class="absolute inset-0 admissions-hero-overlay-soft"></div>
    </div>

    <!-- Floating Particles -->
    <div
        id="admissions-hero-particles"
        class="absolute inset-0 z-[2] overflow-hidden pointer-events-none"
    >
    </div>

    <!-- Content -->
    <div class="relative z-[3] w-full pb-20">
        <div
            class="content-max mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row justify-between items-start gap-10"
        >
            <div>
                <div id="admissions-hero-kicker" class="mb-6 opacity-0 translate-y-2">
                    <span class="admissions-hero-kicker-text"
                        >NEW STUDENT ADMISSIONS 2026/2027</span
                    >
                </div>

                <h1
                    id="admissions-hero-headline"
                    class="text-h1 mb-6 max-w-4xl opacity-0 translate-y-3 admissions-hero-headline"
                >
                    <span class="block"
                        >Start Your</span
                    >
                    <span class="block">Academic Journey at <span class="text-brand-accent-soft"
                            >APU</span
                        ></span
                    >
                </h1>

                <p
                    id="admissions-hero-subtitle"
                    class="text-body max-w-2xl mb-10 opacity-0 translate-y-2 admissions-hero-subtitle"
                >
                    Choose the pathway that matches your potential, prepare your documents, then submit
                    your online registration with ease. Our admissions team is ready to assist you every step of the way.
                </p>

                <div
                    id="admissions-hero-cta"
                    class="flex flex-wrap gap-4 opacity-0 translate-y-2"
                >
                    <CtaButton
                        href={contact.pmbLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        variant="primary"
                        withArrow={true}
                    >
                        <span>Register Now</span>
                    </CtaButton>
                    <CtaButton href="#jalur-masuk" variant="secondary">
                        <span>View Pathways</span>
                    </CtaButton>
                </div>
            </div>

            <!-- Quick Info Card -->
            <aside
                id="admissions-hero-info"
                class="w-full lg:w-fit admissions-hero-info opacity-0 translate-y-2"
            >
                <h2 class="text-h3 mb-5 admissions-hero-info-title">Important Information</h2>
                <div class="space-y-3">
                    <div class="admissions-hero-info-item">
                        <div class="flex items-center gap-3">
                            <div class="admissions-hero-info-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 2v4"/><path d="M16 2v4"/><path d="M3 10h18"/></svg>
                            </div>
                            <div>
                                <p class="admissions-hero-info-label">Registration Period</p>
                                <p class="admissions-hero-info-value">October 1, 2025 – August 25, 2026</p>
                            </div>
                        </div>
                    </div>
                    <div class="admissions-hero-info-item">
                        <div class="flex items-center gap-3">
                            <div class="admissions-hero-info-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <div>
                                <p class="admissions-hero-info-label">Selection Test</p>
                                <p class="admissions-hero-info-value">Every Saturday, 09:00 WIB</p>
                            </div>
                        </div>
                    </div>
                    <div class="admissions-hero-info-item">
                        <div class="flex items-center gap-3">
                            <div class="admissions-hero-info-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                            </div>
                            <div>
                                <p class="admissions-hero-info-label">Registration Support</p>
                                <p class="admissions-hero-info-value">{contact.whatsapp}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <!-- Scroll Indicator -->
        <div
            id="admissions-hero-scroll"
            class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0"
        >
            <span class="text-caption admissions-hero-scroll-text"
                >Scroll to explore</span
            >
            <svg
                class="animate-bounce-slow admissions-hero-scroll-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
            >
        </div>
    </div>
</section>

<style>
    .admissions-hero {
        --hero-navy: #132842;
        --hero-navy-deep: #0b1f35;
        --hero-navy-soft: #274977;
        --hero-orange: #f4bf61;
        --hero-orange-soft: #ffd992;
        --hero-ivory: #fffaf0;
        --hero-accent: #fcbc55;

        --apu-surface: 255 250 240;
        --apu-navy: 19 40 66;
        --apu-accent: 252 188 85;
        --apu-text: 255 250 240;
        --apu-text-muted: 239 232 218;
        --apu-border: 255 255 255;
    }

    .admissions-hero-overlay-main {
        background: linear-gradient(
            to top,
            rgb(244 191 97 / 0.58),
            rgb(21 48 87 / 0.42),
            transparent
        );
    }
    .admissions-hero-overlay-side {
        background: linear-gradient(
            to right,
            rgb(15 39 71 / 0.36),
            transparent,
            rgb(15 39 71 / 0.36)
        );
    }
    .admissions-hero-overlay-soft {
        background: rgb(250 246 238 / 0.18);
    }

    .admissions-hero-kicker-text,
    .admissions-hero-subtitle,
    .admissions-hero-scroll-text,
    .admissions-hero-scroll-icon {
        color: var(--hero-ivory);
    }

    .admissions-hero-kicker-text {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgb(252 188 85 / 0.45);
        border-radius: 999px;
        padding: 0.45rem 0.9rem;
        background: rgb(255 250 240 / 0.1);
        font-family: "Space Mono", monospace;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
    }

    .admissions-hero-headline {
        color: var(--hero-ivory);
        text-shadow: 0 8px 26px rgb(15 39 71 / 0.3);
    }

    .admissions-hero-info {
        border: 1px solid rgb(255 250 240 / 0.3);
        border-radius: 1.5rem;
        background: rgb(255 255 255 / 0.1);
        backdrop-filter: blur(12px);
        padding: 1.5rem;
    }

    .admissions-hero-info-title,
    .admissions-hero-info-label,
    .admissions-hero-info-value {
        color: var(--hero-ivory);
    }

    .admissions-hero-info-item {
        border: 1px solid rgb(255 250 240 / 0.2);
        border-radius: 1rem;
        padding: 0.85rem;
        background: rgb(255 255 255 / 0.06);
        transition: all 0.3s ease;
    }

    .admissions-hero-info-item:hover {
        background: rgb(255 255 255 / 0.1);
        border-color: rgb(252 188 85 / 0.4);
    }

    .admissions-hero-info-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgb(252 188 85 / 0.15);
        border: 1px solid rgb(252 188 85 / 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--hero-accent);
        flex-shrink: 0;
    }

    .admissions-hero-info-label {
        font-size: 0.75rem;
        opacity: 0.7;
        margin-bottom: 0.15rem;
        font-family: "Space Mono", monospace;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .admissions-hero-info-value {
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.3;
        overflow-wrap: break-word;
    }
</style>

<script>
    (function () {
        // Floating particles
        const particleContainer = document.getElementById("admissions-hero-particles");
        if (particleContainer) {
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement("div");
                const size = Math.random() * 3 + 1;
                particle.className = "absolute rounded-full";
                particle.style.cssText = `
                    width: ${size}px;
                    height: ${size}px;
                    left: ${Math.random() * 100}%;
                    top: ${Math.random() * 100}%;
                    background: rgba(255, 223, 153, 0.3);
                    animation: admissionsHeroFloat ${Math.random() * 6 + 4}s ease-in-out infinite;
                    animation-delay: ${Math.random() * 5}s;
                `;
                particleContainer.appendChild(particle);
            }
        }

        // Add float animation
        const style = document.createElement("style");
        style.textContent = `
            @keyframes admissionsHeroFloat {
                0%, 100% { transform: translateY(0) translateX(0); opacity: 0.2; }
                25% { transform: translateY(-20px) translateX(10px); opacity: 0.5; }
                50% { transform: translateY(-40px) translateX(-5px); opacity: 0.3; }
                75% { transform: translateY(-20px) translateX(15px); opacity: 0.4; }
            }
        `;
        document.head.appendChild(style);

        // Elements for animation
        const bg = document.getElementById("admissions-hero-bg");
        const kicker = document.getElementById("admissions-hero-kicker");
        const headline = document.getElementById("admissions-hero-headline");
        const subtitle = document.getElementById("admissions-hero-subtitle");
        const cta = document.getElementById("admissions-hero-cta");
        const info = document.getElementById("admissions-hero-info");
        const scrollIndicator = document.getElementById("admissions-hero-scroll");
        const bgImg = document.getElementById("admissions-hero-bg-img");

        // Staggered reveal on page load
        document.fonts.ready.then(() => {
            if (bg) {
                bg.style.transition = "opacity 2.2s ease-out, transform 2.6s ease-out";
                bg.style.opacity = "1";
                bg.style.transform = "scale(1)";
            }

            setTimeout(() => {
                if (kicker) {
                    kicker.style.transition = "opacity 0.8s ease-out, transform 0.8s ease-out";
                    kicker.style.opacity = "1";
                    kicker.style.transform = "translateY(0)";
                }
            }, 450);

            setTimeout(() => {
                if (headline) {
                    headline.style.transition = "opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1)";
                    headline.style.opacity = "1";
                    headline.style.transform = "translateY(0)";
                }
            }, 760);

            setTimeout(() => {
                if (subtitle) {
                    subtitle.style.transition = "opacity 0.8s ease-out, transform 0.8s ease-out";
                    subtitle.style.opacity = "1";
                    subtitle.style.transform = "translateY(0)";
                }
            }, 1120);

            setTimeout(() => {
                if (cta) {
                    cta.style.transition = "opacity 0.6s ease-out, transform 0.6s ease-out";
                    cta.style.opacity = "1";
                    cta.style.transform = "translateY(0)";
                }
            }, 1480);

            setTimeout(() => {
                if (info) {
                    info.style.transition = "opacity 0.7s ease-out, transform 0.7s ease-out";
                    info.style.opacity = "1";
                    info.style.transform = "translateY(0)";
                }
            }, 1680);

            setTimeout(() => {
                if (scrollIndicator) {
                    scrollIndicator.style.transition = "opacity 0.6s ease-out";
                    scrollIndicator.style.opacity = "1";
                }
            }, 2100);
        });

        // Mouse parallax effect
        let mouseX = 0;
        let mouseY = 0;
        let currentX = 0;
        let currentY = 0;

        document.addEventListener("mousemove", (e) => {
            mouseX = (e.clientX / window.innerWidth - 0.5) * 20;
            mouseY = (e.clientY / window.innerHeight - 0.5) * 20;
        });

        function animateParallax() {
            currentX += (mouseX - currentX) * 0.08;
            currentY += (mouseY - currentY) * 0.08;
            if (bgImg) {
                bgImg.style.transform = `translate(${currentX}px, ${currentY}px) scale(1.05)`;
            }
            requestAnimationFrame(animateParallax);
        }
        animateParallax();

        // Scroll-based fade out
        let ticking = false;
        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    requestAnimationFrame(() => {
                        const scrollY = window.scrollY;
                        const heroHeight =
                            document.querySelector("#beranda")
                                ?.clientHeight || window.innerHeight;
                        const progress = Math.min(scrollY / heroHeight, 1);

                        if (headline) {
                            const scale = 1 - progress * 0.08;
                            const yOffset = -progress * 12;
                            const opacity = 1 - progress * 0.85;
                            headline.style.transform = `scale(${scale}) translateY(${yOffset}%)`;
                            headline.style.opacity = String(Math.max(opacity, 0));
                        }

                        if (kicker) {
                            kicker.style.transform = `translateY(${-progress * 25}%)`;
                            kicker.style.opacity = String(Math.max(1 - progress, 0));
                        }

                        if (scrollIndicator) {
                            scrollIndicator.style.opacity = String(Math.max(1 - progress * 3, 0));
                        }

                        ticking = false;
                    });
                    ticking = true;
                }
            },
            { passive: true },
        );
    })();
</script>
