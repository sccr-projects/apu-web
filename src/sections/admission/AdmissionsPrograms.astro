---
import ScrollReveal from "../../components/ScrollReveal.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { programs } from "../../data/programs";

const programTones: Record<string, { bg: string; accent: string }> = {
  "biomedical-science": { bg: "rgb(6 46 112 / 0.7)", accent: "#60a5fa" },
  biotechnology: { bg: "rgb(43 122 74 / 0.75)", accent: "#86efac" },
  law: { bg: "rgb(180 83 9 / 0.7)", accent: "#fdba74" },
  management: { bg: "rgb(28 86 51 / 0.8)", accent: "#86efac" },
  communication: { bg: "rgb(98 6 112 / 0.7)", accent: "#d8b4fe" },
  "midwifery-s1": { bg: "rgb(180 28 28 / 0.7)", accent: "#fca5a5" },
  "midwifery-d3": { bg: "rgb(43 122 74 / 0.88)", accent: "#86efac" },
};

const getTone = (id: string) => programTones[id] || { bg: "rgb(28 86 51 / 0.8)", accent: "#86efac" };
---

<section
  id="program"
  class="apu-section-shell motion-aurora-shell motion-aurora-shell--programs relative overflow-hidden bg-gradient-to-b from-brand-surface via-brand-surface-alt to-brand-surface pt-8 pb-20"
>
  <ScrollReveal>
    <SectionHeader
      kicker="PROGRAM STUDI"
      title="Program Unggulan, Masa Depan Cerah"
      description="Pilih program studi yang sesuai dengan minat dan passionmu. Setiap program dirancang untuk mempersiapkanmu menghadapi dunia kerja."
      class="text-center mb-10 pt-8"
      titleClass="text-h2 text-brand-primary-deep mb-4"
    />
  </ScrollReveal>

  <!-- Programs Grid -->
  <div class="content-max">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        programs.map((program, index) => {
          const tone = getTone(program.id);
          return (
            <ScrollReveal delay={index * 100}>
              <a
                href={program.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative aspect-[4/3] rounded-2xl overflow-hidden block apu-interactive-card"
                style={`background-image: url('${program.image}'); background-size: cover; background-position: center;`}
              >
                <!-- Overlay -->
                <div
                  class="absolute inset-0 transition-all duration-500"
                  style={`background: linear-gradient(180deg, transparent 0%, ${tone.bg} 100%);`}
                ></div>

                <!-- Content -->
                <div class="absolute inset-0 p-6 flex flex-col justify-end">
                  <span
                    class="inline-block self-start px-3 py-1 rounded-full text-xs font-bold tracking-wider mb-3"
                    style={`background: ${tone.accent}22; color: ${tone.accent}; border: 1px solid ${tone.accent}44;`}
                  >
                    Program {program.degree}
                  </span>

                  <h3 class="text-xl font-bold text-white mb-2 leading-tight">
                    {program.name}
                  </h3>

                  <!-- Sub-programs (reveal on hover) -->
                  <div class="overflow-hidden transition-all duration-500 max-h-0 group-hover:max-h-24">
                    <ul class="space-y-1">
                      {program.subPrograms.map((sub) => (
                        <li
                          class="text-sm text-white/80 flex items-center gap-2"
                        >
                          <span
                            class="w-1 h-1 rounded-full"
                            style={`background: ${tone.accent};`}
                          ></span>
                          {sub}
                        </li>
                      ))}
                    </ul>
                  </div>

                  <!-- Arrow indicator -->
                  <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="white"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12h14"></path>
                      <path d="m12 5 7 7-7 7"></path>
                    </svg>
                  </div>
                </div>

                <!-- Hover glow effect -->
                <div
                  class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                  style={`box-shadow: inset 0 0 60px ${tone.accent}22;`}
                ></div>
              </a>
            </ScrollReveal>
          );
        })
      }
    </div>

    <!-- View All CTA -->
    <ScrollReveal class="text-center mt-12">
      <a
        href="/apu/programs"
        class="inline-flex items-center gap-2 text-body-s font-medium text-brand-primary-deep hover:text-brand-accent transition-colors duration-300"
      >
        <span>Lihat Semua Program Studi</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 hover:translate-x-1"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </ScrollReveal>
  </div>
</section>
