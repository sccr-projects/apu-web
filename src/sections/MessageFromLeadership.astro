---
import ScrollReveal from "@components/ScrollReveal.astro";
import CtaButton from "@components/CtaButton.astro";
import BackgroundBlobs from "@components/BackgroundBlobs.astro";
import { leadershipMessage } from "@data/leadership";

interface Props {
  variant?: "dark" | "light";
}

const { variant = "dark" } = Astro.props;

const { kicker, title, quote, leaderName, leaderTitle,leaderTitle2, leaderImage, cta } =
  leadershipMessage;
---

<section
  id="pesan-pemimpin"
  class:list={[
    "leadership-section",
    "apu-section-shell",
    "relative",
    "isolate",
    "overflow-hidden",
    { "leadership-section--light": variant === "light" },
  ]}
>
  <BackgroundBlobs seed="MessageFromLeadership" />
  {/* Ambient decorative elements */}
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    {/* Large glow orb behind portrait area */}
    <div
      class="absolute -right-32 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-[rgb(var(--color-apu-accent)_/_0.12)] blur-[120px]"
    >
    </div>
    {/* Secondary glow orb */}
    <div
      class="absolute right-1/4 bottom-0 h-80 w-80 rounded-full bg-[rgb(var(--color-brand-primary)_/_0.1)] blur-[100px]"
    >
    </div>
    {/* Subtle top accent line */}
    <div
      class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-apu-accent)_/_0.5)] to-transparent"
    >
    </div>
  </div>

  {/* Floating particles container */}
  <div
    id="leadership-particles"
    class="absolute inset-0 z-[2] overflow-hidden pointer-events-none"
  >
  </div>

  <div
    class="content-max relative z-10 py-24 md:py-32 lg:py-40"
  >
    <div
      class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16"
    >
      {/* Message Side - Left */}
      <div class="order-2 lg:order-1">
        <ScrollReveal direction="left" delay={0}>
          <span class="apu-section-kicker mb-6 inline-flex">{kicker}</span>
        </ScrollReveal>

        <ScrollReveal direction="left" delay={100}>
          <h2 class="text-h2 text-[rgb(var(--leadership-text))] mb-6">
            {title}
            <span
              class="apu-gradient-line mt-4 block w-48"
              style="--apu-gradient-line-height: 0.25rem;"
            ></span>
          </h2>
        </ScrollReveal>

        <ScrollReveal direction="left" delay={200}>
          <div class="leadership-quote relative mb-8">
            {/* Decorative quote mark */}
            <span
              class="absolute -left-2 -top-4 -z-10 text-5xl sm:text-6xl md:text-7xl lg:text-[6rem] leading-none text-[rgb(var(--color-apu-accent)_/_0.2)] font-serif select-none"
              aria-hidden="true"
            >
              "
            </span>
            <div class="relative pl-6">
              {quote.map((paragraph, index) => (
                <p
                  class={`text-body text-[rgb(var(--leadership-text-muted))] leading-relaxed ${index < quote.length - 1 ? "mb-4" : ""}`}
                >
                  {paragraph}
                </p>
              ))}
            </div>
          </div>
        </ScrollReveal>

        <ScrollReveal direction="left" delay={300}>
          <div class="mb-8">
            <p class="text-h3 text-[rgb(var(--leadership-text))] font-medium">
              {leaderName}
            </p>
            <p class="text-caption text-[rgb(var(--leadership-text-muted))] mt-1 tracking-wider">
              {leaderTitle}
            </p>
            <p class="text-caption text-[rgb(var(--leadership-text-muted))] mt-1 tracking-wider">
              {leaderTitle2}
            </p>
            <div
              class="mt-3 h-0.5 w-24 rounded-full bg-gradient-to-r from-[rgb(var(--color-apu-accent))] to-transparent"
            >
            </div>
          </div>
        </ScrollReveal>

        <ScrollReveal direction="left" delay={400}>
          <CtaButton
            href={cta.href}
            variant="primary"
            withArrow
            ariaLabel={cta.label}
          >
            {cta.label}
          </CtaButton>
        </ScrollReveal>
      </div>

      {/* Portrait Side - Right */}
      <div class="order-1 lg:order-2">
        <ScrollReveal direction="right" delay={150}>
          <div class="leadership-portrait relative mx-auto max-w-md lg:max-w-none">
            {/* Glow behind portrait */}

            {/* Portrait container with gradient mask */}
            <div
              class="relative overflow-hidden rounded-[2rem] lg:rounded-[2.5rem]"
            >
              {/* Gradient fade mask on left edge */}
              <div
                class="absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-[rgb(var(--leadership-bg))] to-transparent lg:w-32"
              >
              </div>

              {/* Image */}
              <img
                src={leaderImage}
                alt={`Photo of ${leaderName}, ${leaderTitle}`}
                class="leadership-portrait-img w-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
                style="aspect-ratio: 3/4;"
                loading="lazy"
              />

              {/* Subtle overlay for depth */}
              <div
                class="absolute inset-0 bg-gradient-to-t from-[rgb(var(--leadership-bg)_/_0.4)] via-transparent to-transparent"
              >
              </div>
            </div>

            {/* Decorative corner accent */}
            <div
              class="absolute -bottom-3 right-0 h-24 w-24 apu-corner-accent--br-4"
              aria-hidden="true"
            >
            </div>
            <div
              class="absolute top-0 left-0 h-24 w-24 apu-corner-navy--tl-4"
              aria-hidden="true"
            >
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </div>
</section>

<style>
  .leadership-section {
    --leadership-bg: 19 40 66;
    --leadership-bg-deep: 11 28 48;
    --leadership-text: 255 250 240;
    --leadership-text-muted: 200 190 170;

    --apu-surface: var(--leadership-bg);
    --apu-surface-alt: var(--leadership-bg-deep);
    --apu-text: var(--leadership-text);
    --apu-text-muted: var(--leadership-text-muted);
    --apu-navy: 19 40 66;
    --apu-accent: 252 188 85;

    --apu-btn-primary-bg: rgb(var(--color-apu-accent));
    --apu-btn-primary-color: rgb(var(--color-apu-navy));
    --apu-btn-primary-border: rgb(var(--color-apu-accent) / 0.5);
    --apu-btn-primary-hover-bg: rgb(var(--leadership-text));
    --apu-btn-primary-hover-color: rgb(var(--color-apu-navy));
    --apu-btn-secondary-bg: rgb(255 255 255 / 0.06);
    --apu-btn-secondary-color: rgb(var(--leadership-text));
    --apu-btn-secondary-border: rgb(255 250 240 / 0.3);
    --apu-btn-secondary-hover-bg: rgb(255 255 255 / 0.12);
    --apu-btn-secondary-hover-border: rgb(255 250 240 / 0.6);

    --apu-badge-bg: rgb(255 255 255 / 0.08);
    --apu-badge-border: rgb(252 188 85 / 0.35);
    --apu-badge-color: rgb(255 250 240);

    background-color: rgb(var(--leadership-bg));
  }

  .leadership-section--light {
    --leadership-bg: 247 250 243;
    --leadership-bg-deep: 236 243 227;
    --leadership-text: 27 41 32;
    --leadership-text-muted: 87 112 94;

    --apu-surface: var(--leadership-bg);
    --apu-surface-alt: var(--leadership-bg-deep);
    --apu-text: var(--leadership-text);
    --apu-text-muted: var(--leadership-text-muted);
    --apu-navy: 19 40 66;
    --apu-accent: 252 188 85;

    --apu-btn-primary-bg: rgb(var(--color-apu-navy));
    --apu-btn-primary-color: rgb(var(--color-brand-surface));
    --apu-btn-primary-border: rgb(255 255 255 / 0.14);
    --apu-btn-primary-hover-bg: rgb(var(--color-apu-accent));
    --apu-btn-primary-hover-color: rgb(var(--color-apu-navy));
    --apu-btn-secondary-bg: rgb(255 255 255 / 0.72);
    --apu-btn-secondary-color: rgb(var(--leadership-text));
    --apu-btn-secondary-border: rgb(var(--leadership-text) / 0.3);
    --apu-btn-secondary-hover-bg: rgb(255 255 255 / 0.92);
    --apu-btn-secondary-hover-border: rgb(var(--leadership-text) / 0.5);

    --apu-badge-bg: rgb(255 255 255 / 0.82);
    --apu-badge-border: rgb(var(--apu-navy) / 0.14);
    --apu-badge-color: rgb(var(--apu-navy));

    background-color: rgb(var(--leadership-bg));
  }

  .leadership-quote {
    position: relative;
  }

  .leadership-quote p {
    font-family: "Instrument Serif", Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.125rem, 1.5vw, 1.35rem);
    line-height: 1.7;
  }

  .leadership-portrait {
    position: relative;
  }

  .leadership-portrait-img {
    filter: contrast(1.05) saturate(0.95);
  }

</style>

<script>
  (function () {
    // Floating particles
    const particleContainer = document.getElementById("leadership-particles");
    if (particleContainer) {
      for (let i = 0; i < 20; i++) {
        const particle = document.createElement("div");
        const size = Math.random() * 2.5 + 1;
        particle.className = "absolute rounded-full";
        particle.style.cssText = `
          width: ${size}px;
          height: ${size}px;
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          background: rgba(252, 188, 85, ${Math.random() * 0.25 + 0.1});
          animation: leadershipFloat ${Math.random() * 7 + 5}s ease-in-out infinite;
          animation-delay: ${Math.random() * 6}s;
        `;
        particleContainer.appendChild(particle);
      }
    }

    // Add keyframes if not already present
    if (!document.getElementById("leadership-animations")) {
      const style = document.createElement("style");
      style.id = "leadership-animations";
      style.textContent = `
        @keyframes leadershipFloat {
          0%, 100% { transform: translateY(0) translateX(0); opacity: 0.15; }
          25% { transform: translateY(-18px) translateX(8px); opacity: 0.35; }
          50% { transform: translateY(-35px) translateX(-4px); opacity: 0.22; }
          75% { transform: translateY(-15px) translateX(12px); opacity: 0.3; }
        }
      `;
      document.head.appendChild(style);
    }
  })();
</script>
