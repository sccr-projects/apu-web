---
import ScrollReveal from "../components/ScrollReveal.astro";
import { contact } from "../data/contact";
import { programs } from "../data/programs";
---

<section
  id="kontak"
  class="motion-aurora-shell motion-aurora-shell--contact relative isolate overflow-hidden bg-gradient-to-b from-brand-surface-alt via-brand-aurora/10 to-brand-surface-soft py-24 md:py-32"
>
  <div class="content-max">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left Column - Contact Info -->
      <ScrollReveal direction="left">
        <div class="space-y-8">
          <!-- Header -->
          <div>
            <span class="text-mono text-brand-accent tracking-widest block mb-4"
              >KONTAK KAMI</span
            >
            <h2 class="text-h2 text-brand-text mb-4">
              Hubungi Tim Admisi Kami
            </h2>
            <p class="text-body text-brand-text-muted">
              Ada pertanyaan seputar pendaftaran? Tim admisi kami siap membantu
              kamu.
            </p>
          </div>

          <!-- Contact Items -->
          <div class="space-y-6">
            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-brand-surface-alt/78 border border-brand-border/24 text-brand-primary-deep flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                  ></path></svg
                >
              </div>
              <div>
                <span
                  class="text-caption text-brand-text-muted uppercase tracking-wider block mb-1"
                  >WhatsApp</span
                >
                <a
                  href={contact.whatsappLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-body text-brand-text hover:text-brand-primary-deep transition-colors"
                >
                  {contact.whatsapp}
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-brand-surface-alt/78 border border-brand-border/24 text-brand-primary-deep flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
              </div>
              <div>
                <span
                  class="text-caption text-brand-text-muted uppercase tracking-wider block mb-1"
                  >Alamat</span
                >
                <p class="text-body text-brand-text">{contact.address}</p>
              </div>
            </div>

            <!-- Website -->
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-brand-surface-alt/78 border border-brand-border/24 text-brand-primary-deep flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="12" cy="12" r="10"></circle><line
                    x1="2"
                    y1="12"
                    x2="22"
                    y2="12"></line><path
                    d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                  ></path></svg
                >
              </div>
              <div>
                <span
                  class="text-caption text-brand-text-muted uppercase tracking-wider block mb-1"
                  >Website</span
                >
                <a
                  href={contact.websiteLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-body text-brand-text hover:text-brand-primary-deep transition-colors"
                >
                  {contact.website}
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-brand-surface-alt/78 border border-brand-border/24 text-brand-primary-deep flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
                >
              </div>
              <div>
                <span
                  class="text-caption text-brand-text-muted uppercase tracking-wider block mb-1"
                  >Email</span
                >
                <a
                  href={`mailto:${contact.email}`}
                  class="text-body text-brand-text hover:text-brand-primary-deep transition-colors"
                >
                  {contact.email}
                </a>
              </div>
            </div>
          </div>

          <!-- Social Media -->
          <div class="pt-4">
            <span class="text-caption text-brand-text-muted block mb-3"
              >Follow Kami</span
            >
            <div class="flex items-center gap-4">
              <a
                href={contact.social.instagramLink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="text-brand-text-muted hover:text-brand-primary-deep transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                  ></rect><path
                    d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                  ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
                  ></line></svg
                >
              </a>
              <a
                href={contact.social.tiktokLink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="TikTok"
                class="text-brand-text-muted hover:text-brand-primary-deep transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg
                >
              </a>
              <a
                href={contact.social.twitterLink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="X"
                class="text-brand-text-muted hover:text-brand-primary-deep transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  ></path></svg
                >
              </a>
              <a
                href={contact.social.youtubeLink}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="YouTube"
                class="text-brand-text-muted hover:text-brand-primary-deep transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"
                  ></path><polygon
                    points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"
                  ></polygon></svg
                >
              </a>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Right Column - Contact Form -->
      <ScrollReveal direction="right">
        <div
          class="bg-brand-surface/94 rounded-xl p-8 shadow-sm border border-brand-border/34"
        >
          <!-- <h3 class="text-h3 text-brand-text mb-6">Kirim Pesan</h3> -->

          <!-- <form id="contact-form" class="space-y-5">
            <div>
              <label for="nama" class="text-body-s text-brand-text block mb-2"
                >Nama Lengkap <span class="text-brand-accent">*</span></label
              >
              <input
                type="text"
                id="nama"
                name="nama"
                required
                class="w-full px-4 py-3 bg-brand-surface border border-brand-border/48 rounded-lg text-body text-brand-text placeholder:text-brand-text-muted/60 focus:outline-none focus:border-brand-primary-deep focus:ring-2 focus:ring-brand-primary/18 transition-all shadow-[inset_0_1px_0_rgb(var(--color-base-white)_/_0.5)]"
                placeholder="Masukkan nama lengkap"
              />
            </div>

            <div>
              <label for="email" class="text-body-s text-brand-text block mb-2"
                >Email <span class="text-brand-accent">*</span></label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-brand-surface border border-brand-border/48 rounded-lg text-body text-brand-text placeholder:text-brand-text-muted/60 focus:outline-none focus:border-brand-primary-deep focus:ring-2 focus:ring-brand-primary/18 transition-all shadow-[inset_0_1px_0_rgb(var(--color-base-white)_/_0.5)]"
                placeholder="email@example.com"
              />
            </div>

            <div>
              <label
                for="whatsapp"
                class="text-body-s text-brand-text block mb-2"
                >Nomor WhatsApp</label
              >
              <input
                type="tel"
                id="whatsapp"
                name="whatsapp"
                class="w-full px-4 py-3 bg-brand-surface border border-brand-border/48 rounded-lg text-body text-brand-text placeholder:text-brand-text-muted/60 focus:outline-none focus:border-brand-primary-deep focus:ring-2 focus:ring-brand-primary/18 transition-all shadow-[inset_0_1px_0_rgb(var(--color-base-white)_/_0.5)]"
                placeholder="0812xxxxxxx"
              />
            </div>

            <div>
              <label
                for="program"
                class="text-body-s text-brand-text block mb-2"
                >Program yang Diminati <span class="text-brand-accent">*</span
                ></label
              >
              <select
                id="program"
                name="program"
                required
                class="w-full px-4 py-3 bg-brand-surface border border-brand-border/48 rounded-lg text-body text-brand-text focus:outline-none focus:border-brand-primary-deep focus:ring-2 focus:ring-brand-primary/18 transition-all appearance-none cursor-pointer shadow-[inset_0_1px_0_rgb(var(--color-base-white)_/_0.5)]"
              >
                <option value="" disabled selected>Pilih program studi</option>
                {
                  programs.map((program) => (
                    <option value={`${program.degree} ${program.name}`}>
                      {program.degree} {program.name}
                    </option>
                  ))
                }
              </select>
            </div>

            <div>
              <label for="pesan" class="text-body-s text-brand-text block mb-2"
                >Pesan <span class="text-brand-accent">*</span></label
              >
              <textarea
                id="pesan"
                name="pesan"
                rows="4"
                required
                class="w-full px-4 py-3 bg-brand-surface border border-brand-border/48 rounded-lg text-body text-brand-text placeholder:text-brand-text-muted/60 focus:outline-none focus:border-brand-primary-deep focus:ring-2 focus:ring-brand-primary/18 transition-all resize-none shadow-[inset_0_1px_0_rgb(var(--color-base-white)_/_0.5)]"
                placeholder="Tulis pertanyaan atau pesanmu..."></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full py-4 bg-brand-primary-deep text-brand-surface text-body font-medium rounded-lg transition-all duration-300 hover:bg-brand-primary-deeper disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="btn-text">Kirim Pesan</span>
            </button>
          </form> -->

          <!-- Success State (hidden by default) -->
          <div id="success-state" class="hidden text-center py-8">
            <div
              class="w-16 h-16 rounded-full bg-brand-surface-alt/78 border border-brand-border/24 text-brand-primary-deep flex items-center justify-center mx-auto mb-4"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
                  points="22 4 12 14.01 9 11.01"></polyline></svg
              >
            </div>
            <h4 class="text-h3 text-brand-text mb-2">Pesan Terkirim!</h4>
            <p class="text-body-s text-brand-text-muted">
              Tim admisi kami akan segera menghubungimu.
            </p>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const btnText = document.getElementById("btn-text");
    const successState = document.getElementById("success-state");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();

      // Disable button
      submitBtn!.disabled = true;
      btnText!.textContent = "Mengirim...";

      // Simulate sending
      setTimeout(() => {
        form!.classList.add("hidden");
        successState!.classList.remove("hidden");
      }, 1500);
    });
  })();
</script>
