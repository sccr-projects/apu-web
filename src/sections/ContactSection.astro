---
import { contact } from "@data/contact";

const contactItems = [
  {
    label: "WhatsApp",
    value: contact.whatsapp,
    href: contact.whatsappLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  },
  {
    label: "Address",
    value: contact.address,
    href: null,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    label: "Website",
    value: contact.website,
    href: contact.websiteLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  },
  {
    label: "Email",
    value: contact.email,
    href: `mailto:${contact.email}`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
];

const socials = [
  {
    label: "Instagram",
    href: contact.social.instagramLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: "TikTok",
    href: contact.social.tiktokLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>`,
  },
  {
    label: "X",
    href: contact.social.twitterLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: "YouTube",
    href: contact.social.youtubeLink,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>`,
  },
];
---

<section
  id="kontak"
  class="apu-section-shell motion-aurora-shell motion-aurora-shell--contact relative isolate overflow-hidden"
  style="padding-top: var(--apu-section-spacing-y); padding-bottom: var(--apu-section-spacing-y);"
>
  <div class="content-max">
    {/* Section Header */}
    <header class="text-center mb-10 md:mb-14">
      <span class="apu-section-kicker mb-4">CONTACT US</span>
      <h2 class="text-h2 text-brand-text mb-3">
        Reach the Admissions Team
        <span class="apu-gradient-line mx-auto mt-3 w-48"></span>
      </h2>
      <p class="text-body-s text-brand-text-muted max-w-md mx-auto leading-relaxed mt-4">
        Have questions about admissions? Our admissions team is ready to help.
      </p>
    </header>

    {/* Contact Card Grid */}
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {
        contactItems.map((item) => (
          <div class="apu-glass-card apu-interactive-card apu-corner-accent--tr p-5 group">
              <div class="flex flex-row gap-3 items-center mb-4">
                  <div class="apu-icon-chip w-10 h-10">
                    <Fragment set:html={item.icon} />
                  </div>
                  <span class="text-caption text-xl text-brand-text-muted uppercase tracking-wider block mb-1.5">
                    {item.label}
                  </span>

              </div>

            {item.href ? (
              <a
                href={item.href}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="text-body-s text-brand-text group-hover:text-brand-primary-deep transition-colors duration-220 break-words"
              >
                {item.value}
              </a>
            ) : (
              <p class="text-body-s text-brand-text break-words">{item.value}</p>
            )}
          </div>
        ))
      }
    </div>

    {/* Bottom Bar: Social + CTA */}
    <div class="apu-glass-card p-5 flex flex-col sm:flex-row items-center justify-center gap-8">
      {/* Social Icons */}
      <div class="flex items-center gap-8">
        <span class="text-caption text-brand-text-muted text-2xl mr-2">Follow Us:</span>
        {
          socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="w-12 h-12 sm:w-14 md:w-16 lg:w-20 rounded-full bg-brand-surface-alt/60 border border-brand-border/20 text-brand-text-muted hover:text-brand-primary-deep hover:border-brand-primary/30 hover:bg-brand-primary/8 flex items-center justify-center transition-all duration-220"
            >
                <Fragment class="w-24 h-24" set:html={social.icon} />
            </a>
          ))
        }
      </div>

      {/* CTA */}
      <a
        href={contact.whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="w-12 h-12 sm:w-14 md:w-16 lg:w-20 rounded-full bg-brand-surface-alt/60 border border-brand-border/20 text-brand-text-muted hover:text-brand-primary-deep hover:border-brand-primary/30 hover:bg-brand-primary/8 flex items-center justify-center transition-all duration-220"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="42"
          height="42"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
