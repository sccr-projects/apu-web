---
import { Image } from "astro:assets";
import ScrollReveal from "@components/ScrollReveal.astro";
import SectionHeader from "@components/SectionHeader.astro";
import DiasporaFeaturedCard from "@components/DiasporaFeaturedCard.astro";
import type { ProgramFacultyData } from "@data/program-faculty";
import { people as diasporaPeople } from "@data/diaspora";
import canada from "@/assets/images/academic/canada-bg.jpg";
import BackgroundBlobs from "@components/BackgroundBlobs.astro";
import googleScholar from "@/assets/images/academic/google_scholar.webp";


interface Props {
  data: ProgramFacultyData;
}

const { data } = Astro.props;
const members = data.facultyMembers;
const featured = members[0];

const diasporaIds = new Set(diasporaPeople.map((p) => p.id));
const isFeaturedDiaspora = featured ? diasporaIds.has(featured.id) : false;
const initialDiasporaPerson = isFeaturedDiaspora
  ? diasporaPeople.find((p) => p.id === featured!.id) ?? diasporaPeople[0]
  : diasporaPeople[0];

const facultyAvatarGradients = [
  "from-blue-500 to-indigo-600",
  "from-emerald-500 to-teal-600",
  "from-amber-500 to-orange-600",
  "from-rose-500 to-pink-600",
  "from-violet-500 to-purple-600",
  "from-cyan-500 to-blue-600",
];

function gradientFor(index: number): string {
  return facultyAvatarGradients[index % facultyAvatarGradients.length];
}

function getInitials(name: string): string {
  return name
    .split(" ")
    .map((n) => n[0])
    .filter((c) => c === c.toUpperCase())
    .slice(0, 2)
    .join("");
}

---

<section
  id="dosen-spotlight"
  class="apu-section-shell relative overflow-hidden py-12"
  aria-label="Faculty spotlight"
  data-members={JSON.stringify(members)}
  data-diaspora-people={JSON.stringify(diasporaPeople)}
  data-default-bg={canada.src}
>
    <BackgroundBlobs seed="ProgramFacultySpotlightSection" />
  <div>
    <ScrollReveal>
      <SectionHeader
        kicker="LECTURER SPOTLIGHT"
        title="Meet Our Expert Lecturers"
        description={data.description}
        class="text-center mb-16"
        titleClass="text-h2 text-brand-primary-deep mb-4"
      />
    </ScrollReveal>

    <!-- Featured lecturer -->
    <ScrollReveal>
      <div
        class="apu-glass-card rounded-none lecturers-featured-card mb-10 overflow-hidden flex justify-center relative"
      >
        <div
          data-standard-featured
          class:list={[
            "relative z-10 flex flex-col justify-center w-full md:flex-row",
            { hidden: isFeaturedDiaspora },
          ]}
        >
          <div
            class="order-2 w-full flex flex-col justify-center px-4 md:order-1 md:w-1/2 md:px-0 md:pl-10"
          >
            <h2
              class="text-h2 mb-3 text-white"
              data-featured-name
            >
              {featured?.name}
            </h2>
            <p
              class="text-body mb-3 text-apu-accent"
              data-featured-title
            >
              {featured?.title}
            </p>

            <p
              class:list={[
                "text-body-s text-white/80 mb-3",
                { hidden: !featured?.specialization },
              ]}
              data-featured-specialization
            >
              {featured?.specialization || ""}
            </p>

            <p
              class:list={[
                "text-caption text-white/60 ",
                { hidden: !featured?.nidn || featured?.nidn === "-" },
              ]}
              data-featured-nidn
            >
              {featured?.nidn && featured.nidn !== "-"
                ? `NIDN ${featured.nidn}`
                : ""}
            </p>

            <a
              data-featured-google-link
              href={featured?.google_link || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "flex flex-row w-full mt-3 mb-6 text-white",
                { hidden: !featured?.google_link },
              ]}
            >
              <Image
                src={googleScholar}
                alt={`Google Scholar profile of ${featured?.name ?? ""}`}
                class="w-6 object-contain border-0 mr-1"
                loading="lazy"
              />
              <span data-featured-google-index>{featured?.google_index ?? ""}</span>
            </a>

            <div data-featured-link-wrapper class="flex flex-wrap items-center gap-4">
              <a
                href={featured?.link || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class="apu-btn apu-btn--primary inline-flex items-center gap-2"
                data-featured-link
              >
                View Profile
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14"></path>
                  <path d="m12 5 7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>

          <div
            class="relative order-1 w-full mb-4 md:mb-0 md:order-2 md:w-96"
          >
            <div
              class="relative h-80 md:h-96 w-full overflow-hidden rounded-2xl flex items-center justify-center"
              data-featured-visual
            >
              {featured?.image ? (
                <Image
                  src={featured.image}
                  alt={`Portrait of ${featured.name}`}
                  class="h-full w-full object-contain border-0"
                  loading="eager"
                  data-featured-image
                />
              ) : (
                <div
                  class={`w-full h-full bg-gradient-to-br ${gradientFor(0)} flex items-center justify-center`}
                  data-featured-initials
                >
                  <span class="text-white text-4xl md:text-5xl font-bold">
                    {getInitials(featured?.name ?? "")}
                  </span>
                </div>
              )}
            </div>
          </div>
        </div>

        <div
          data-diaspora-featured
          class:list={[
            "w-full",
            { hidden: !isFeaturedDiaspora },
          ]}
        >
          <DiasporaFeaturedCard person={initialDiasporaPerson} />
        </div>
      </div>
    </ScrollReveal>

    <!-- Carousel header -->
    <div class="mb-6 px-4 flex items-end justify-between gap-6">
      <ScrollReveal class="flex-1">
        <h2
          class="font-epilogue font-semibold text-2xl text-apu-navy md:text-4xl"
        >
          List of Lecturers
        </h2>
      </ScrollReveal>
    </div>

    <!-- Carousel -->
    <ScrollReveal delay={150}>
      <div data-lecturers-carousel>
        <div
          data-lecturers-track
          class="lecturers-track flex snap-x snap-mandatory gap-4 overflow-x-auto pb-6"
          tabindex="0"
          aria-label="Faculty spotlight carousel"
        >
          {
            members.map((member, index) => (
              <article
                class="group apu-glass-card apu-interactive-card w-[82%] flex-shrink-0 snap-start cursor-pointer p-4 sm:p-5 sm:w-[47%] md:w-[31%] lg:w-[23%] xl:w-[18%]"
                data-member-id={member.id}
                data-gradient={gradientFor(index)}
                data-initials={getInitials(member.name)}
                tabindex="0"
                role="button"
              >
                <div class="mb-5 h-64 md:h-72 w-full overflow-hidden rounded-xl flex items-center justify-center">
                  {member.image ? (
                    <Image
                      draggable="false"
                      src={member.image}
                      alt={`Portrait of ${member.name}`}
                      class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div
                      draggable="false"
                      class={`h-full w-full bg-gradient-to-br ${gradientFor(index)} flex items-center justify-center`}
                    >
                      <span class="text-white text-2xl md:text-3xl font-bold">
                        {getInitials(member.name)}
                      </span>
                    </div>
                  )}
                </div>
                <h3
                  draggable="false"
                  class="text-lg font-semibold text-brand-text mb-1"
                >
                  {member.name}
                </h3>
                <p class="text-caption text-brand-text-muted">{member.title}</p>
                {
                  member.google_link && (
                    <a
                      href={member.google_link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex flex-row w-full mt-2"
                    >
                      <Image
                        src={googleScholar}
                        alt={`Google Scholar profile of ${member.name}`}
                        class="w-6 object-contain border-0 mr-1"
                        loading="lazy"
                      />
                      {member.google_index}
                    </a>
                  )
                }
              </article>
            ))
          }
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<script is:inline data-astro-rerun>
  (function () {
    var abortController = window.__apuFacultySpotlightAbort;
    if (abortController) abortController.abort();
    abortController = new AbortController();
    window.__apuFacultySpotlightAbort = abortController;
    var signal = abortController.signal;

    const section = document.querySelector("#dosen-spotlight");
    const members = JSON.parse(section?.getAttribute("data-members") || "[]");
    const diasporaPeople = JSON.parse(section?.getAttribute("data-diaspora-people") || "[]");
    const diasporaById = new Map(diasporaPeople.map((p) => [p.id, p]));
    const defaultBg = section?.getAttribute("data-default-bg") || "";

    const standardFeatured = section?.querySelector("[data-standard-featured]");
    const diasporaFeatured = section?.querySelector("[data-diaspora-featured]");

    const featuredName = section?.querySelector("[data-featured-name]");
    const featuredTitle = section?.querySelector("[data-featured-title]");
    const featuredSpecialization = section?.querySelector("[data-featured-specialization]");
    const featuredNidn = section?.querySelector("[data-featured-nidn]");
    const featuredLink = section?.querySelector("[data-featured-link]");
    const featuredLinkWrapper = section?.querySelector("[data-featured-link-wrapper]");
    const featuredVisual = section?.querySelector("[data-featured-visual]");
    const featuredGoogleLink = section?.querySelector("[data-featured-google-link]");
    const featuredGoogleIndex = section?.querySelector("[data-featured-google-index]");

    const updateFeatured = (id) => {
      const member = members.find((m) => m.id === id);
      if (!member || !section) return;

      const card = section.querySelector(`[data-member-id="${id}"]`);
      const gradient = card?.getAttribute("data-gradient") || "from-blue-500 to-indigo-600";
      const initials = card?.getAttribute("data-initials") || "";

      if (featuredName) featuredName.textContent = member.name;
      if (featuredTitle) featuredTitle.textContent = member.title;

      if (featuredSpecialization) {
        featuredSpecialization.textContent = member.specialization || "";
        featuredSpecialization.style.display = member.specialization ? "" : "none";
      }

      if (featuredNidn) {
        if (member.nidn && member.nidn !== "-") {
          featuredNidn.textContent = `NIDN ${member.nidn}`;
          featuredNidn.style.display = "";
        } else {
          featuredNidn.style.display = "none";
        }
      }

      if (featuredLink) {
        featuredLink.href = member.link || "#";
      }
      if (featuredLinkWrapper) {
        featuredLinkWrapper.style.display = member.link ? "flex" : "none";
      }

      if (featuredGoogleLink) {
        featuredGoogleLink.href = member.google_link || "#";
        featuredGoogleLink.classList.toggle("hidden", !member.google_link);
      }
      if (featuredGoogleIndex) {
        featuredGoogleIndex.textContent = member.google_index || "";
      }

      if (featuredVisual) {
        if (member.image) {
          featuredVisual.innerHTML = `<img src="${member.image.src}" alt="Portrait of ${member.name}" class="h-full w-full object-contain border-0" loading="eager" data-featured-image />`;
        } else {
          featuredVisual.innerHTML = `<div class="w-full h-full bg-gradient-to-br ${gradient} flex items-center justify-center" data-featured-initials><span class="text-white text-4xl md:text-5xl font-bold">${initials}</span></div>`;
        }
      }
    };

    const updateDiasporaFeatured = (id) => {
      const person = diasporaById.get(id);
      if (!person || !diasporaFeatured) return;

      const dName = diasporaFeatured.querySelector("[data-featured-name]");
      const dRole = diasporaFeatured.querySelector("[data-featured-role]");
      const dUniv = diasporaFeatured.querySelector("[data-featured-univ]");
      const dPast = diasporaFeatured.querySelector("[data-featured-past-experience]");
      const dResearch = diasporaFeatured.querySelector("[data-featured-notable-research]");
      const dImage = diasporaFeatured.querySelector("[data-featured-image]");
      const dFlag = diasporaFeatured.querySelector("[data-featured-flag]");
      const dBg = diasporaFeatured.querySelector("[data-featured-background]");
      const dProfile = diasporaFeatured.querySelector("[data-featured-profile]");
      const dGoogleLink = diasporaFeatured.querySelector("[data-featured-google-link]");
      const dGoogleIndex = diasporaFeatured.querySelector("[data-featured-google-index]");

      if (dName) dName.textContent = person.name;
      if (dRole) dRole.textContent = person.role;
      if (dUniv) dUniv.textContent = person.univ;
      if (dResearch) dResearch.textContent = person.notableResearch?.text || "";

      if (dPast) {
        dPast.innerHTML = (person.pastExperience?.items || [])
          .map(
            (item) =>
              `<li class="text-body-s flex items-start gap-3 text-white/90"><span class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-apu-accent" aria-hidden="true"></span>${item}</li>`
          )
          .join("");
      }

      if (dImage) {
        dImage.src = person.image.src;
        dImage.alt = `Portrait of ${person.name}`;
        if (typeof person.position === "number") {
          dImage.style.objectPosition = `${person.position}% center`;
        }
      }

      if (dFlag) {
        dFlag.src = person.flag;
        dFlag.alt = `Flag of ${person.country}`;
      }

      if (dBg) {
        dBg.src = person.background_image?.src || defaultBg;
        dBg.alt = person.name;
      }

      if (dProfile) {
        dProfile.href = person.google_scholar || "#";
      }
      if (dGoogleLink) {
        dGoogleLink.href = person.google_scholar || "#";
        dGoogleLink.classList.toggle("hidden", !person.google_scholar);
      }
      if (dGoogleIndex) {
        dGoogleIndex.textContent = person.h_index != null ? String(person.h_index) : "";
      }
    };

    const showStandard = () => {
      if (standardFeatured) standardFeatured.classList.remove("hidden");
      if (diasporaFeatured) diasporaFeatured.classList.add("hidden");
    };

    const showDiaspora = () => {
      if (standardFeatured) standardFeatured.classList.add("hidden");
      if (diasporaFeatured) diasporaFeatured.classList.remove("hidden");
    };

    section?.querySelectorAll("[data-member-id]").forEach((card) => {
      card.addEventListener("mousedown", (event) => {
        event.preventDefault();
      }, { signal });

      card.addEventListener("click", (event) => {
        event.preventDefault();
        const id = card.getAttribute("data-member-id");
        if (!id) return;

        if (diasporaById.has(id)) {
          showDiaspora();
          updateDiasporaFeatured(id);
        } else {
          showStandard();
          updateFeatured(id);
        }
      }, { signal });

      card.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          const id = card.getAttribute("data-member-id");
          if (!id) return;

          if (diasporaById.has(id)) {
            showDiaspora();
            updateDiasporaFeatured(id);
          } else {
            showStandard();
            updateFeatured(id);
          }
        }
      }, { signal });
    });

    const hashMatch = location.hash.match(/^#dosen-spotlight-(.+)/);
    if (hashMatch) {
      const id = hashMatch[1];
      if (diasporaById.has(id)) {
        showDiaspora();
        updateDiasporaFeatured(id);
      } else {
        showStandard();
        updateFeatured(id);
      }
    }

    const carousels = document.querySelectorAll("[data-lecturers-carousel]");
    carousels.forEach((root) => {
      const track = root.querySelector("[data-lecturers-track]");
      const controls = root.closest("section")?.querySelector("[data-lecturers-controls]");
      const prev = controls?.querySelector("[data-lecturers-prev]");
      const next = controls?.querySelector("[data-lecturers-next]");

      if (!track) return;

      const getGap = () => {
        const style = window.getComputedStyle(track);
        return parseInt(style.gap || "0", 10) || 0;
      };

      const getCardWidth = () => {
        const card = track.querySelector(":scope > article");
        return card?.offsetWidth || track.clientWidth;
      };

      const scrollStep = () => getCardWidth() + getGap();

      const scrollBy = (direction) => {
        track.scrollBy({ left: direction * scrollStep(), behavior: "smooth" });
      };

      prev?.addEventListener("click", () => scrollBy(-1), { signal });
      next?.addEventListener("click", () => scrollBy(1), { signal });

      track.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollBy(-1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollBy(1);
        }
      }, { signal });
    });
  })();
</script>

<style>
  .lecturers-featured-card {
    --apu-card-bg: rgb(var(--color-apu-navy));
    --apu-card-border: rgb(var(--color-apu-accent) / 0.22);
    --apu-card-shadow: 0 28px 80px rgb(var(--color-apu-navy) / 0.35);
    --apu-btn-primary-bg: rgb(var(--color-apu-accent));
    --apu-btn-primary-color: rgb(var(--color-apu-navy));
    --apu-btn-primary-hover-bg: rgb(var(--color-base-surface));
    --apu-btn-primary-hover-color: rgb(var(--color-apu-navy));
  }

  @media (max-width: 767px) {
    [data-featured-image] {
      max-height: 80vh;
    }
  }

  .lecturers-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-x;
    user-select: none;
    -webkit-user-select: none;
  }

  .lecturers-track::-webkit-scrollbar {
    display: none;
  }
</style>
