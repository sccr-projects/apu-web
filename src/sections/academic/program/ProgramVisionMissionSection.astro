---
import ScrollReveal from "@components/ScrollReveal.astro";
import SectionHeader from "@components/SectionHeader.astro";
import type { ProgramDetail } from "@data/program-details";
import BackgroundBlobs from "@components/BackgroundBlobs.astro";


interface Props {
  data: ProgramDetail;
  variant?: "default" | "biotechnology" | "communication" | "management";
}

const { data, variant = "default" } = Astro.props;
const { vision, mission } = data;
---

<section id="visi-misi" class="apu-section-shell relative overflow-hidden bg-brand-surface-alt">
    <BackgroundBlobs seed="ProgramVisionMissionSection" />

  <div class="content-max py-24 md:py-32">
    <ScrollReveal>
      <SectionHeader
        kicker="VISION & MISSION"
        title="Vision and Mission"
        class="text-center mb-16"
        titleClass="text-h2 text-brand-primary-deep mb-4"
      />
    </ScrollReveal>

    <!-- Vision Block -->
    <ScrollReveal class="mb-16 md:mb-20">
      <div class:list={[
        "apu-glass-card",
        "border-l-4",
        "border-[rgb(var(--color-apu-accent))]",
        "bg-gradient-to-r",
        "from-[rgb(var(--color-apu-navy)_/_0.06)]",
        "to-white/60",
        "p-8",
        "md:p-12",
        "mx-auto",
        variant === "communication" ? "max-w-5xl" : "max-w-4xl",
      ]}>
        <p class="text-mono text-brand-text-muted mb-4">VISION 2043</p>
        <blockquote class="text-h3 md:text-h2 text-brand-primary-deep font-normal leading-tight">
          "{vision}"
        </blockquote>
      </div>
    </ScrollReveal>

    <!-- Mission List -->
    {variant === "biotechnology" && (
      <div class="flex flex-wrap justify-center gap-6 md:gap-8 max-w-6xl mx-auto">
        {mission.map((item, index) => (
          <ScrollReveal
            delay={index * 100}
            direction={index % 2 === 0 ? 'left' : 'right'}
            class="w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.35rem)]"
          >
            <div class="apu-glass-card apu-interactive-card h-full min-h-[260px] p-6 md:p-8 flex flex-col gap-5">
              <span class="text-mono text-2xl text-[rgb(var(--color-apu-accent))] font-bold">
                {String(index + 1).padStart(2, '0')}
              </span>

              <p class="text-body text-brand-text leading-relaxed">
                {item}
              </p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    )}

    {variant === "management" && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-5xl mx-auto items-stretch">
        {mission.map((item, index) => {
          const isLastOdd = index === mission.length - 1 && mission.length % 2 !== 0;
          return (
            <ScrollReveal
              delay={index * 100}
              direction={index % 2 === 0 ? 'left' : 'right'}
              class={isLastOdd ? 'h-full md:col-span-2 md:justify-self-center md:w-[calc(50%-1rem)]' : 'h-full'}
            >
              <div class="apu-glass-card apu-interactive-card p-6 md:p-8 flex gap-5 items-start h-full">
                <span class="text-mono text-2xl text-[rgb(var(--color-apu-accent))] font-bold flex-shrink-0 mt-0.5">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <p class="text-body text-brand-text leading-relaxed">
                  {item}
                </p>
              </div>
            </ScrollReveal>
          );
        })}
      </div>
    )}

    {(variant === "default" || variant === "communication") && (
      <div class:list={[
        "grid",
        "grid-cols-1",
        "md:grid-cols-2",
        "gap-6",
        "md:gap-8",
        "max-w-5xl",
        "mx-auto",
      ]}>
        {mission.map((item, index) => (
          <ScrollReveal
            class={variant === "communication" ? "h-full" : undefined}
            delay={index * 100}
            direction={index % 2 === 0 ? 'left' : 'right'}
          >
            <div class:list={[
              "apu-glass-card",
              "apu-interactive-card",
              "p-6",
              "md:p-8",
              "flex",
              "gap-5",
              "items-start",
              variant === "communication" ? "h-full" : undefined,
            ]}>
              <span class="text-mono text-2xl text-[rgb(var(--color-apu-accent))] font-bold flex-shrink-0 mt-0.5">
                {String(index + 1).padStart(2, '0')}
              </span>
              <p class:list={[
                "leading-relaxed",
                variant === "communication" ? "text-body-s md:text-body text-brand-text" : "text-body text-brand-text",
              ]}>
                {item}
              </p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    )}
  </div>
</section>
