---
import { Image } from "astro:assets";
import ScrollReveal from "@components/ScrollReveal.astro";
import DiasporaFeaturedCard from "@components/DiasporaFeaturedCard.astro";
import { people } from "@data/diaspora";
const featuredLecturer = people.find((p) => p.id === "prof-agung") ?? people[0];
import canada from "@/assets/images/academic/canada-bg.jpg";
import BackgroundBlobs from "@/components/BackgroundBlobs.astro";

const directoryTitle = "Faculty Directory";
const sectionTitle = "Diaspora Lecturers List:";
---

<section
  id="lecturers"
  class="apu-section-shell relative overflow-hidden bg-brand-surface"
  aria-label={directoryTitle}
  data-people={JSON.stringify(people)}
  data-default-bg={canada.src}
>
    <BackgroundBlobs seed="DiasporaDetailsSection" />
  <div>
    {/* Featured researcher */}
    <ScrollReveal>
      <div class="apu-glass-card rounded-none lecturers-featured-card mb-10 overflow-hidden flex justify-center relative">
        <DiasporaFeaturedCard person={featuredLecturer} />
      </div>
    </ScrollReveal>

    {/* Faculty directory */}
      <div class="mb-6 flex items-end justify-between gap-6 px-4 md:px-10">
        <ScrollReveal class="flex-1">
          <h2 class="font-epilogue font-semibold text-2xl text-apu-navy md:text-4xl">{sectionTitle}</h2>
      </ScrollReveal>

      <div
        class="hidden items-center gap-2 md:flex"
        data-lecturers-controls
      >
        <button
          type="button"
          data-lecturers-prev
          aria-label="Previous lecturers"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-brand-border bg-white/80 text-brand-primary-deep shadow-sm transition hover:bg-white hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m15 18-6-6 6-6" />
          </svg>
        </button>
        <button
          type="button"
          data-lecturers-next
          aria-label="Next lecturers"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-brand-border bg-white/80 text-brand-primary-deep shadow-sm transition hover:bg-white hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
        </button>
      </div>
    </div>

    <ScrollReveal delay={150}>
      <div data-lecturers-carousel class="px-4 md:px-10">
        <div
          data-lecturers-track
        class="lecturers-track flex snap-x snap-mandatory gap-4 overflow-x-auto pb-6"
          tabindex="0"
          aria-label="Faculty directory carousel"
        >
          {people.map((person) => (
            <article
              class="group apu-corner-accent--tr apu-glass-card apu-interactive-card w-[82%] flex-shrink-0 snap-start cursor-pointer p-4 sm:p-5 sm:w-[47%] lg:w-[calc(15%-0.75rem)]"
              data-person-id={person.id}
              tabindex="0"
              role="button"
            >
              <div class="mb-5 aspect-[3/4] overflow-hidden rounded-xl ">
                <Image
                  draggable="false"
                  src={person.image}
                  alt={`Portrait of ${person.name}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <h3 draggable="false" class="text-2xl font-semibold text-brand-text mb-1">
                <a draggable="false" href={person.href} class="hover:underline">
                  {person.name}
                </a>
              </h3>
              <p class="text-caption text-brand-text-muted mb-4">
                {person.univ}
              </p>
            </article>
          ))}
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<script is:inline data-astro-rerun>
  (function () {
    var abortController = window.__apuDiasporaDetailsAbort;
    if (abortController) abortController.abort();
    abortController = new AbortController();
    window.__apuDiasporaDetailsAbort = abortController;
    var signal = abortController.signal;

    const section = document.querySelector("#lecturers");
    const peopleData = JSON.parse(section?.getAttribute("data-people") || "[]");

    const featuredName = section?.querySelector("[data-featured-name]");
    const featuredRole = section?.querySelector("[data-featured-role]");
    const featuredUniv = section?.querySelector("[data-featured-univ]");
    const featuredPast = section?.querySelector("[data-featured-past-experience]");
    const featuredResearch = section?.querySelector("[data-featured-notable-research]");
    const featuredImage = section?.querySelector("[data-featured-image]");
    const featuredFlag = section?.querySelector("[data-featured-flag]");
    const featuredBackground = section?.querySelector("[data-featured-background]");
    const defaultBg = section?.getAttribute("data-default-bg") || "";
    const featuredProfile = section?.querySelector("[data-featured-profile]");

    const updateFeatured = (id) => {
      const person = peopleData.find((p) => p.id === id);
      if (!person || !section) return;

      if (featuredName) featuredName.textContent = person.name;
      if (featuredRole) featuredRole.textContent = person.role;
      if (featuredUniv) featuredUniv.textContent = person.univ;
      if (featuredResearch) featuredResearch.textContent = person.notableResearch.text;

      if (featuredPast) {
        featuredPast.innerHTML = person.pastExperience.items
          .map(
            (item) =>
              `<li class="text-body-s flex items-start gap-3 text-white/90"><span class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-apu-accent" aria-hidden="true"></span>${item}</li>`
          )
          .join("");
      }

      if (featuredImage) {
        featuredImage.src = person.image.src;
        featuredImage.alt = `Portrait of ${person.name}`;
        featuredImage.style.objectPosition = `${person.position}% center`;
      }

      if (featuredFlag) {
        featuredFlag.src = person.flag;
        featuredFlag.alt = `Flag of ${person.country}`;
      }

      if (featuredBackground) {
        featuredBackground.src = person.background_image?.src || defaultBg;
        featuredBackground.alt = person.name;
      }

      if (featuredProfile) {
        featuredProfile.href = person.google_scholar || "#";
      }
    };

    section?.querySelectorAll("[data-person-id]").forEach((card) => {
      card.addEventListener("click", (event) => {
        event.preventDefault();
        const id = card.getAttribute("data-person-id");
        if (id) {
          updateFeatured(id);
          history.replaceState(null, "", `#lecturers-${id}`);
        }
      }, { signal });
      card.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          const id = card.getAttribute("data-person-id");
          if (id) {
            updateFeatured(id);
            history.replaceState(null, "", `#lecturers-${id}`);
          }
        }
      }, { signal });
    });

    document.addEventListener("diaspora:select", (event) => {
      const id = event.detail?.id;
      if (id) updateFeatured(id);
    }, { signal });

    const hashMatch = location.hash.match(/^#lecturers-(.+)/);
    if (hashMatch) updateFeatured(hashMatch[1]);

    const carousels = document.querySelectorAll("[data-lecturers-carousel]");

    carousels.forEach((root) => {
      const track = root.querySelector("[data-lecturers-track]");
      const controls = root.closest("section")?.querySelector("[data-lecturers-controls]");
      const prev = controls?.querySelector("[data-lecturers-prev]");
      const next = controls?.querySelector("[data-lecturers-next]");

      if (!track) return;

      const getGap = () => {
        const style = window.getComputedStyle(track);
        return parseInt(style.gap || "0", 10) || 0;
      };

      const getCardWidth = () => {
        const card = track.querySelector(":scope > article");
        return card?.offsetWidth || track.clientWidth;
      };

      const scrollStep = () => getCardWidth() + getGap();

      const updateButtons = () => {
        if (!prev || !next) return;
        const maxScroll = track.scrollWidth - track.clientWidth;
        prev.disabled = track.scrollLeft <= 0;
        next.disabled = track.scrollLeft >= maxScroll - 1;
        prev.style.opacity = prev.disabled ? "0.4" : "";
        next.style.opacity = next.disabled ? "0.4" : "";
      };

      const scrollBy = (direction) => {
        track.scrollBy({ left: direction * scrollStep(), behavior: "smooth" });
      };

      prev?.addEventListener("click", () => scrollBy(-1), { signal });
      next?.addEventListener("click", () => scrollBy(1), { signal });

      track.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollBy(-1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollBy(1);
        }
      }, { signal });

      track.addEventListener("scroll", updateButtons, { passive: true, signal });
      window.addEventListener("resize", updateButtons, { passive: true, signal });
      updateButtons();
    });
  })();
</script>

<style>
  .lecturers-featured-card {
    --apu-card-bg: rgb(var(--color-apu-navy));
    --apu-card-border: rgb(var(--color-apu-accent) / 0.22);
    --apu-card-shadow: 0 28px 80px rgb(var(--color-apu-navy) / 0.35);
    --apu-btn-primary-bg: rgb(var(--color-apu-accent));
    --apu-btn-primary-color: rgb(var(--color-apu-navy));
    --apu-btn-primary-hover-bg: rgb(var(--color-base-surface));
    --apu-btn-primary-hover-color: rgb(var(--color-apu-navy));
  }

  @media (max-width: 767px) {
    [data-featured-image] {
      max-height: 80vh;
    }
    .lecturers-featured-card [data-featured-flag] {
      height: 2.5rem;
      top: 0.5rem;
      right: 0.5rem;
    }
  }

  .lecturers-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
    touch-action: pan-x;
    user-select: none;
    -webkit-user-select: none;
  }

  .lecturers-track::-webkit-scrollbar {
    display: none;
  }
</style>
