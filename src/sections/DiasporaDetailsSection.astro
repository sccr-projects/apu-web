---
import ScrollReveal from "@components/ScrollReveal.astro";
import { people } from "@data/diaspora";
const featuredLecturer = people.find((p) => p.id === "prof-agung") ?? people[0];
import canada from "@/assets/images/academic/canada-bg.jpg";

const directoryTitle = "Faculty Directory";
const sectionTitle = "Lecturers List:";
---

<section
  id="lecturers"
  class="apu-section-shell relative overflow-hidden bg-brand-surface py-24 md:py-32"
  aria-label={directoryTitle}
  data-people={JSON.stringify(people)}
  data-default-bg={canada.src}
>
  <div>
    {/* Featured researcher */}
    <ScrollReveal>
      <div class="apu-glass-card rounded-none lecturers-featured-card mb-10 overflow-hidden flex justify-center py-10 relative">
          <img
            src={featuredLecturer.background_image?.src ?? canada.src}
            alt={featuredLecturer.name}
            class="pointer-events-none absolute top-0 left-0 w-full h-full object-cover opacity-30"
            aria-hidden="true"
            data-featured-background
          />
          <img
            src={featuredLecturer.flag}
            alt={`Flag of ${featuredLecturer.country}`}
            class="absolute right-4 top-4 h-20 opacity-75 w-auto rounded-sm shadow-lg"
            loading="eager"
            data-featured-flag
          />
        <div class="relative z-10 flex flex-row justify-center">
          <div class="order-2 w-1/2 flex flex-col justify-center md:order-1">
            <h2 class="text-h2 mb-3 text-white" data-featured-name>
              {featuredLecturer.name}
            </h2>
            <p class="text-body mb-3 text-apu-accent" data-featured-role>
              {featuredLecturer.role}
            </p>
            <!-- <p class="text-body mb-6 text-apu-accent text-sm">
              {department}
            </p> -->

            <div class="mb-6">
                <h3 class="text-body mb-6 text-apu-accent">
                   <p data-featured-univ>{featuredLecturer.univ}</p>
                </h3>
              <h3 class="text-caption mb-3 uppercase tracking-widest text-white/70">
                Past Experience
              </h3>
              <ul class="space-y-2" data-featured-past-experience>
                {featuredLecturer.pastExperience.items.map((item) => (
                  <li class="text-body-s flex items-start gap-3 text-white/90">
                    <span
                      class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-apu-accent"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <div class="mb-8">
              <h3 class="text-caption mb-3 uppercase tracking-widest text-white/70">
                Notable Research
              </h3>
              <p class="text-body-s leading-relaxed text-white/90" data-featured-notable-research>
                {featuredLecturer.notableResearch.text}
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-4">
              <a
                href={featuredLecturer.google_scholar}
                target="_blank"
                rel="noopener noreferrer"
                class="apu-btn apu-btn--primary inline-flex items-center gap-2"
                data-featured-profile
              >
                View Researcher Profile
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14"></path>
                  <path d="m12 5 7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>



          <div class="relative order-1 md:order-2 w-96">
            <div class="relative aspect-[4/5] overflow-hidden rounded-2xl md:aspect-auto md:h-full">
              <img
                src={featuredLecturer.image.src}
                alt={`Portrait of ${featuredLecturer.name}`}
                class="h-full w-full object-cover border-0"
                style={`object-position: ${featuredLecturer.position}% center;`}
                loading="eager"
                data-featured-image
              />

            </div>
          </div>
        </div>
      </div>
    </ScrollReveal>

    {/* Faculty directory */}
    <div class="mb-6 flex items-end justify-between gap-6 px-10">
      <ScrollReveal class="flex-1">
          <h2 class="font-epilogue font-semibold text-4xl text-apu-navy">{sectionTitle}</h2>
      </ScrollReveal>

      <div
        class="hidden items-center gap-2 md:flex"
        data-lecturers-controls
      >
        <button
          type="button"
          data-lecturers-prev
          aria-label="Previous lecturers"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-brand-border bg-white/80 text-brand-primary-deep shadow-sm transition hover:bg-white hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m15 18-6-6 6-6" />
          </svg>
        </button>
        <button
          type="button"
          data-lecturers-next
          aria-label="Next lecturers"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-brand-border bg-white/80 text-brand-primary-deep shadow-sm transition hover:bg-white hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-apu-accent))]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
        </button>
      </div>
    </div>

    <ScrollReveal delay={150}>
      <div data-lecturers-carousel class="px-10">
        <div
          data-lecturers-track
          class="lecturers-track flex snap-x snap-mandatory gap-4 overflow-x-auto pb-6"
          tabindex="0"
          aria-label="Faculty directory carousel"
        >
          {people.map((person) => (
            <article
              class="group apu-glass-card apu-interactive-card w-[82%] flex-shrink-0 snap-start cursor-pointer p-5 sm:w-[47%] lg:w-[calc(15%-0.75rem)]"
              data-person-id={person.id}
              tabindex="0"
              role="button"
            >
              <div class="mb-5 aspect-[3/4] overflow-hidden rounded-xl">
                <img
                  src={person.image.src}
                  alt={`Portrait of ${person.name}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <h3 class="text-2xl font-semibold text-brand-text mb-1">
                <a href={person.href} class="hover:underline">
                  {person.name}
                </a>
              </h3>
              <p class="text-caption text-brand-text-muted mb-4">
                {person.role}
              </p>
            </article>
          ))}
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector("#lecturers");
    const peopleData = JSON.parse(section?.getAttribute("data-people") || "[]");

    const featuredName = section?.querySelector("[data-featured-name]");
    const featuredRole = section?.querySelector("[data-featured-role]");
    const featuredUniv = section?.querySelector("[data-featured-univ]");
    const featuredPast = section?.querySelector("[data-featured-past-experience]");
    const featuredResearch = section?.querySelector("[data-featured-notable-research]");
    const featuredImage = section?.querySelector("[data-featured-image]") as HTMLImageElement | null;
    const featuredFlag = section?.querySelector("[data-featured-flag]") as HTMLImageElement | null;
    const featuredBackground = section?.querySelector("[data-featured-background]") as HTMLImageElement | null;
    const defaultBg = section?.getAttribute("data-default-bg") || "";
    const featuredProfile = section?.querySelector("[data-featured-profile]") as HTMLAnchorElement | null;

    const updateFeatured = (id: string) => {
      const person = peopleData.find((p: any) => p.id === id);
      if (!person || !section) return;

      if (featuredName) featuredName.textContent = person.name;
      if (featuredRole) featuredRole.textContent = person.role;
      if (featuredUniv) featuredUniv.textContent = person.univ;
      if (featuredResearch) featuredResearch.textContent = person.notableResearch.text;

      if (featuredPast) {
        featuredPast.innerHTML = person.pastExperience.items
          .map(
            (item: string) =>
              `<li class="text-body-s flex items-start gap-3 text-white/90"><span class="mt-2 inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-apu-accent" aria-hidden="true"></span>${item}</li>`
          )
          .join("");
      }

      if (featuredImage) {
        featuredImage.src = person.image.src;
        featuredImage.alt = `Portrait of ${person.name}`;
        featuredImage.style.objectPosition = `${person.position}% center`;
      }

      if (featuredFlag) {
        featuredFlag.src = person.flag;
        featuredFlag.alt = `Flag of ${person.country}`;
      }

      if (featuredBackground) {
        featuredBackground.src = person.background_image?.src || defaultBg;
        featuredBackground.alt = person.name;
      }

      if (featuredProfile) {
        featuredProfile.href = person.google_scholar || "#";
      }
    };

    section?.querySelectorAll("[data-person-id]").forEach((card) => {
      card.addEventListener("click", (event) => {
        event.preventDefault();
        const id = card.getAttribute("data-person-id");
        if (id) updateFeatured(id);
      });
      card.addEventListener("keydown", (event) => {
        const keyboardEvent = event as KeyboardEvent;
        if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
          keyboardEvent.preventDefault();
          const id = card.getAttribute("data-person-id");
          if (id) updateFeatured(id);
        }
      });
    });

    const carousels = document.querySelectorAll("[data-lecturers-carousel]");

    carousels.forEach((root) => {
      const track = root.querySelector("[data-lecturers-track]") as HTMLElement | null;
      const controls = root.closest("section")?.querySelector("[data-lecturers-controls]") as HTMLElement | null | undefined;
      const prev = controls?.querySelector("[data-lecturers-prev]") as HTMLButtonElement | null;
      const next = controls?.querySelector("[data-lecturers-next]") as HTMLButtonElement | null;

      if (!track) return;

      const getGap = () => {
        const style = window.getComputedStyle(track);
        return parseInt(style.gap || "0", 10) || 0;
      };

      const getCardWidth = () => {
        const card = track.querySelector(":scope > article") as HTMLElement | null;
        return card?.offsetWidth || track.clientWidth;
      };

      const scrollStep = () => getCardWidth() + getGap();

      const updateButtons = () => {
        if (!prev || !next) return;
        const maxScroll = track.scrollWidth - track.clientWidth;
        prev.disabled = track.scrollLeft <= 0;
        next.disabled = track.scrollLeft >= maxScroll - 1;
        prev.style.opacity = prev.disabled ? "0.4" : "";
        next.style.opacity = next.disabled ? "0.4" : "";
      };

      const scrollBy = (direction: number) => {
        track.scrollBy({ left: direction * scrollStep(), behavior: "smooth" });
      };

      prev?.addEventListener("click", () => scrollBy(-1));
      next?.addEventListener("click", () => scrollBy(1));

      track.addEventListener("keydown", (event: KeyboardEvent) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollBy(-1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollBy(1);
        }
      });

      track.addEventListener("scroll", updateButtons, { passive: true });
      window.addEventListener("resize", updateButtons, { passive: true });
      updateButtons();
    });
  })();
</script>

<style>
  .lecturers-featured-card {
    --apu-card-bg: rgb(var(--color-apu-navy));
    --apu-card-border: rgb(var(--color-apu-accent) / 0.22);
    --apu-card-shadow: 0 28px 80px rgb(var(--color-apu-navy) / 0.35);
    --apu-btn-primary-bg: rgb(var(--color-apu-accent));
    --apu-btn-primary-color: rgb(var(--color-apu-navy));
    --apu-btn-primary-hover-bg: rgb(var(--color-base-surface));
    --apu-btn-primary-hover-color: rgb(var(--color-apu-navy));
  }

  .lecturers-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .lecturers-track::-webkit-scrollbar {
    display: none;
  }
</style>
