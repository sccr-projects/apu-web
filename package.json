{
  "name": "kimi-claw",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "astro:dev": "bunx --bun astro dev --port 4322 --host",
    "astro:build": "bunx --bun astro build",
    "astro:preview": "bunx --bun astro preview --port 4322",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "build": "bun run astro:build",
    "build:frontend": "bunx --bun astro build --config astro.config.static.mjs",
    "preview": "bun run astro:preview",
    "dev": "bun run docker:up && bun run astro:dev",
    "dev:frontend": "bun run astro:dev",
    "up": "bun run dev"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/node": "^10.1.1",
    "@directus/sdk": "^21.3.0",
    "@fontsource/epilogue": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "alpinejs": "^3.15.12",
    "astro": "^6.3.5",
    "directus": "^11.17.4",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/leaflet": "^1.9.21",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "entities": "4.5.0",
    "typescript": "^6.0.3"
  }
}