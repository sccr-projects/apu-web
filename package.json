{
  "name": "kimi-claw",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "astro:dev": "bunx astro dev --port 4322",
    "astro:build": "bunx astro build",
    "astro:preview": "bunx astro preview --port 4322",
    "directus:bootstrap": "bunx directus bootstrap",
    "directus:start": "bunx directus start",
    "build": "bun run astro:build",
    "preview": "bun run astro:preview",
    "dev": "bun run directus:bootstrap && bun run dev:all",
    "dev:all": "bunx concurrently -n directus,astro -c cyan,magenta \"bun run directus:start\" \"bun run astro:dev\"",
    "up": "bun run dev"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@directus/sdk": "^21.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.5",
    "directus": "^11.17.4",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "entities": "4.5.0"
  }
}
